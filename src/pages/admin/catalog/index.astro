---
import Admin from '../../../layouts/Admin.astro';
---

<Admin title="Catalog" current="catalog">
  <div class="catalog-header">
    <h1>Catalog</h1>
    <a href="/admin/catalog/new" class="btn-new">+ New Release</a>
  </div>

  <div class="status-tabs" id="status-tabs">
    <button class="tab active" data-status="all">All</button>
    <button class="tab" data-status="draft">Draft</button>
    <button class="tab" data-status="published">Published</button>
  </div>

  <div id="loading" style="color: var(--color-muted);"><span class="loading-dots">Loading releases</span></div>
  <div id="error" class="login-error" style="display:none;"></div>
  <div id="empty" style="display:none; color: var(--color-muted); padding: var(--space-md) 0;">No releases found.</div>

  <div class="table-wrap" id="table-wrap" style="display:none;">
    <table class="release-table">
      <thead>
        <tr>
          <th>Code</th>
          <th>Title</th>
          <th>Entity</th>
          <th>Status</th>
          <th>Release Date</th>
          <th>Tracks</th>
          <th>Created By</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody id="release-tbody"></tbody>
    </table>
  </div>

  <!-- Delete confirmation dialog -->
  <div class="dialog-overlay" id="delete-dialog" style="display:none;">
    <div class="dialog">
      <p>Delete release <strong id="delete-code"></strong>?</p>
      <p style="color: var(--color-muted); font-size: var(--text-sm); margin-top: var(--space-xs);">This action cannot be undone.</p>
      <div class="dialog-actions">
        <button class="btn-cancel" id="delete-cancel">Cancel</button>
        <button class="btn-danger" id="delete-confirm">Delete</button>
      </div>
    </div>
  </div>
</Admin>

<style>
  .catalog-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }
  .catalog-header h1 {
    margin-bottom: 0;
    border-bottom: none;
    padding-bottom: 0;
  }
  .btn-new {
    display: inline-block;
    padding: var(--space-xs) var(--space-sm);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: bold;
    text-transform: uppercase;
    letter-spacing: 1pt;
    background: #1a1a1a;
    color: #fff;
    border: none;
    cursor: pointer;
    text-decoration: none;
  }
  .btn-new:hover { background: #333; }

  .status-tabs {
    display: flex;
    gap: 0;
    margin: var(--space-md) 0;
    border-bottom: 2px solid var(--color-text);
  }
  .tab {
    padding: var(--space-xs) var(--space-sm);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    text-transform: uppercase;
    letter-spacing: 0.5pt;
    background: none;
    border: 1px solid var(--color-border);
    border-bottom: none;
    cursor: pointer;
    color: var(--color-muted);
    margin-bottom: -2px;
  }
  .tab:hover { color: var(--color-text); }
  .tab.active {
    color: var(--color-text);
    font-weight: bold;
    border-color: var(--color-text);
    border-bottom: 2px solid var(--color-bg);
  }

  .table-wrap {
    overflow-x: auto;
  }
  .release-table {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--text-sm);
  }
  .release-table th {
    text-align: left;
    text-transform: uppercase;
    letter-spacing: 0.5pt;
    font-size: 0.7rem;
    padding: var(--space-xs) var(--space-sm);
    border-bottom: 2px solid var(--color-text);
    color: var(--color-muted);
    white-space: nowrap;
  }
  .release-table td {
    padding: var(--space-xs) var(--space-sm);
    border-bottom: 1px solid var(--color-border);
    vertical-align: middle;
  }

  .badge {
    display: inline-block;
    padding: 2px 8px;
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.5pt;
    border: 1px solid;
  }
  .badge--draft {
    color: var(--color-muted);
    border-color: var(--color-border);
  }
  .badge--published {
    color: var(--color-accent);
    border-color: var(--color-accent);
  }

  .action-btn {
    background: none;
    border: 1px solid var(--color-border);
    color: var(--color-text);
    font-family: var(--font-mono);
    font-size: 0.65rem;
    padding: 2px 6px;
    cursor: pointer;
    text-transform: uppercase;
    text-decoration: none;
    display: inline-block;
    margin-right: 2px;
    margin-bottom: 2px;
  }
  .action-btn:hover { background: var(--color-text); color: var(--color-bg); }
  .action-btn--danger { border-color: #c00; color: #c00; }
  .action-btn--danger:hover { background: #c00; color: #fff; }
  .action-btn--publish { border-color: var(--color-accent); color: var(--color-accent); }
  .action-btn--publish:hover { background: var(--color-accent); color: #fff; }

  .dialog-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.4);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 200;
  }
  .dialog {
    background: #fff;
    padding: var(--space-md);
    border: 2px solid var(--color-text);
    max-width: 400px;
    width: 90%;
    font-family: var(--font-mono);
  }
  .dialog-actions {
    display: flex;
    gap: var(--space-sm);
    margin-top: var(--space-md);
    justify-content: flex-end;
  }
  .btn-cancel {
    padding: var(--space-xs) var(--space-sm);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    text-transform: uppercase;
    background: none;
    border: 1px solid var(--color-border);
    cursor: pointer;
  }
  .btn-cancel:hover { border-color: var(--color-text); }
  .btn-danger {
    padding: var(--space-xs) var(--space-sm);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: bold;
    text-transform: uppercase;
    background: #c00;
    color: #fff;
    border: none;
    cursor: pointer;
  }
  .btn-danger:hover { background: #a00; }

  @media (max-width: 640px) {
    .release-table th:nth-child(6),
    .release-table td:nth-child(6),
    .release-table th:nth-child(7),
    .release-table td:nth-child(7) {
      display: none;
    }
  }
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    if (!document.getElementById('release-tbody')) return;

    let allReleases: any[] = [];
    let currentFilter = 'all';
    let deleteTarget: string | null = null;

    document.body.addEventListener('auth-ready', (() => {
      loadReleases();
    }) as EventListener, { once: true });

    // Tab switching
    document.getElementById('status-tabs')?.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest('.tab') as HTMLButtonElement | null;
      if (!btn) return;
      currentFilter = btn.dataset.status || 'all';
      document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
      btn.classList.add('active');
      renderTable();
    });

    async function loadReleases() {
      const loadingEl = document.getElementById('loading')!;
      const errorEl = document.getElementById('error')!;
      loadingEl.style.display = 'block';
      errorEl.style.display = 'none';

      try {
        const res = await fetch('/api/releases?status=all', { credentials: 'include' });
        if (!res.ok) throw new Error('Failed to load releases');
        const data = await res.json();
        allReleases = data.releases || data;
        loadingEl.style.display = 'none';
        renderTable();
      } catch (err: any) {
        loadingEl.style.display = 'none';
        errorEl.textContent = err.message;
        errorEl.style.display = 'block';
      }
    }

    function renderTable() {
      const tbody = document.getElementById('release-tbody')!;
      const tableWrap = document.getElementById('table-wrap')!;
      const emptyEl = document.getElementById('empty')!;

      const filtered = currentFilter === 'all'
        ? allReleases
        : allReleases.filter((r: any) => r.status === currentFilter);

      if (filtered.length === 0) {
        tableWrap.style.display = 'none';
        emptyEl.style.display = 'block';
        return;
      }

      emptyEl.style.display = 'none';
      tableWrap.style.display = 'block';

      tbody.innerHTML = filtered.map((r: any) => {
        const entities = (r.entities || []).map((e: any) => e.name).join(', ') || '—';
        const badgeClass = r.status === 'published' ? 'badge--published' : 'badge--draft';
        const date = r.release_date || '—';
        const trackCount = r.track_count ?? r.tracks?.length ?? '—';
        const createdBy = r.created_by_name || r.created_by || '—';
        const toggleBtn = r.status === 'published'
          ? `<button class="action-btn" data-action="unpublish" data-code="${r.product_code}">Unpublish</button>`
          : `<button class="action-btn action-btn--publish" data-action="publish" data-code="${r.product_code}">Publish</button>`;

        return `<tr>
          <td style="white-space:nowrap; font-weight:bold;">${r.product_code}</td>
          <td>${r.title || '(untitled)'}</td>
          <td>${entities}</td>
          <td><span class="badge ${badgeClass}">${r.status}</span></td>
          <td style="white-space:nowrap;">${date}</td>
          <td>${trackCount}</td>
          <td>${createdBy}</td>
          <td style="white-space:nowrap;">
            <a class="action-btn" href="/admin/catalog/edit?code=${encodeURIComponent(r.product_code)}">Edit</a>
            <a class="action-btn" href="/catalog/release?code=${encodeURIComponent(r.product_code)}" target="_blank">Preview</a>
            ${toggleBtn}
            <button class="action-btn action-btn--danger" data-action="delete" data-code="${r.product_code}">Delete</button>
          </td>
        </tr>`;
      }).join('');
    }

    // Action delegation
    document.getElementById('release-tbody')?.addEventListener('click', async (e) => {
      const btn = (e.target as HTMLElement).closest('[data-action]') as HTMLElement | null;
      if (!btn) return;

      const action = btn.dataset.action;
      const code = btn.dataset.code;
      if (!code) return;

      if (action === 'publish' || action === 'unpublish') {
        try {
          const res = await fetch(`/api/releases/${encodeURIComponent(code)}/${action}`, {
            method: 'POST',
            credentials: 'include',
          });
          if (!res.ok) {
            const err = await res.json().catch(() => ({ detail: 'Request failed' }));
            alert(err.detail || 'Request failed');
            return;
          }
          await loadReleases();
        } catch {
          alert('Network error');
        }
      }

      if (action === 'delete') {
        deleteTarget = code;
        document.getElementById('delete-code')!.textContent = code;
        document.getElementById('delete-dialog')!.style.display = 'flex';
      }
    });

    // Delete dialog
    document.getElementById('delete-cancel')?.addEventListener('click', () => {
      document.getElementById('delete-dialog')!.style.display = 'none';
      deleteTarget = null;
    });

    document.getElementById('delete-confirm')?.addEventListener('click', async () => {
      if (!deleteTarget) return;
      const btn = document.getElementById('delete-confirm') as HTMLButtonElement;
      btn.disabled = true;
      btn.textContent = 'Deleting...';

      try {
        const res = await fetch(`/api/releases/${encodeURIComponent(deleteTarget)}`, {
          method: 'DELETE',
          credentials: 'include',
        });
        if (!res.ok) {
          const err = await res.json().catch(() => ({ detail: 'Delete failed' }));
          alert(err.detail || 'Delete failed');
        } else {
          await loadReleases();
        }
      } catch {
        alert('Network error');
      }

      document.getElementById('delete-dialog')!.style.display = 'none';
      btn.disabled = false;
      btn.textContent = 'Delete';
      deleteTarget = null;
    });
  });
</script>
