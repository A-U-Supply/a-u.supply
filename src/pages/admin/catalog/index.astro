---
import Admin from '../../../layouts/Admin.astro';
---

<Admin title="Releases" current="catalog">
  <div class="page-header">
    <h1>Releases</h1>
    <a href="/admin/catalog/new" class="btn-primary">+ New Release</a>
  </div>

  <div
    class="status-tabs"
    id="status-tabs"
    style="margin-top: var(--space-md);"
  >
    <button class="tab active" data-status="all">All</button>
    <button class="tab" data-status="draft">Draft</button>
    <button class="tab" data-status="published">Published</button>
  </div>

  <div id="loading" style="color: var(--color-muted);">
    <span class="loading-dots">Loading releases</span>
  </div>
  <div id="error" class="login-error" style="display:none;"></div>
  <div id="empty" class="empty-state" style="display:none;">
    <div class="empty-state__icon">&#9744;</div>
    No releases found.
  </div>

  <div class="table-wrap" id="table-wrap" style="display:none;">
    <table class="release-table">
      <thead>
        <tr>
          <th>Code</th>
          <th>Title</th>
          <th>Entity</th>
          <th>Status</th>
          <th>Release Date</th>
          <th>Tracks</th>
          <th>Created By</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody id="release-tbody"></tbody>
    </table>
  </div>

  <!-- Delete confirmation dialog -->
  <div class="dialog-overlay" id="delete-dialog" style="display:none;">
    <div class="dialog">
      <p>Delete release <strong id="delete-code"></strong>?</p>
      <p
        style="color: var(--color-muted); font-size: var(--text-sm); margin-top: var(--space-xs);"
      >
        This action cannot be undone.
      </p>
      <div class="dialog-actions">
        <button class="btn-cancel" id="delete-cancel">Cancel</button>
        <button class="btn-danger" id="delete-confirm">Delete</button>
      </div>
    </div>
  </div>
</Admin>

<style>
  @media (max-width: 900px) {
    /* Entity, Tracks, Created By are secondary — drop them before the table scrolls */
    .release-table th:nth-child(3),
    .release-table td:nth-child(3),
    .release-table th:nth-child(6),
    .release-table td:nth-child(6),
    .release-table th:nth-child(7),
    .release-table td:nth-child(7) {
      display: none;
    }
  }
  @media (max-width: 540px) {
    /* Release date also drops on very small screens */
    .release-table th:nth-child(5),
    .release-table td:nth-child(5) {
      display: none;
    }
  }
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    if (!document.getElementById('release-tbody')) return;

    let allReleases: any[] = [];
    let currentFilter = 'all';
    let deleteTarget: string | null = null;

    (window as any).__authReady.then(() => loadReleases());

    // Tab switching
    document.getElementById('status-tabs')?.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest(
        '.tab',
      ) as HTMLButtonElement | null;
      if (!btn) return;
      currentFilter = btn.dataset.status || 'all';
      document
        .querySelectorAll('.tab')
        .forEach((t) => t.classList.remove('active'));
      btn.classList.add('active');
      renderTable();
    });

    async function loadReleases() {
      const loadingEl = document.getElementById('loading')!;
      const errorEl = document.getElementById('error')!;
      loadingEl.style.display = 'block';
      errorEl.style.display = 'none';

      try {
        const res = await fetch('/api/releases?status=all', {
          credentials: 'include',
        });
        if (!res.ok) throw new Error('Failed to load releases');
        const data = await res.json();
        allReleases = data.releases || data;
        loadingEl.style.display = 'none';
        renderTable();
      } catch (err: any) {
        loadingEl.style.display = 'none';
        errorEl.textContent = err.message;
        errorEl.style.display = 'block';
      }
    }

    function renderTable() {
      const tbody = document.getElementById('release-tbody')!;
      const tableWrap = document.getElementById('table-wrap')!;
      const emptyEl = document.getElementById('empty')!;

      const filtered =
        currentFilter === 'all'
          ? allReleases
          : allReleases.filter((r: any) => r.status === currentFilter);

      if (filtered.length === 0) {
        tableWrap.style.display = 'none';
        emptyEl.style.display = 'block';
        return;
      }

      emptyEl.style.display = 'none';
      tableWrap.style.display = 'block';

      tbody.innerHTML = filtered
        .map((r: any) => {
          const entities =
            (r.entities || []).map((e: any) => e.name).join(', ') || '—';
          const badgeClass =
            r.status === 'published' ? 'badge--published' : 'badge--draft';
          const date = r.release_date || '—';
          const trackCount = r.track_count ?? r.tracks?.length ?? '—';
          const createdBy = r.created_by_name || r.created_by || '—';
          const toggleBtn =
            r.status === 'published'
              ? `<button class="action-btn" data-action="unpublish" data-code="${r.product_code}">Unpublish</button>`
              : `<button class="action-btn action-btn--publish" data-action="publish" data-code="${r.product_code}">Publish</button>`;

          return `<tr>
          <td style="white-space:nowrap; font-weight:bold;">${r.product_code}</td>
          <td>${r.title || '(untitled)'}</td>
          <td>${entities}</td>
          <td><span class="badge ${badgeClass}">${r.status}</span></td>
          <td style="white-space:nowrap;">${date}</td>
          <td>${trackCount}</td>
          <td>${createdBy}</td>
          <td style="white-space:nowrap;">
            <a class="action-btn" href="/admin/catalog/edit?code=${encodeURIComponent(r.product_code)}">Edit</a>
            <a class="action-btn" href="/catalog/release?code=${encodeURIComponent(r.product_code)}" target="_blank">Preview</a>
            ${toggleBtn}
            <button class="action-btn action-btn--danger" data-action="delete" data-code="${r.product_code}">Delete</button>
          </td>
        </tr>`;
        })
        .join('');
    }

    // Action delegation
    document
      .getElementById('release-tbody')
      ?.addEventListener('click', async (e) => {
        const btn = (e.target as HTMLElement).closest(
          '[data-action]',
        ) as HTMLElement | null;
        if (!btn) return;

        const action = btn.dataset.action;
        const code = btn.dataset.code;
        if (!code) return;

        if (action === 'publish' || action === 'unpublish') {
          try {
            const res = await fetch(
              `/api/releases/${encodeURIComponent(code)}/${action}`,
              {
                method: 'POST',
                credentials: 'include',
              },
            );
            if (!res.ok) {
              const err = await res
                .json()
                .catch(() => ({ detail: 'Request failed' }));
              (window as any).toast.error(err.detail || 'Request failed');
              return;
            }
            await loadReleases();
          } catch {
            (window as any).toast.error('Network error');
          }
        }

        if (action === 'delete') {
          deleteTarget = code;
          document.getElementById('delete-code')!.textContent = code;
          document.getElementById('delete-dialog')!.style.display = 'flex';
        }
      });

    // Delete dialog
    document.getElementById('delete-cancel')?.addEventListener('click', () => {
      document.getElementById('delete-dialog')!.style.display = 'none';
      deleteTarget = null;
    });

    document
      .getElementById('delete-confirm')
      ?.addEventListener('click', async () => {
        if (!deleteTarget) return;
        const btn = document.getElementById(
          'delete-confirm',
        ) as HTMLButtonElement;
        btn.disabled = true;
        btn.textContent = 'Deleting...';

        try {
          const res = await fetch(
            `/api/releases/${encodeURIComponent(deleteTarget)}`,
            {
              method: 'DELETE',
              credentials: 'include',
            },
          );
          if (!res.ok) {
            const err = await res
              .json()
              .catch(() => ({ detail: 'Delete failed' }));
            (window as any).toast.error(err.detail || 'Delete failed');
          } else {
            await loadReleases();
          }
        } catch {
          (window as any).toast.error('Network error');
        }

        document.getElementById('delete-dialog')!.style.display = 'none';
        btn.disabled = false;
        btn.textContent = 'Delete';
        deleteTarget = null;
      });
  });
</script>
