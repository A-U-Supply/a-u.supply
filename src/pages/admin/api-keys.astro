---
import Admin from '../../layouts/Admin.astro';
---

<Admin title="API Keys" current="api-keys">
  <h1>API Keys</h1>

  <div class="new-key-form">
    <h2>Generate New Key</h2>
    <div class="form-row">
      <div class="form-group">
        <label class="form-label">Label</label>
        <input type="text" id="key-label" placeholder="e.g. Slack Bot, CI Pipeline" />
      </div>
      <div class="form-group">
        <label class="form-label">Scope</label>
        <select id="key-scope">
          <option value="read">Read</option>
          <option value="write">Write</option>
          <option value="admin">Admin</option>
        </select>
      </div>
      <button class="generate-btn" id="generate-btn">Generate Key</button>
    </div>
  </div>

  <div id="new-key-display" class="new-key-display" style="display:none;">
    <p class="new-key-warning">Copy this key now. It will not be shown again.</p>
    <div class="new-key-value">
      <code id="new-key-value"></code>
      <button class="action-btn" id="copy-key-btn">Copy</button>
    </div>
  </div>

  <div id="loading" style="color: var(--color-muted); margin-top: var(--space-md);"><span class="loading-dots">Loading</span></div>
  <div id="error" class="login-error" style="display:none;"></div>
  <div id="empty" style="display:none; color: var(--color-muted); padding: var(--space-md) 0;">No API keys found.</div>

  <div class="table-wrap" id="table-wrap" style="display:none;">
    <table class="release-table">
      <thead>
        <tr>
          <th>Label</th>
          <th>Key Prefix</th>
          <th>Scope</th>
          <th>Created</th>
          <th>Last Used</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody id="keys-tbody"></tbody>
    </table>
  </div>

  <!-- Revoke confirmation dialog -->
  <div class="dialog-overlay" id="revoke-dialog" style="display:none;">
    <div class="dialog">
      <p>Revoke API key <strong id="revoke-label"></strong>?</p>
      <p style="color: var(--color-muted); font-size: var(--text-sm); margin-top: var(--space-xs);">Any integrations using this key will stop working.</p>
      <div class="dialog-actions">
        <button class="btn-cancel" id="revoke-cancel">Cancel</button>
        <button class="btn-danger" id="revoke-confirm">Revoke</button>
      </div>
    </div>
  </div>
</Admin>

<style>
  .new-key-form {
    border: 1px solid var(--color-border);
    padding: var(--space-md);
    margin: var(--space-md) 0;
  }
  .new-key-form h2 {
    font-size: var(--text-lg);
    text-transform: uppercase;
    letter-spacing: 1pt;
    margin-bottom: var(--space-sm);
    padding-bottom: var(--space-xs);
    border-bottom: 2px solid var(--color-text);
  }
  .form-row {
    display: flex;
    gap: var(--space-sm);
    align-items: flex-end;
    flex-wrap: wrap;
  }
  .form-group {
    flex: 1;
    min-width: 150px;
  }
  .form-label {
    display: block;
    font-size: 0.65rem;
    color: var(--color-muted);
    text-transform: uppercase;
    letter-spacing: 0.5pt;
    margin-bottom: var(--space-xs);
  }
  .form-group input,
  .form-group select {
    width: 100%;
    padding: var(--space-xs) var(--space-sm);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    border: 1px solid var(--color-border);
    background: #fff;
    color: var(--color-text);
  }
  .form-group input:focus,
  .form-group select:focus {
    outline: 2px solid var(--color-accent);
    outline-offset: -1px;
  }
  .generate-btn {
    padding: var(--space-xs) var(--space-md);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: bold;
    text-transform: uppercase;
    letter-spacing: 1pt;
    background: #1a1a1a;
    color: #fff;
    border: none;
    cursor: pointer;
    white-space: nowrap;
  }
  .generate-btn:hover { background: #333; }
  .generate-btn:disabled { opacity: 0.5; cursor: not-allowed; }

  .new-key-display {
    background: #fffbe6;
    border: 2px solid var(--color-accent);
    padding: var(--space-md);
    margin-bottom: var(--space-md);
  }
  .new-key-warning {
    font-size: var(--text-sm);
    font-weight: bold;
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.5pt;
    margin-bottom: var(--space-sm);
  }
  .new-key-value {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    background: #fff;
    border: 1px solid var(--color-border);
    padding: var(--space-sm);
  }
  .new-key-value code {
    flex: 1;
    font-size: var(--text-sm);
    word-break: break-all;
    user-select: all;
  }

  .table-wrap {
    overflow-x: auto;
    margin-top: var(--space-md);
  }
  .release-table {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--text-sm);
  }
  .release-table th {
    text-align: left;
    text-transform: uppercase;
    letter-spacing: 0.5pt;
    font-size: 0.7rem;
    padding: var(--space-xs) var(--space-sm);
    border-bottom: 2px solid var(--color-text);
    color: var(--color-muted);
    white-space: nowrap;
  }
  .release-table td {
    padding: var(--space-xs) var(--space-sm);
    border-bottom: 1px solid var(--color-border);
    vertical-align: middle;
  }

  .badge {
    display: inline-block;
    padding: 2px 8px;
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.5pt;
    border: 1px solid;
  }
  .badge--read { color: #080; border-color: #080; }
  .badge--write { color: var(--color-accent); border-color: var(--color-accent); }
  .badge--admin { color: #c00; border-color: #c00; }

  .action-btn {
    background: none;
    border: 1px solid var(--color-border);
    color: var(--color-text);
    font-family: var(--font-mono);
    font-size: 0.65rem;
    padding: 2px 6px;
    cursor: pointer;
    text-transform: uppercase;
    text-decoration: none;
    display: inline-block;
  }
  .action-btn:hover { background: var(--color-text); color: var(--color-bg); }
  .action-btn--danger { border-color: #c00; color: #c00; }
  .action-btn--danger:hover { background: #c00; color: #fff; }

  .dialog-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.4);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 200;
  }
  .dialog {
    background: #fff;
    padding: var(--space-md);
    border: 2px solid var(--color-text);
    max-width: 400px;
    width: 90%;
    font-family: var(--font-mono);
  }
  .dialog-actions {
    display: flex;
    gap: var(--space-sm);
    margin-top: var(--space-md);
    justify-content: flex-end;
  }
  .btn-cancel {
    padding: var(--space-xs) var(--space-sm);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    text-transform: uppercase;
    background: none;
    border: 1px solid var(--color-border);
    cursor: pointer;
  }
  .btn-cancel:hover { border-color: var(--color-text); }
  .btn-danger {
    padding: var(--space-xs) var(--space-sm);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: bold;
    text-transform: uppercase;
    background: #c00;
    color: #fff;
    border: none;
    cursor: pointer;
  }
  .btn-danger:hover { background: #a00; }

  @media (max-width: 640px) {
    .form-row { flex-direction: column; }
    .release-table th:nth-child(4),
    .release-table td:nth-child(4),
    .release-table th:nth-child(5),
    .release-table td:nth-child(5) {
      display: none;
    }
  }
</style>

<script>
  document.addEventListener('astro:page-load', async () => {
    const tbody = document.getElementById('keys-tbody');
    if (!tbody) return;

    const user = await (window as any).__authReady;
    if (!user) return;

    const loadingEl = document.getElementById('loading')!;
    const errorEl = document.getElementById('error')!;
    const emptyEl = document.getElementById('empty')!;
    const tableWrap = document.getElementById('table-wrap')!;
    const generateBtn = document.getElementById('generate-btn') as HTMLButtonElement;
    const newKeyDisplay = document.getElementById('new-key-display')!;
    const newKeyValue = document.getElementById('new-key-value')!;

    let revokeTarget: string | null = null;

    async function loadKeys() {
      loadingEl.style.display = 'block';
      errorEl.style.display = 'none';
      emptyEl.style.display = 'none';
      tableWrap.style.display = 'none';

      try {
        const res = await fetch('/api/keys', { credentials: 'include' });
        if (!res.ok) throw new Error('Failed to load API keys');
        const data = await res.json();
        const keys = data.keys || data;
        loadingEl.style.display = 'none';

        if (keys.length === 0) {
          emptyEl.style.display = 'block';
          return;
        }

        emptyEl.style.display = 'none';
        tableWrap.style.display = 'block';

        tbody.innerHTML = keys.map((k: any) => {
          const badgeClass = k.scope === 'admin' ? 'badge--admin' : k.scope === 'write' ? 'badge--write' : 'badge--read';
          const created = k.created_at ? new Date(k.created_at).toLocaleDateString() : '--';
          const lastUsed = k.last_used_at ? new Date(k.last_used_at).toLocaleDateString() : 'Never';
          return `<tr>
            <td style="font-weight:bold;">${k.label || '--'}</td>
            <td style="font-family: var(--font-mono); color: var(--color-muted);">${k.key_prefix || '--'}...</td>
            <td><span class="badge ${badgeClass}">${k.scope || '--'}</span></td>
            <td style="white-space:nowrap;">${created}</td>
            <td style="white-space:nowrap;">${lastUsed}</td>
            <td>
              <button class="action-btn action-btn--danger" data-revoke="${k.id}" data-label="${k.label || k.key_prefix || 'this key'}">Revoke</button>
            </td>
          </tr>`;
        }).join('');
      } catch (err: any) {
        loadingEl.style.display = 'none';
        errorEl.textContent = err.message;
        errorEl.style.display = 'block';
      }
    }

    // Generate key
    generateBtn.addEventListener('click', async () => {
      const label = (document.getElementById('key-label') as HTMLInputElement).value.trim();
      const scope = (document.getElementById('key-scope') as HTMLSelectElement).value;

      if (!label) {
        alert('Please enter a label for the key');
        return;
      }

      generateBtn.disabled = true;
      generateBtn.textContent = 'Generating...';

      try {
        const res = await fetch('/api/keys', {
          method: 'POST',
          credentials: 'include',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ label, scope }),
        });
        if (!res.ok) {
          const err = await res.json().catch(() => ({ detail: 'Failed to generate key' }));
          alert(err.detail || 'Failed to generate key');
          return;
        }
        const data = await res.json();
        newKeyValue.textContent = data.key || data.api_key || '';
        newKeyDisplay.style.display = 'block';

        // Clear form
        (document.getElementById('key-label') as HTMLInputElement).value = '';
        (document.getElementById('key-scope') as HTMLSelectElement).value = 'read';

        loadKeys();
      } catch { alert('Network error'); }

      generateBtn.disabled = false;
      generateBtn.textContent = 'Generate Key';
    });

    // Copy key
    document.getElementById('copy-key-btn')?.addEventListener('click', async () => {
      const key = newKeyValue.textContent || '';
      try {
        await navigator.clipboard.writeText(key);
        const btn = document.getElementById('copy-key-btn')!;
        btn.textContent = 'Copied!';
        setTimeout(() => { btn.textContent = 'Copy'; }, 2000);
      } catch {
        // Fallback
        const range = document.createRange();
        range.selectNodeContents(newKeyValue);
        window.getSelection()?.removeAllRanges();
        window.getSelection()?.addRange(range);
      }
    });

    // Revoke delegation
    tbody.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest('[data-revoke]') as HTMLElement | null;
      if (btn) {
        revokeTarget = btn.dataset.revoke!;
        document.getElementById('revoke-label')!.textContent = btn.dataset.label || 'this key';
        document.getElementById('revoke-dialog')!.style.display = 'flex';
      }
    });

    document.getElementById('revoke-cancel')?.addEventListener('click', () => {
      document.getElementById('revoke-dialog')!.style.display = 'none';
      revokeTarget = null;
    });

    document.getElementById('revoke-confirm')?.addEventListener('click', async () => {
      if (!revokeTarget) return;
      const btn = document.getElementById('revoke-confirm') as HTMLButtonElement;
      btn.disabled = true;
      btn.textContent = 'Revoking...';

      try {
        const res = await fetch(`/api/keys/${revokeTarget}`, {
          method: 'DELETE',
          credentials: 'include',
        });
        if (!res.ok) {
          const err = await res.json().catch(() => ({ detail: 'Revoke failed' }));
          alert(err.detail || 'Revoke failed');
        } else {
          await loadKeys();
        }
      } catch { alert('Network error'); }

      document.getElementById('revoke-dialog')!.style.display = 'none';
      btn.disabled = false;
      btn.textContent = 'Revoke';
      revokeTarget = null;
    });

    loadKeys();
  });
</script>
