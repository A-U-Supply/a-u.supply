---
import Admin from '../../../layouts/Admin.astro';
---

<Admin title="Job Detail" current="jobs">
  <div class="page-header">
    <h1 id="job-title">Job</h1>
    <div class="header-actions">
      <a href="/admin/jobs" class="action-btn" style="text-decoration:none;">Back to Jobs</a>
    </div>
  </div>

  <div id="loading" style="color: var(--color-muted);"><span class="loading-dots">Loading</span></div>

  <div id="job-detail" style="display:none;">
    <div class="detail-grid">
      <div class="detail-row"><span class="detail-label">Status</span><span id="job-status"></span></div>
      <div class="detail-row"><span class="detail-label">App</span><span id="job-app"></span></div>
      <div class="detail-row"><span class="detail-label">Input Items</span><span id="job-items"></span></div>
      <div class="detail-row"><span class="detail-label">Created</span><span id="job-created"></span></div>
      <div class="detail-row"><span class="detail-label">Started</span><span id="job-started"></span></div>
      <div class="detail-row"><span class="detail-label">Completed</span><span id="job-completed"></span></div>
      <div class="detail-row"><span class="detail-label">Retries</span><span id="job-retries"></span></div>
    </div>

    <div id="job-params-section" style="display:none;">
      <h2>Parameters</h2>
      <pre id="job-params" class="log-block"></pre>
    </div>

    <div id="job-error-section" style="display:none;">
      <h2>Error</h2>
      <pre id="job-error" class="log-block error-block"></pre>
    </div>

    <div id="job-log-section" style="display:none;">
      <h2>Log Output</h2>
      <pre id="job-log" class="log-block"></pre>
    </div>

    <div id="job-outputs-section" style="display:none;">
      <h2>Outputs</h2>
      <div class="output-actions">
        <button class="action-btn" id="index-all-btn">Index All to Search</button>
        <button class="action-btn action-btn--danger" id="discard-all-btn">Discard All</button>
      </div>
      <div id="outputs-list" class="outputs-grid"></div>
    </div>
  </div>
</Admin>

<style>
  .page-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }
  .page-header h1 {
    margin-bottom: 0;
    border-bottom: none;
    padding-bottom: 0;
  }
  .detail-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    gap: var(--space-xs);
    margin-top: var(--space-md);
  }
  .detail-row {
    display: flex;
    gap: var(--space-sm);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    padding: var(--space-xs) 0;
    border-bottom: 1px solid var(--color-border);
  }
  .detail-label {
    color: var(--color-muted);
    min-width: 100px;
  }
  h2 {
    font-size: var(--text-base);
    margin-top: var(--space-lg);
    margin-bottom: var(--space-sm);
    border-bottom: 1px solid var(--color-border);
    padding-bottom: var(--space-xs);
  }
  .log-block {
    background: #0a0a0a;
    color: #e0e0e0;
    border: 1px solid var(--color-border);
    padding: var(--space-sm);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    overflow-x: auto;
    white-space: pre-wrap;
    word-break: break-all;
    max-height: 400px;
    overflow-y: auto;
  }
  .error-block { border-color: #e04040; }
  .output-actions {
    display: flex;
    gap: var(--space-sm);
    margin-bottom: var(--space-sm);
  }
  .outputs-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: var(--space-sm);
  }
  .output-card {
    border: 1px solid var(--color-border);
    padding: var(--space-sm);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
  }
  .output-card .output-name {
    font-weight: bold;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .output-card .output-meta {
    color: var(--color-muted);
    font-size: 0.65rem;
    margin-top: 2px;
  }
  .output-card .output-actions {
    margin-top: var(--space-xs);
    display: flex;
    gap: var(--space-xs);
  }
  .output-indexed {
    color: #40c040;
    font-size: 0.65rem;
  }
  .status-badge {
    display: inline-block;
    padding: 1px 6px;
    font-size: 0.65rem;
    text-transform: uppercase;
    font-family: var(--font-mono);
  }
  .status-pending { color: var(--color-muted); border: 1px solid var(--color-border); }
  .status-running { color: #f0c040; border: 1px solid #f0c040; }
  .status-completed { color: #40c040; border: 1px solid #40c040; }
  .status-failed { color: #e04040; border: 1px solid #e04040; }
  .status-cancelled { color: var(--color-muted); border: 1px solid var(--color-border); text-decoration: line-through; }
</style>

<script>
  document.addEventListener('astro:page-load', async () => {
    await (window as any).__authReady;

    const jobId = new URLSearchParams(window.location.search).get('id');
    if (!jobId) { window.location.href = '/admin/jobs'; return; }

    const loadingEl = document.getElementById('loading')!;
    const detailEl = document.getElementById('job-detail')!;
    const titleEl = document.getElementById('job-title')!;

    function formatSize(bytes: number): string {
      if (bytes < 1024) return bytes + ' B';
      if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(1) + ' KB';
      return (bytes / (1024 * 1024)).toFixed(1) + ' MB';
    }

    function formatDate(iso: string | null): string {
      if (!iso) return '-';
      return new Date(iso).toLocaleString();
    }

    async function loadJob() {
      const res = await fetch(`/api/jobs/${jobId}`, { credentials: 'include' });
      loadingEl.style.display = 'none';

      if (!res.ok) {
        detailEl.innerHTML = '<p style="color:var(--color-muted);">Job not found.</p>';
        detailEl.style.display = '';
        return;
      }

      const data = await res.json();
      const job = data.job;
      const outputs = data.outputs;

      detailEl.style.display = '';
      titleEl.textContent = `Job: ${job.app_name}`;

      document.getElementById('job-status')!.innerHTML = `<span class="status-badge status-${job.status}">${job.status}</span>`;
      document.getElementById('job-app')!.textContent = job.app_name;
      document.getElementById('job-items')!.textContent = String(job.input_item_count);
      document.getElementById('job-created')!.textContent = formatDate(job.created_at);
      document.getElementById('job-started')!.textContent = formatDate(job.started_at);
      document.getElementById('job-completed')!.textContent = formatDate(job.completed_at);
      document.getElementById('job-retries')!.textContent = String(job.retry_count);

      // Params
      const paramsSection = document.getElementById('job-params-section')!;
      if (Object.keys(job.params).length > 0) {
        paramsSection.style.display = '';
        document.getElementById('job-params')!.textContent = JSON.stringify(job.params, null, 2);
      }

      // Error
      const errorSection = document.getElementById('job-error-section')!;
      if (job.error_message) {
        errorSection.style.display = '';
        document.getElementById('job-error')!.textContent = job.error_message;
      }

      // Log
      const logSection = document.getElementById('job-log-section')!;
      if (job.log_tail) {
        logSection.style.display = '';
        document.getElementById('job-log')!.textContent = job.log_tail;
      }

      // Outputs
      const outputsSection = document.getElementById('job-outputs-section')!;
      if (outputs.length > 0) {
        outputsSection.style.display = '';
        const listEl = document.getElementById('outputs-list')!;

        listEl.innerHTML = outputs.map((o: any) => `
          <div class="output-card">
            <div class="output-name" title="${o.filename}">${o.filename}</div>
            <div class="output-meta">
              ${o.media_type || 'unknown'} &middot; ${o.file_size_bytes ? formatSize(o.file_size_bytes) : '?'}
            </div>
            ${o.indexed ? '<div class="output-indexed">indexed</div>' : ''}
            <div class="output-actions">
              <a href="/api/jobs/${jobId}/outputs/${o.id}/download" class="action-btn" style="text-decoration:none;">Download</a>
              ${!o.indexed ? `<button class="action-btn" data-index="${o.id}">Index</button>` : ''}
            </div>
          </div>
        `).join('');

        // Index buttons
        listEl.querySelectorAll('[data-index]').forEach(btn => {
          btn.addEventListener('click', async () => {
            const oid = (btn as HTMLElement).dataset.index;
            const res = await fetch(`/api/jobs/${jobId}/outputs/${oid}/index`, {
              method: 'POST', credentials: 'include' });
            if (res.ok) { loadJob(); }
            else { alert('Indexing failed'); }
          });
        });

        // Index all
        document.getElementById('index-all-btn')?.addEventListener('click', async () => {
          const unindexed = outputs.filter((o: any) => !o.indexed).map((o: any) => o.id);
          if (unindexed.length === 0) { alert('All outputs already indexed'); return; }
          const res = await fetch(`/api/jobs/${jobId}/outputs/index`, {
            method: 'POST', credentials: 'include',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ output_ids: unindexed }) });
          if (res.ok) { loadJob(); }
          else { alert('Bulk indexing failed'); }
        });

        // Discard all
        document.getElementById('discard-all-btn')?.addEventListener('click', async () => {
          if (!confirm('Delete all output files? Indexed items in search are not affected.')) return;
          await fetch(`/api/jobs/${jobId}/outputs`, {
            method: 'DELETE', credentials: 'include' });
          loadJob();
        });
      }
    }

    loadJob();

    // Auto-refresh if running
    const refreshInterval = setInterval(async () => {
      const statusEl = document.querySelector('.status-running, .status-pending');
      if (statusEl) { loadJob(); }
      else { clearInterval(refreshInterval); }
    }, 3000);
  });
</script>
