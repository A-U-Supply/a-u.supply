---
import Admin from '../../../layouts/Admin.astro';
---

<Admin title="The Queue" current="jobs">
  <div class="page-header">
    <h1>The Queue</h1>
    <div class="header-actions">
      <select id="filter-status" class="filter-select">
        <option value="">All statuses</option>
        <option value="pending">Pending</option>
        <option value="running">Running</option>
        <option value="completed">Completed</option>
        <option value="failed">Failed</option>
        <option value="cancelled">Cancelled</option>
      </select>
    </div>
  </div>

  <div id="batch-banner" class="batch-banner" style="display:none;">
    <span>
      Showing batch <code id="batch-banner-id"></code>
      (<span id="batch-banner-count">0</span> jobs)
    </span>
    <span class="batch-banner-actions">
      <a
        id="batch-banner-slop"
        class="action-btn"
        href="#"
        style="text-decoration:none;">View slop</a
      >
      <a class="action-btn" href="/admin/jobs" style="text-decoration:none;"
        >Clear filter</a
      >
    </span>
  </div>

  <div id="loading" style="color: var(--color-muted);">
    <span class="loading-dots">Loading</span>
  </div>
  <div id="empty" class="empty-state" style="display:none;">
    <div class="empty-state__icon">&#9881;</div>
    No jobs found.
  </div>

  <div class="queue-batch-bar" id="queue-batch-bar" style="display:none;">
    <span id="queue-selected-count">0 selected</span>
    <button class="action-btn action-btn--danger" id="bulk-discard-btn">
      Discard outputs to midden
    </button>
    <button class="action-btn" id="bulk-clear-btn">Clear selection</button>
  </div>

  <div class="table-wrap" id="jobs-table" style="display:none;">
    <table class="release-table">
      <thead>
        <tr>
          <th class="col-check">
            <input type="checkbox" id="select-all" aria-label="Select all" />
          </th>
          <th class="col-thumb" aria-label="Preview"></th>
          <th>Status</th>
          <th>App</th>
          <th>Items</th>
          <th>Created</th>
          <th>Duration</th>
          <th>Outputs</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody id="jobs-tbody"></tbody>
    </table>
  </div>

  <div class="pagination" id="pagination" style="display:none;">
    <button class="action-btn" id="prev-page">Prev</button>
    <span id="page-info">Page 1</span>
    <button class="action-btn" id="next-page">Next</button>
  </div>
</Admin>

<style>
  /* page-specific styles only — shared styles in admin.css */
  .batch-banner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
    margin-bottom: var(--space-md);
    padding: var(--space-sm) var(--space-md);
    border: 1px solid var(--color-border);
    border-left: 3px solid var(--color-text);
    background: rgba(255, 255, 255, 0.02);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
  }
  .batch-banner code {
    font-family: var(--font-mono);
    padding: 1px 6px;
    background: rgba(255, 255, 255, 0.05);
  }
  .batch-banner-actions {
    display: flex;
    gap: var(--space-xs);
  }
  .job-row--highlight {
    background: rgba(184, 134, 11, 0.08);
  }
  .job-app {
    font-family: var(--font-mono);
    word-break: break-word;
  }
  .job-actions {
    white-space: nowrap;
  }
  .job-actions .action-btn {
    margin-right: 2px;
  }

  .col-check {
    width: 28px;
  }
  .col-thumb {
    width: 48px;
  }
  .queue-batch-bar {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    padding: var(--space-xs) var(--space-sm);
    margin-bottom: var(--space-sm);
    border: 1px solid var(--color-accent);
    background: rgba(184, 134, 11, 0.06);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    flex-wrap: wrap;
  }
  .queue-batch-bar #queue-selected-count {
    margin-right: auto;
    color: var(--color-text);
    font-weight: bold;
  }
  .job-thumb {
    width: 40px;
    height: 40px;
    object-fit: cover;
    display: block;
    background: #111;
    border: 1px solid var(--color-border);
  }
  .job-thumb--placeholder {
    background: #eee;
    color: var(--color-muted);
    font-size: 0.6rem;
    text-transform: uppercase;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  @media (max-width: 760px) {
    .batch-banner {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-xs);
    }
    /* Card layout: drop the table grid, stack each row as a card */
    #jobs-table .release-table,
    #jobs-table .release-table tbody,
    #jobs-table .release-table tr,
    #jobs-table .release-table td {
      display: block;
    }
    #jobs-table .release-table thead {
      display: none;
    }
    #jobs-table .release-table tr {
      border: 1px solid var(--color-border);
      border-left: 3px solid var(--color-border);
      padding: var(--space-xs) var(--space-sm);
      margin-bottom: var(--space-xs);
    }
    #jobs-table .release-table tr.job-row--highlight {
      border-left-color: var(--color-accent);
    }
    #jobs-table .release-table td {
      padding: 2px 0;
      border: none;
      font-size: var(--text-sm);
    }
    /* Checkbox + thumbnail + status badge + app name share the top line */
    #jobs-table .release-table td.col-check,
    #jobs-table .release-table td.col-thumb,
    #jobs-table .release-table td[data-label='Status'],
    #jobs-table .release-table td.job-app {
      display: inline-block;
      vertical-align: middle;
      margin-right: var(--space-xs);
    }
    #jobs-table .release-table td.col-thumb .job-thumb {
      width: 32px;
      height: 32px;
    }
    #jobs-table .release-table td.job-app {
      font-weight: bold;
    }
    /* Meta rows (Items, Created, Duration, Outputs): label + value */
    #jobs-table .release-table td[data-label='Items']::before,
    #jobs-table .release-table td[data-label='Created']::before,
    #jobs-table .release-table td[data-label='Duration']::before,
    #jobs-table .release-table td[data-label='Outputs']::before {
      content: attr(data-label) ': ';
      color: var(--color-muted);
      font-size: 0.65rem;
      text-transform: uppercase;
      letter-spacing: 0.5pt;
      margin-right: var(--space-xs);
    }
    /* Hide zero-value meta rows so cards stay tight */
    #jobs-table .release-table td[data-label='Items'],
    #jobs-table .release-table td[data-label='Duration'],
    #jobs-table .release-table td[data-label='Outputs'] {
      display: inline-block;
      margin-right: var(--space-sm);
      color: var(--color-muted);
    }
    #jobs-table .release-table td[data-label='Created'] {
      display: block;
      color: var(--color-muted);
    }
    #jobs-table .release-table td.job-actions {
      display: flex;
      flex-wrap: wrap;
      gap: var(--space-xs);
      margin-top: var(--space-xs);
      padding-top: var(--space-xs);
      border-top: 1px dotted var(--color-border);
    }
    #jobs-table .release-table td.job-actions .action-btn {
      flex: 1;
      min-width: 70px;
      margin-right: 0;
      text-align: center;
      padding: var(--space-xs);
      font-size: var(--text-sm);
    }
  }
</style>

<script>
  document.addEventListener('astro:page-load', async () => {
    await (window as any).__authReady;

    const loadingEl = document.getElementById('loading')!;
    const emptyEl = document.getElementById('empty')!;
    const tableEl = document.getElementById('jobs-table')!;
    const tbodyEl = document.getElementById('jobs-tbody')!;
    const paginationEl = document.getElementById('pagination')!;
    const pageInfo = document.getElementById('page-info')!;
    const filterStatus = document.getElementById(
      'filter-status',
    ) as HTMLSelectElement;
    const selectAllEl = document.getElementById(
      'select-all',
    ) as HTMLInputElement;
    const batchBarEl = document.getElementById('queue-batch-bar')!;
    const batchCountEl = document.getElementById('queue-selected-count')!;
    const bulkDiscardBtn = document.getElementById(
      'bulk-discard-btn',
    ) as HTMLButtonElement;
    const bulkClearBtn = document.getElementById(
      'bulk-clear-btn',
    ) as HTMLButtonElement;

    const pageSize = 50;
    let totalJobs = 0;
    // Selection survives pagination in memory; only cleared on explicit
    // user action (Clear selection or after a successful bulk discard).
    const selectedIds = new Set<string>();

    // Read query params (filter status + pagination survives back-nav)
    function readParams(): {
      status: string;
      page: number;
      highlight: string | null;
      batchId: string | null;
    } {
      const u = new URLSearchParams(window.location.search);
      return {
        status: u.get('status') ?? '',
        page: Math.max(1, parseInt(u.get('page') ?? '1')),
        highlight: u.get('highlight'),
        batchId: u.get('batch_id'),
      };
    }

    function writeParams(
      patch: Partial<{ status: string; page: number }>,
      replace = false,
    ) {
      const u = new URLSearchParams(window.location.search);
      if ('status' in patch) {
        if (patch.status) u.set('status', patch.status);
        else u.delete('status');
      }
      if ('page' in patch) {
        if (patch.page && patch.page > 1) u.set('page', String(patch.page));
        else u.delete('page');
      }
      const q = u.toString();
      const url = q
        ? `${window.location.pathname}?${q}`
        : window.location.pathname;
      if (replace) history.replaceState(null, '', url);
      else history.pushState(null, '', url);
    }

    let {
      status: currentStatus,
      page: currentPage,
      highlight: highlightId,
      batchId,
    } = readParams();
    filterStatus.value = currentStatus;

    if (batchId) {
      const banner = document.getElementById('batch-banner')!;
      const idEl = document.getElementById('batch-banner-id')!;
      const slopLink = document.getElementById(
        'batch-banner-slop',
      ) as HTMLAnchorElement;
      idEl.textContent = batchId.slice(0, 8);
      slopLink.href = `/admin/search/slop?batch_id=${encodeURIComponent(batchId)}`;
      banner.style.display = '';
    }

    function updateBatchBar() {
      const n = selectedIds.size;
      if (n === 0) {
        batchBarEl.style.display = 'none';
      } else {
        batchBarEl.style.display = '';
        batchCountEl.textContent = `${n} selected`;
      }
      // Keep select-all in sync
      const rowChecks =
        tbodyEl.querySelectorAll<HTMLInputElement>('.job-select');
      const allChecked =
        rowChecks.length > 0 && Array.from(rowChecks).every((c) => c.checked);
      selectAllEl.checked = allChecked;
    }

    function formatDuration(job: any): string {
      if (!job.started_at) return '-';
      const end = job.completed_at ? new Date(job.completed_at) : new Date();
      const start = new Date(job.started_at);
      const secs = Math.round((end.getTime() - start.getTime()) / 1000);
      if (secs < 60) return `${secs}s`;
      return `${Math.floor(secs / 60)}m ${secs % 60}s`;
    }

    function formatDate(iso: string): string {
      const d = new Date(iso);
      return d.toLocaleString(undefined, {
        month: 'short',
        day: 'numeric',
        hour: '2-digit',
        minute: '2-digit',
      });
    }

    function renderThumbCell(j: any): string {
      if (j.preview_media_id) {
        const title = (j.preview_media_type || 'media').replace(/["<>&]/g, '');
        return `<img class="job-thumb" src="/api/media/${j.preview_media_id}/thumbnail" alt="" loading="lazy" title="${title}">`;
      }
      return `<div class="job-thumb job-thumb--placeholder">—</div>`;
    }

    async function loadJobs() {
      const status = currentStatus;
      const params = new URLSearchParams({
        page: String(currentPage),
        per_page: String(pageSize),
      });
      if (status) params.set('status', status);
      if (batchId) params.set('batch_id', batchId);

      const res = await fetch(`/api/jobs?${params}`, {
        credentials: 'include',
      });
      loadingEl.style.display = 'none';

      if (!res.ok) {
        emptyEl.style.display = '';
        return;
      }
      const data = await res.json();
      totalJobs = data.total;

      if (batchId) {
        const countEl = document.getElementById('batch-banner-count');
        if (countEl) countEl.textContent = String(totalJobs);
      }

      if (totalJobs === 0) {
        emptyEl.style.display = '';
        tableEl.style.display = 'none';
        updateBatchBar();
        return;
      }

      emptyEl.style.display = 'none';
      tableEl.style.display = '';

      tbodyEl.innerHTML = data.jobs
        .map(
          (j: any) => `
        <tr data-job-id="${j.id}"${j.id === highlightId ? ' class="job-row--highlight"' : ' class="job-row"'}>
          <td class="col-check"><input type="checkbox" class="job-select" data-job-id="${j.id}" aria-label="Select job" ${selectedIds.has(j.id) ? 'checked' : ''} /></td>
          <td class="col-thumb">${renderThumbCell(j)}</td>
          <td data-label="Status"><span class="status-badge status-${j.status}">${j.status}</span></td>
          <td data-label="App" class="job-app">${j.app_name}</td>
          <td data-label="Items">${j.input_item_count}</td>
          <td data-label="Created">${formatDate(j.created_at)}</td>
          <td data-label="Duration">${formatDuration(j)}</td>
          <td data-label="Outputs">${j.output_count > 0 ? j.output_count + ' files' : '-'}</td>
          <td class="job-actions">
            <a href="/admin/jobs/detail?id=${j.id}" class="action-btn" style="text-decoration:none;">View</a>
            ${
              j.status === 'pending' || j.status === 'running'
                ? `<button class="action-btn" data-cancel="${j.id}">Cancel</button>`
                : ''
            }
            ${
              j.status === 'failed'
                ? `<button class="action-btn" data-retry="${j.id}">Retry</button>`
                : ''
            }
          </td>
        </tr>
      `,
        )
        .join('');

      // Row checkbox → selection set
      tbodyEl
        .querySelectorAll<HTMLInputElement>('.job-select')
        .forEach((chk) => {
          chk.addEventListener('change', () => {
            const id = chk.dataset.jobId!;
            if (chk.checked) selectedIds.add(id);
            else selectedIds.delete(id);
            updateBatchBar();
          });
        });

      // Cancel buttons
      tbodyEl.querySelectorAll('[data-cancel]').forEach((btn) => {
        btn.addEventListener('click', async () => {
          const id = (btn as HTMLElement).dataset.cancel;
          await fetch(`/api/jobs/${id}/cancel`, {
            method: 'POST',
            credentials: 'include',
          });
          loadJobs();
        });
      });

      // Retry buttons
      tbodyEl.querySelectorAll('[data-retry]').forEach((btn) => {
        btn.addEventListener('click', async () => {
          const id = (btn as HTMLElement).dataset.retry;
          await fetch(`/api/jobs/${id}/retry`, {
            method: 'POST',
            credentials: 'include',
          });
          loadJobs();
        });
      });

      // Pagination
      const totalPages = Math.ceil(totalJobs / pageSize);
      paginationEl.style.display = totalPages > 1 ? 'flex' : 'none';
      pageInfo.textContent = `Page ${currentPage} of ${totalPages}`;

      updateBatchBar();
    }

    selectAllEl.addEventListener('change', () => {
      const checked = selectAllEl.checked;
      tbodyEl
        .querySelectorAll<HTMLInputElement>('.job-select')
        .forEach((chk) => {
          chk.checked = checked;
          const id = chk.dataset.jobId!;
          if (checked) selectedIds.add(id);
          else selectedIds.delete(id);
        });
      updateBatchBar();
    });

    bulkClearBtn.addEventListener('click', () => {
      selectedIds.clear();
      tbodyEl
        .querySelectorAll<HTMLInputElement>('.job-select')
        .forEach((chk) => (chk.checked = false));
      selectAllEl.checked = false;
      updateBatchBar();
    });

    bulkDiscardBtn.addEventListener('click', async () => {
      const ids = Array.from(selectedIds);
      if (ids.length === 0) return;
      const ok = await (window as any).confirmDialog(
        `Discard outputs from ${ids.length} job${ids.length !== 1 ? 's' : ''} to the midden? Files will be deleted in 24h unless rescued.`,
        'Discard to midden',
      );
      if (!ok) return;

      bulkDiscardBtn.disabled = true;
      // DELETE /api/jobs/{id}/outputs per job, in parallel.
      const results = await Promise.allSettled(
        ids.map((id) =>
          fetch(`/api/jobs/${id}/outputs`, {
            method: 'DELETE',
            credentials: 'include',
          }),
        ),
      );
      bulkDiscardBtn.disabled = false;

      let discarded = 0;
      let failed = 0;
      for (let i = 0; i < results.length; i++) {
        const r = results[i];
        if (r.status === 'fulfilled' && r.value.ok) {
          discarded++;
          // Remove the row from the DOM so the user sees immediate feedback.
          const row = tbodyEl.querySelector(`tr[data-job-id="${ids[i]}"]`);
          row?.remove();
          selectedIds.delete(ids[i]);
        } else {
          failed++;
        }
      }

      if (discarded > 0) {
        (window as any).toast.success(
          `Discarded outputs from ${discarded} job${discarded !== 1 ? 's' : ''}`,
        );
      }
      if (failed > 0) {
        (window as any).toast.error(
          `Failed on ${failed} job${failed !== 1 ? 's' : ''}`,
        );
      }

      updateBatchBar();
      // If we emptied the current page, reload so pagination/totals are honest.
      if (tbodyEl.children.length === 0) loadJobs();
    });

    filterStatus.addEventListener('change', () => {
      currentStatus = filterStatus.value;
      currentPage = 1;
      writeParams({ status: currentStatus, page: currentPage });
      loadJobs();
    });
    document.getElementById('prev-page')?.addEventListener('click', () => {
      if (currentPage > 1) {
        currentPage--;
        writeParams({ page: currentPage });
        loadJobs();
      }
    });
    document.getElementById('next-page')?.addEventListener('click', () => {
      if (currentPage * pageSize < totalJobs) {
        currentPage++;
        writeParams({ page: currentPage });
        loadJobs();
      }
    });

    // Browser back/forward: re-read params and reload
    const onPopState = () => {
      const p = readParams();
      currentStatus = p.status;
      currentPage = p.page;
      filterStatus.value = currentStatus;
      loadJobs();
    };
    window.addEventListener('popstate', onPopState);

    loadJobs();

    // Auto-refresh if there are running jobs
    const refreshTimer = window.setInterval(() => {
      if (
        tbodyEl.querySelector('.status-running') ||
        tbodyEl.querySelector('.status-pending')
      ) {
        loadJobs();
      }
    }, 5000);

    // Clean up on navigation away (astro ViewTransitions)
    document.addEventListener(
      'astro:before-swap',
      () => {
        window.clearInterval(refreshTimer);
        window.removeEventListener('popstate', onPopState);
      },
      { once: true },
    );
  });
</script>
