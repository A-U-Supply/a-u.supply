---
import Admin from '../../../layouts/Admin.astro';
---

<Admin title="The Queue" current="jobs">
  <div class="page-header">
    <h1>The Queue</h1>
    <div class="header-actions">
      <select id="filter-status" class="filter-select">
        <option value="">All statuses</option>
        <option value="pending">Pending</option>
        <option value="running">Running</option>
        <option value="completed">Completed</option>
        <option value="failed">Failed</option>
        <option value="cancelled">Cancelled</option>
      </select>
    </div>
  </div>

  <div id="batch-banner" class="batch-banner" style="display:none;">
    <span>
      Showing batch <code id="batch-banner-id"></code>
      (<span id="batch-banner-count">0</span> jobs)
    </span>
    <span class="batch-banner-actions">
      <a
        id="batch-banner-slop"
        class="action-btn"
        href="#"
        style="text-decoration:none;">View slop</a
      >
      <a class="action-btn" href="/admin/jobs" style="text-decoration:none;"
        >Clear filter</a
      >
    </span>
  </div>

  <div id="loading" style="color: var(--color-muted);">
    <span class="loading-dots">Loading</span>
  </div>
  <div id="empty" class="empty-state" style="display:none;">
    <div class="empty-state__icon">&#9881;</div>
    No jobs found.
  </div>

  <div class="table-wrap" id="jobs-table" style="display:none;">
    <table class="release-table">
      <thead>
        <tr>
          <th>Status</th>
          <th>App</th>
          <th>Items</th>
          <th>Created</th>
          <th>Duration</th>
          <th>Outputs</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody id="jobs-tbody"></tbody>
    </table>
  </div>

  <div class="pagination" id="pagination" style="display:none;">
    <button class="action-btn" id="prev-page">Prev</button>
    <span id="page-info">Page 1</span>
    <button class="action-btn" id="next-page">Next</button>
  </div>
</Admin>

<style>
  /* page-specific styles only — shared styles in admin.css */
  .batch-banner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
    margin-bottom: var(--space-md);
    padding: var(--space-sm) var(--space-md);
    border: 1px solid var(--color-border);
    border-left: 3px solid var(--color-text);
    background: rgba(255, 255, 255, 0.02);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
  }
  .batch-banner code {
    font-family: var(--font-mono);
    padding: 1px 6px;
    background: rgba(255, 255, 255, 0.05);
  }
  .batch-banner-actions {
    display: flex;
    gap: var(--space-xs);
  }
  .job-row--highlight {
    background: rgba(184, 134, 11, 0.08);
  }
  .job-app {
    font-family: var(--font-mono);
    word-break: break-word;
  }
  .job-actions {
    white-space: nowrap;
  }
  .job-actions .action-btn {
    margin-right: 2px;
  }

  @media (max-width: 760px) {
    .batch-banner {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-xs);
    }
    /* Card layout: drop the table grid, stack each row as a card */
    #jobs-table .release-table,
    #jobs-table .release-table tbody,
    #jobs-table .release-table tr,
    #jobs-table .release-table td {
      display: block;
    }
    #jobs-table .release-table thead {
      display: none;
    }
    #jobs-table .release-table tr {
      border: 1px solid var(--color-border);
      border-left: 3px solid var(--color-border);
      padding: var(--space-xs) var(--space-sm);
      margin-bottom: var(--space-xs);
    }
    #jobs-table .release-table tr.job-row--highlight {
      border-left-color: var(--color-accent);
    }
    #jobs-table .release-table td {
      padding: 2px 0;
      border: none;
      font-size: var(--text-sm);
    }
    /* First td: status badge — sits alongside app name */
    #jobs-table .release-table td:first-child {
      display: inline-block;
      margin-right: var(--space-xs);
    }
    #jobs-table .release-table td.job-app {
      display: inline-block;
      font-weight: bold;
      margin-bottom: var(--space-xs);
    }
    /* Meta rows (Items, Created, Duration, Outputs): label + value */
    #jobs-table .release-table td[data-label='Items']::before,
    #jobs-table .release-table td[data-label='Created']::before,
    #jobs-table .release-table td[data-label='Duration']::before,
    #jobs-table .release-table td[data-label='Outputs']::before {
      content: attr(data-label) ': ';
      color: var(--color-muted);
      font-size: 0.65rem;
      text-transform: uppercase;
      letter-spacing: 0.5pt;
      margin-right: var(--space-xs);
    }
    /* Hide zero-value meta rows so cards stay tight */
    #jobs-table .release-table td[data-label='Items'],
    #jobs-table .release-table td[data-label='Duration'],
    #jobs-table .release-table td[data-label='Outputs'] {
      display: inline-block;
      margin-right: var(--space-sm);
      color: var(--color-muted);
    }
    #jobs-table .release-table td[data-label='Created'] {
      display: block;
      color: var(--color-muted);
    }
    #jobs-table .release-table td.job-actions {
      display: flex;
      flex-wrap: wrap;
      gap: var(--space-xs);
      margin-top: var(--space-xs);
      padding-top: var(--space-xs);
      border-top: 1px dotted var(--color-border);
    }
    #jobs-table .release-table td.job-actions .action-btn {
      flex: 1;
      min-width: 70px;
      margin-right: 0;
      text-align: center;
      padding: var(--space-xs);
      font-size: var(--text-sm);
    }
  }
</style>

<script>
  document.addEventListener('astro:page-load', async () => {
    await (window as any).__authReady;

    const loadingEl = document.getElementById('loading')!;
    const emptyEl = document.getElementById('empty')!;
    const tableEl = document.getElementById('jobs-table')!;
    const tbodyEl = document.getElementById('jobs-tbody')!;
    const paginationEl = document.getElementById('pagination')!;
    const pageInfo = document.getElementById('page-info')!;
    const filterStatus = document.getElementById(
      'filter-status',
    ) as HTMLSelectElement;

    let currentPage = 1;
    const pageSize = 50;
    let totalJobs = 0;

    // Highlight param from workspace redirect
    const urlParams = new URLSearchParams(window.location.search);
    const highlightId = urlParams.get('highlight');
    const batchId = urlParams.get('batch_id');

    if (batchId) {
      const banner = document.getElementById('batch-banner')!;
      const idEl = document.getElementById('batch-banner-id')!;
      const slopLink = document.getElementById(
        'batch-banner-slop',
      ) as HTMLAnchorElement;
      idEl.textContent = batchId.slice(0, 8);
      slopLink.href = `/admin/search/slop?batch_id=${encodeURIComponent(batchId)}`;
      banner.style.display = '';
    }

    function formatDuration(job: any): string {
      if (!job.started_at) return '-';
      const end = job.completed_at ? new Date(job.completed_at) : new Date();
      const start = new Date(job.started_at);
      const secs = Math.round((end.getTime() - start.getTime()) / 1000);
      if (secs < 60) return `${secs}s`;
      return `${Math.floor(secs / 60)}m ${secs % 60}s`;
    }

    function formatDate(iso: string): string {
      const d = new Date(iso);
      return d.toLocaleString(undefined, {
        month: 'short',
        day: 'numeric',
        hour: '2-digit',
        minute: '2-digit',
      });
    }

    async function loadJobs() {
      const status = filterStatus.value;
      const params = new URLSearchParams({
        page: String(currentPage),
        per_page: String(pageSize),
      });
      if (status) params.set('status', status);
      if (batchId) params.set('batch_id', batchId);

      const res = await fetch(`/api/jobs?${params}`, {
        credentials: 'include',
      });
      loadingEl.style.display = 'none';

      if (!res.ok) {
        emptyEl.style.display = '';
        return;
      }
      const data = await res.json();
      totalJobs = data.total;

      if (batchId) {
        const countEl = document.getElementById('batch-banner-count');
        if (countEl) countEl.textContent = String(totalJobs);
      }

      if (totalJobs === 0) {
        emptyEl.style.display = '';
        tableEl.style.display = 'none';
        return;
      }

      emptyEl.style.display = 'none';
      tableEl.style.display = '';

      tbodyEl.innerHTML = data.jobs
        .map(
          (j: any) => `
        <tr${j.id === highlightId ? ' class="job-row--highlight"' : ' class="job-row"'}>
          <td data-label="Status"><span class="status-badge status-${j.status}">${j.status}</span></td>
          <td data-label="App" class="job-app">${j.app_name}</td>
          <td data-label="Items">${j.input_item_count}</td>
          <td data-label="Created">${formatDate(j.created_at)}</td>
          <td data-label="Duration">${formatDuration(j)}</td>
          <td data-label="Outputs">${j.output_count > 0 ? j.output_count + ' files' : '-'}</td>
          <td class="job-actions">
            <a href="/admin/jobs/detail?id=${j.id}" class="action-btn" style="text-decoration:none;">View</a>
            ${
              j.status === 'pending' || j.status === 'running'
                ? `<button class="action-btn" data-cancel="${j.id}">Cancel</button>`
                : ''
            }
            ${
              j.status === 'failed'
                ? `<button class="action-btn" data-retry="${j.id}">Retry</button>`
                : ''
            }
          </td>
        </tr>
      `,
        )
        .join('');

      // Cancel buttons
      tbodyEl.querySelectorAll('[data-cancel]').forEach((btn) => {
        btn.addEventListener('click', async () => {
          const id = (btn as HTMLElement).dataset.cancel;
          await fetch(`/api/jobs/${id}/cancel`, {
            method: 'POST',
            credentials: 'include',
          });
          loadJobs();
        });
      });

      // Retry buttons
      tbodyEl.querySelectorAll('[data-retry]').forEach((btn) => {
        btn.addEventListener('click', async () => {
          const id = (btn as HTMLElement).dataset.retry;
          await fetch(`/api/jobs/${id}/retry`, {
            method: 'POST',
            credentials: 'include',
          });
          loadJobs();
        });
      });

      // Pagination
      const totalPages = Math.ceil(totalJobs / pageSize);
      paginationEl.style.display = totalPages > 1 ? 'flex' : 'none';
      pageInfo.textContent = `Page ${currentPage} of ${totalPages}`;
    }

    filterStatus.addEventListener('change', () => {
      currentPage = 1;
      loadJobs();
    });
    document.getElementById('prev-page')?.addEventListener('click', () => {
      if (currentPage > 1) {
        currentPage--;
        loadJobs();
      }
    });
    document.getElementById('next-page')?.addEventListener('click', () => {
      if (currentPage * pageSize < totalJobs) {
        currentPage++;
        loadJobs();
      }
    });

    loadJobs();

    // Auto-refresh if there are running jobs
    setInterval(() => {
      if (
        tbodyEl.querySelector('.status-running') ||
        tbodyEl.querySelector('.status-pending')
      ) {
        loadJobs();
      }
    }, 5000);
  });
</script>
