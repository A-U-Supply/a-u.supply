---
import Admin from '../../../layouts/Admin.astro';
---

<Admin title="The Midden" current="midden">
  <div class="page-header">
    <h1>The Midden</h1>
    <div class="midden-summary" id="midden-summary"></div>
  </div>
  <p class="midden-lede">
    Everyone's discarded outputs pile up here for 24 hours. Anyone <em>but</em>
    the original discarder can still pull one back by indexing it. After the countdown,
    the reaper takes it.
  </p>

  <div class="slop-controls">
    <select id="filter-type">
      <option value="">All Types</option>
      <option value="image">Image</option>
      <option value="audio">Audio</option>
      <option value="video">Video</option>
    </select>
    <select id="filter-app">
      <option value="">All Apps</option>
    </select>
    <select id="filter-discarder">
      <option value="">All Discarders</option>
    </select>
    <button class="action-btn" id="btn-refresh">Refresh</button>
    <div class="slop-bulk-actions">
      <label
        class="slop-all-pages"
        title="Apply Index All to every page that matches the current filter, not just this page."
      >
        <input type="checkbox" id="bulk-all-pages" />
        <span>Across all pages</span>
      </label>
      <button class="action-btn" id="btn-play-all" style="display:none;"
        >Play All</button
      >
      <button class="action-btn" id="btn-index-all" style="display:none;"
        >Index All</button
      >
    </div>
  </div>

  <div id="slop-pagination" class="slop-pagination" style="display:none;">
    <button class="action-btn" id="slop-prev">Prev</button>
    <span id="slop-page-info">Page 1</span>
    <button class="action-btn" id="slop-next">Next</button>
  </div>

  <div id="slop-loading" style="color: var(--color-muted);">
    <span class="loading-dots">Loading</span>
  </div>
  <div id="slop-error" class="login-error" style="display:none;"></div>
  <div
    id="slop-empty"
    style="display:none; color: var(--color-muted); padding: var(--space-lg) 0; text-align: center;"
  >
    The midden is empty. Everyone's making careful choices today.
  </div>

  <div id="slop-grid" class="slop-grid" style="display:none;"></div>

  <!-- Index metadata dialog -->
  <div class="dialog-overlay" id="index-dialog" style="display:none;">
    <div
      class="dialog"
      style="max-width: 560px; max-height: 90vh; overflow-y: auto;"
    >
      <h3>Index to Search</h3>
      <div id="idx-info" class="idx-info"></div>
      <input id="idx-output-index" type="hidden" />
      <div class="idx-field">
        <label>Title</label>
        <input
          id="idx-description"
          type="text"
          placeholder="Editable — auto-generated from job context"
        />
        <div class="idx-hint">
          Searchable title for these outputs. Edit freely.
        </div>
      </div>
      <div class="idx-field">
        <label>Notes</label>
        <textarea id="idx-notes" rows="2" placeholder="Optional freeform notes"
        ></textarea>
      </div>
      <div class="idx-field">
        <label>Additional Tags</label>
        <input id="idx-tags" type="text" placeholder="comma-separated" />
      </div>
      <div
        id="idx-auto-tags"
        class="idx-info"
        style="margin-top: var(--space-xs);"
      >
      </div>
      <div class="dialog-actions">
        <button class="btn-cancel" id="idx-cancel">Cancel</button>
        <button class="action-btn" id="idx-confirm">Index</button>
      </div>
    </div>
  </div>
</Admin>

<style>
  .page-header {
    display: flex;
    align-items: baseline;
    gap: var(--space-md);
    flex-wrap: wrap;
  }
  .midden-summary {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-muted);
  }
  .midden-lede {
    color: var(--color-muted);
    font-size: var(--text-sm);
    max-width: 64ch;
    margin-top: var(--space-xs);
  }
  .midden-lede em {
    font-style: italic;
    color: var(--color-text);
  }
  .slop-controls {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    margin-top: var(--space-sm);
    flex-wrap: wrap;
  }
  .slop-bulk-actions {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    margin-left: auto;
  }
  .slop-all-pages {
    display: flex;
    align-items: center;
    gap: 4px;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-muted);
    cursor: pointer;
    user-select: none;
  }
  .slop-all-pages input[type='checkbox'] {
    width: 14px;
    height: 14px;
    accent-color: var(--color-text);
  }
  .slop-pagination {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    margin-top: var(--space-md);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
  }
  .slop-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: var(--space-sm);
    margin-top: var(--space-md);
  }
  .slop-card {
    border: 1px solid var(--color-border);
    padding: var(--space-sm);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    position: relative;
  }
  .slop-card.is-own-discard {
    opacity: 0.55;
  }
  .slop-preview {
    width: 100%;
    height: auto;
    max-height: 320px;
    object-fit: contain;
    display: block;
    margin-bottom: var(--space-xs);
    border-radius: 2px;
  }
  video.slop-preview {
    max-height: 240px;
    background: #000;
  }
  @media (max-width: 640px) {
    .slop-preview {
      max-height: 220px;
    }
    video.slop-preview {
      max-height: 180px;
    }
  }
  .slop-card .slop-name {
    font-weight: bold;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .slop-card .slop-meta {
    color: var(--color-muted);
    font-size: 0.65rem;
    margin-top: 2px;
  }
  .slop-card .slop-job {
    font-size: 0.65rem;
    margin-top: 4px;
  }
  .slop-card .slop-job a {
    color: var(--color-link);
  }
  .slop-card .slop-actions {
    margin-top: var(--space-xs);
    display: flex;
    gap: var(--space-xs);
    flex-wrap: wrap;
  }
  .slop-card .midden-countdown {
    display: inline-block;
    padding: 1px 6px;
    font-size: 0.6rem;
    border-radius: 2px;
    background: rgba(255, 90, 60, 0.12);
    color: #e07060;
    border: 1px solid rgba(255, 90, 60, 0.3);
    font-variant-numeric: tabular-nums;
  }
  .slop-card .midden-countdown.urgent {
    background: rgba(255, 60, 40, 0.22);
    color: #ff8070;
    border-color: rgba(255, 60, 40, 0.5);
  }
  .slop-card .discarded-by {
    color: var(--color-muted);
    font-size: 0.6rem;
    margin-top: 2px;
  }
  .slop-card .own-crime-tag {
    display: inline-block;
    margin-top: var(--space-xs);
    padding: 2px 6px;
    font-size: 0.6rem;
    border: 1px dashed rgba(200, 200, 200, 0.3);
    color: var(--color-muted);
    font-style: italic;
    letter-spacing: 0.02em;
  }
  .status-badge {
    display: inline-block;
    padding: 1px 6px;
    font-size: 0.6rem;
    border-radius: 2px;
    text-transform: uppercase;
  }
  .status-completed {
    background: #1a3a1a;
    color: #40c040;
  }
  .status-failed {
    background: #3a1a1a;
    color: #e04040;
  }
  .status-running {
    background: #1a2a3a;
    color: #40a0e0;
  }
  .status-pending {
    background: #2a2a1a;
    color: #c0c040;
  }
  .status-cancelled {
    background: #2a2a2a;
    color: #a0a0a0;
  }
  .idx-info {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-muted);
    border-left: 2px solid var(--color-border);
    padding: var(--space-xs) var(--space-sm);
    margin-bottom: var(--space-sm);
    line-height: 1.5;
    white-space: pre-line;
  }
  .idx-field {
    margin-top: var(--space-sm);
  }
  .idx-field label {
    display: block;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    margin-bottom: 2px;
  }
  .idx-field input,
  .idx-field textarea {
    width: 100%;
    padding: var(--space-xs);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    border: 1px solid var(--color-border);
    background: var(--color-bg);
    color: var(--color-text);
    box-sizing: border-box;
  }
  .idx-field textarea {
    resize: vertical;
  }
  .idx-hint {
    color: var(--color-muted);
    font-size: 0.65rem;
    margin-top: 2px;
  }
</style>

<script>
  document.addEventListener('astro:page-load', async () => {
    await (window as any).__authReady;

    // Preload the discarder filter with every admin user so it's useful on
    // first render, not just after you've paginated through every page.
    // Re-renders instead of appending so re-mounts via ViewTransitions and
    // races with loadOutputs() can't leave duplicate options.
    (async () => {
      try {
        const res = await fetch('/api/admin/users', {
          credentials: 'include',
        });
        if (!res.ok) return;
        const users = (await res.json()) as Array<{
          id: string;
          name: string;
        }>;
        knownDiscarders = new Map(users.map((u) => [u.id, u.name]));
        renderDiscarderOptions();
      } catch {}
    })();

    let allOutputs: any[] = [];
    let pendingIndexIds: string[] = [];
    let pendingIndexJobId: string | null = null;

    let currentPage = 1;
    const pageSize = 50;
    let totalOutputs = 0;
    let countdownTimer: number | null = null;

    // Single source of truth for the discarder dropdown: union of every
    // admin user plus any discarder ID we've seen in midden rows so far.
    let knownDiscarders = new Map<string, string>();

    function renderDiscarderOptions() {
      const select = document.getElementById(
        'filter-discarder',
      ) as HTMLSelectElement | null;
      if (!select) return;
      const prev = select.value;
      const sorted = Array.from(knownDiscarders.entries()).sort((a, b) =>
        a[1].localeCompare(b[1]),
      );
      const opts = ['<option value="">All Discarders</option>'];
      for (const [id, name] of sorted) {
        opts.push(
          `<option value="${id}"${prev === id ? ' selected' : ''}>${name}</option>`,
        );
      }
      select.innerHTML = opts.join('');
    }

    function formatSize(bytes: number): string {
      if (bytes < 1024) return bytes + ' B';
      if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(1) + ' KB';
      return (bytes / (1024 * 1024)).toFixed(1) + ' MB';
    }

    function isPlayable(o: any): boolean {
      return o.media_type === 'audio' || o.media_type === 'video';
    }

    function downloadUrl(o: any): string {
      return `/api/jobs/${o.job_id}/outputs/${o.id}/download`;
    }

    // Human-readable "Xh Ym" until the given timestamp.
    function formatRemaining(ms: number): { label: string; urgent: boolean } {
      if (ms <= 0) return { label: 'reaping…', urgent: true };
      const totalMins = Math.floor(ms / 60000);
      const hours = Math.floor(totalMins / 60);
      const mins = totalMins % 60;
      const urgent = totalMins < 60;
      if (hours > 0) return { label: `${hours}h ${mins}m left`, urgent };
      if (mins > 0) return { label: `${mins}m left`, urgent };
      const secs = Math.max(0, Math.floor(ms / 1000));
      return { label: `${secs}s left`, urgent: true };
    }

    function updateCountdowns() {
      const now = Date.now();
      for (const o of allOutputs) {
        const el = document.querySelector(
          `[data-countdown="${o.id}"]`,
        ) as HTMLElement | null;
        if (!el) continue;
        const ms = new Date(o.purge_at).getTime() - now;
        const { label, urgent } = formatRemaining(ms);
        el.textContent = label;
        if (urgent) el.classList.add('urgent');
        else el.classList.remove('urgent');
      }
    }

    function renderPagination() {
      const pagEl = document.getElementById('slop-pagination')!;
      const pageInfo = document.getElementById('slop-page-info')!;
      const prevBtn = document.getElementById('slop-prev') as HTMLButtonElement;
      const nextBtn = document.getElementById('slop-next') as HTMLButtonElement;
      const totalPages = Math.max(1, Math.ceil(totalOutputs / pageSize));
      if (totalOutputs <= pageSize) {
        pagEl.style.display = 'none';
        return;
      }
      pagEl.style.display = '';
      pageInfo.textContent = `Page ${currentPage} of ${totalPages} — ${totalOutputs} total`;
      prevBtn.disabled = currentPage <= 1;
      nextBtn.disabled = currentPage >= totalPages;
    }

    // Fetch every output ID the caller is ALLOWED to index (excludes own
    // discards per the inverse rule).
    async function fetchAllIndexableIds(): Promise<string[]> {
      const mediaType = (
        document.getElementById('filter-type') as HTMLSelectElement
      ).value;
      const appName = (
        document.getElementById('filter-app') as HTMLSelectElement
      ).value;
      const discardedBy = (
        document.getElementById('filter-discarder') as HTMLSelectElement
      ).value;
      const params = new URLSearchParams();
      if (mediaType) params.set('media_type', mediaType);
      if (appName) params.set('app_name', appName);
      if (discardedBy) params.set('discarded_by', discardedBy);
      const res = await fetch(`/api/jobs/outputs/midden/ids?${params}`, {
        credentials: 'include',
      });
      if (!res.ok) return [];
      const data = await res.json();
      return data.ids || [];
    }

    function isAllPages(): boolean {
      return (document.getElementById('bulk-all-pages') as HTMLInputElement)
        .checked;
    }

    // ---- Load outputs ----
    async function loadOutputs() {
      const loadingEl = document.getElementById('slop-loading')!;
      const errorEl = document.getElementById('slop-error')!;
      const emptyEl = document.getElementById('slop-empty')!;
      const gridEl = document.getElementById('slop-grid')!;
      const summaryEl = document.getElementById('midden-summary')!;

      loadingEl.style.display = '';
      errorEl.style.display = 'none';
      emptyEl.style.display = 'none';
      gridEl.style.display = 'none';

      const mediaType = (
        document.getElementById('filter-type') as HTMLSelectElement
      ).value;
      const appName = (
        document.getElementById('filter-app') as HTMLSelectElement
      ).value;
      const discardedBy = (
        document.getElementById('filter-discarder') as HTMLSelectElement
      ).value;

      const params = new URLSearchParams();
      if (mediaType) params.set('media_type', mediaType);
      if (appName) params.set('app_name', appName);
      if (discardedBy) params.set('discarded_by', discardedBy);
      params.set('page', String(currentPage));
      params.set('per_page', String(pageSize));

      const res = await fetch(`/api/jobs/outputs/midden?${params}`, {
        credentials: 'include',
      });
      loadingEl.style.display = 'none';

      if (!res.ok) {
        errorEl.textContent = 'Failed to load the midden.';
        errorEl.style.display = '';
        return;
      }

      const data = await res.json();
      allOutputs = data.outputs;
      totalOutputs = data.total || 0;

      // Populate app filter dropdown (preserve selection)
      const appSelect = document.getElementById(
        'filter-app',
      ) as HTMLSelectElement;
      const currentApp = appSelect.value;
      appSelect.innerHTML = '<option value="">All Apps</option>';
      for (const name of data.app_names) {
        const opt = document.createElement('option');
        opt.value = name;
        opt.textContent = name;
        if (name === currentApp) opt.selected = true;
        appSelect.appendChild(opt);
      }

      // Fold any newly seen discarders into the shared map, then re-render
      // the dropdown (dedup is handled by the Map keyed on user id).
      let changed = false;
      for (const o of allOutputs as any[]) {
        if (!o.discarded_by_id) continue;
        if (!knownDiscarders.has(o.discarded_by_id)) {
          knownDiscarders.set(
            o.discarded_by_id,
            o.discarded_by_name || 'someone',
          );
          changed = true;
        }
      }
      if (changed) renderDiscarderOptions();

      renderPagination();

      if (allOutputs.length === 0) {
        summaryEl.textContent =
          totalOutputs === 0
            ? ''
            : `Page ${currentPage} is empty. Go back a page.`;
        emptyEl.style.display = totalOutputs === 0 ? '' : 'none';
        document.getElementById('btn-index-all')!.style.display = 'none';
        document.getElementById('btn-play-all')!.style.display = 'none';
        return;
      }

      const totalPages = Math.max(1, Math.ceil(totalOutputs / pageSize));
      const pageLabel =
        totalPages > 1 ? ` · page ${currentPage}/${totalPages}` : '';
      summaryEl.textContent = `${totalOutputs} item${totalOutputs !== 1 ? 's' : ''} awaiting rescue${pageLabel}`;

      document.getElementById('btn-index-all')!.style.display = '';
      const playable = allOutputs.filter(isPlayable);
      document.getElementById('btn-play-all')!.style.display =
        playable.length > 0 ? '' : 'none';

      // Render grid
      gridEl.innerHTML = allOutputs
        .map((o: any) => {
          const dlUrl = downloadUrl(o);
          let preview = '';
          if (o.media_type === 'image') {
            preview = `<a href="${dlUrl}" target="_blank"><img class="slop-preview" src="${dlUrl}" alt="${o.filename}" loading="lazy"></a>`;
          } else if (o.media_type === 'video') {
            preview = `<video class="slop-preview" controls preload="none" src="${dlUrl}"></video>`;
          } else if (o.media_type === 'audio') {
            preview = `<audio controls preload="none" src="${dlUrl}" style="width:100%;margin-top:var(--space-xs);"></audio>`;
          }

          const own = o.is_own_discard;
          const discarderLabel = own ? 'you' : o.discarded_by_name || 'someone';
          const actions = own
            ? `
              <button class="action-btn" data-play="${o.id}" ${isPlayable(o) ? '' : 'style="display:none;"'}>Play</button>
              <a href="${dlUrl}" download="${o.filename}" class="action-btn" style="text-decoration:none;">Download</a>
              <button class="action-btn" disabled title="You discarded this. Someone else has to save it.">Index</button>
            `
            : `
              ${isPlayable(o) ? `<button class="action-btn" data-play="${o.id}">Play</button>` : ''}
              <a href="${dlUrl}" download="${o.filename}" class="action-btn" style="text-decoration:none;">Download</a>
              <button class="action-btn" data-index="${o.id}" data-job="${o.job_id}">Index</button>
            `;

          return `
        <div class="slop-card${own ? ' is-own-discard' : ''}" data-output-id="${o.id}">
          ${preview}
          <div class="slop-name" title="${o.filename}">${o.filename}</div>
          <div class="slop-meta">
            ${o.media_type || 'unknown'} &middot; ${o.file_size_bytes ? formatSize(o.file_size_bytes) : '?'}
            &middot; <span class="midden-countdown" data-countdown="${o.id}">…</span>
          </div>
          <div class="slop-job">
            <span class="status-badge status-${o.job_status}">${o.job_status}</span>
            ${o.job_app_name} &middot;
            <a href="/admin/jobs/detail?id=${o.job_id}">view job</a>
          </div>
          <div class="discarded-by">discarded by ${discarderLabel}</div>
          ${own ? '<div class="own-crime-tag">your crime — awaiting absolution</div>' : ''}
          <div class="slop-actions">${actions}</div>
        </div>
      `;
        })
        .join('');
      gridEl.style.display = '';
      updateCountdowns();

      // Wire up play buttons
      gridEl.querySelectorAll('[data-play]').forEach((btn) => {
        btn.addEventListener('click', () => {
          const oid = (btn as HTMLElement).dataset.play;
          const o = allOutputs.find((x: any) => x.id === oid);
          if (!o) return;
          document.dispatchEvent(
            new CustomEvent('player:queue', {
              detail: {
                tracks: [
                  {
                    track_id: o.id,
                    title: o.filename,
                    release_title: '',
                    release_code: '',
                    media_type: o.media_type,
                    stream_url: downloadUrl(o),
                    cover_url: '',
                    duration: 0,
                    entity_name: o.job_app_name,
                  },
                ],
                startIndex: 0,
              },
            }),
          );
        });
      });

      // Wire up single index buttons (skipped for own-discards — those are disabled)
      gridEl.querySelectorAll('[data-index]').forEach((btn) => {
        btn.addEventListener('click', () => {
          const oid = (btn as HTMLElement).dataset.index!;
          const jobId = (btn as HTMLElement).dataset.job!;
          openIndexDialog([oid], jobId);
        });
      });
    }

    // ---- Index dialog ----
    function openIndexDialog(outputIds: string[], singleJobId: string | null) {
      pendingIndexIds = outputIds;

      const jobIds = new Set<string>();
      for (const oid of outputIds) {
        const o = allOutputs.find((x: any) => x.id === oid);
        if (o) jobIds.add(o.job_id);
      }
      const isSingleJob = jobIds.size === 1;
      pendingIndexJobId = isSingleJob ? [...jobIds][0] : null;

      const infoEl = document.getElementById('idx-info')!;
      const autoTagsEl = document.getElementById('idx-auto-tags')!;
      const descInput = document.getElementById(
        'idx-description',
      ) as HTMLInputElement;
      const notesInput = document.getElementById(
        'idx-notes',
      ) as HTMLTextAreaElement;
      const tagsInput = document.getElementById('idx-tags') as HTMLInputElement;
      const outputIndexInput = document.getElementById(
        'idx-output-index',
      ) as HTMLInputElement;

      descInput.value = '';
      notesInput.value = '';
      tagsInput.value = '';
      outputIndexInput.value = '';

      if (isSingleJob) {
        const sample = allOutputs.find(
          (x: any) => x.job_id === pendingIndexJobId,
        );
        if (sample) {
          const params = sample.job_params || {};
          const parts = [sample.job_app_name];
          if (params.recipe) parts.push(params.recipe);
          else if (params.model) parts.push(params.model);
          if (params.input_combination && params.input_combination !== 'splice')
            parts.push(params.input_combination);
          descInput.value = parts.join(' / ');

          const infoLines = [`App: ${sample.job_app_name}`];
          if (params.processing_mode)
            infoLines.push(`Mode: ${params.processing_mode}`);
          if (params.recipe) infoLines.push(`Recipe: ${params.recipe}`);
          if (params.model) infoLines.push(`Model: ${params.model}`);
          infoLines.push(`Outputs: ${outputIds.length}`);
          infoEl.textContent = infoLines.join('\n');

          const autoTags = [`app:${sample.job_app_name}`];
          if (params.recipe) autoTags.push(`recipe:${params.recipe}`);
          if (params.model) autoTags.push(`model:${params.model}`);
          autoTagsEl.textContent = `Auto-tags: ${autoTags.join(', ')}`;
        }
      } else {
        // Cross-job bulk from midden — no preview sample, most items are
        // probably off the current page anyway.
        infoEl.textContent = `Indexing ${outputIds.length} item${outputIds.length !== 1 ? 's' : ''} from the midden`;
        autoTagsEl.textContent = 'Auto-tags will be generated per-job';
      }

      document.getElementById('index-dialog')!.style.display = 'flex';
    }

    document.getElementById('idx-cancel')?.addEventListener('click', () => {
      document.getElementById('index-dialog')!.style.display = 'none';
      pendingIndexIds = [];
    });

    document
      .getElementById('idx-confirm')
      ?.addEventListener('click', async () => {
        const title = (
          document.getElementById('idx-description') as HTMLInputElement
        ).value.trim();
        const notes = (
          document.getElementById('idx-notes') as HTMLTextAreaElement
        ).value.trim();
        const description =
          [title, notes].filter(Boolean).join('\n\n') || undefined;
        const outputIndex =
          (
            document.getElementById('idx-output-index') as HTMLInputElement
          ).value.trim() || undefined;
        const tagsStr = (
          document.getElementById('idx-tags') as HTMLInputElement
        ).value.trim();
        const tags = tagsStr
          ? tagsStr
              .split(',')
              .map((t) => t.trim())
              .filter(Boolean)
          : [];

        const meta = { description, tags, output_index: outputIndex };

        let ok = true;

        if (pendingIndexIds.length === 1 && pendingIndexJobId) {
          const res = await fetch(
            `/api/jobs/${pendingIndexJobId}/outputs/${pendingIndexIds[0]}/index`,
            {
              method: 'POST',
              credentials: 'include',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify(meta),
            },
          );
          ok = res.ok;
        } else {
          // Bulk / cross-job — reuse the existing cross-job endpoint. The
          // inverse rule (no self-indexing from midden) is enforced server-side
          // in `_do_index_output`.
          const res = await fetch('/api/jobs/outputs/bulk-index', {
            method: 'POST',
            credentials: 'include',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ output_ids: pendingIndexIds, ...meta }),
          });
          ok = res.ok;
        }

        document.getElementById('index-dialog')!.style.display = 'none';
        pendingIndexIds = [];
        pendingIndexJobId = null;

        if (ok) {
          (window as any).toast.success('Rescued from the midden');
          loadOutputs();
        } else {
          (window as any).toast.error('Indexing failed');
        }
      });

    // ---- Bulk actions ----
    document
      .getElementById('btn-index-all')
      ?.addEventListener('click', async () => {
        let ids: string[];
        if (isAllPages()) {
          ids = await fetchAllIndexableIds();
        } else {
          ids = allOutputs.filter((o) => !o.is_own_discard).map((o) => o.id);
        }
        if (ids.length === 0) {
          (window as any).toast.error(
            'Nothing to index — the rest are your own sins.',
          );
          return;
        }
        openIndexDialog(ids, null);
      });

    document.getElementById('btn-play-all')?.addEventListener('click', () => {
      const playable = allOutputs.filter(isPlayable);
      if (playable.length === 0) return;
      const tracks = playable.map((o) => ({
        track_id: o.id,
        title: o.filename,
        release_title: '',
        release_code: '',
        media_type: o.media_type,
        stream_url: downloadUrl(o),
        cover_url: '',
        duration: 0,
        entity_name: o.job_app_name,
      }));
      document.dispatchEvent(
        new CustomEvent('player:queue', {
          detail: { tracks, startIndex: 0 },
        }),
      );
    });

    // ---- Filters ----
    function resetAndLoad() {
      currentPage = 1;
      loadOutputs();
    }
    document
      .getElementById('filter-type')
      ?.addEventListener('change', resetAndLoad);
    document
      .getElementById('filter-app')
      ?.addEventListener('change', resetAndLoad);
    document
      .getElementById('filter-discarder')
      ?.addEventListener('change', resetAndLoad);
    document
      .getElementById('btn-refresh')
      ?.addEventListener('click', loadOutputs);

    // ---- Pagination ----
    document.getElementById('slop-prev')?.addEventListener('click', () => {
      if (currentPage > 1) {
        currentPage -= 1;
        loadOutputs();
        window.scrollTo({ top: 0, behavior: 'instant' });
      }
    });
    document.getElementById('slop-next')?.addEventListener('click', () => {
      const totalPages = Math.max(1, Math.ceil(totalOutputs / pageSize));
      if (currentPage < totalPages) {
        currentPage += 1;
        loadOutputs();
        window.scrollTo({ top: 0, behavior: 'instant' });
      }
    });

    // Tick countdowns every 30s so the urgency label updates without a reload.
    if (countdownTimer !== null) {
      window.clearInterval(countdownTimer);
    }
    countdownTimer = window.setInterval(updateCountdowns, 30000);

    // Initial load
    loadOutputs();
  });
</script>
