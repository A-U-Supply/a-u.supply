---
import Admin from '../../../layouts/Admin.astro';
---

<Admin title="Media Detail" current="search">
  <div id="detail-loading" style="color: var(--color-muted);"><span class="loading-dots">Loading</span></div>
  <div id="detail-error" class="login-error" style="display:none;"></div>

  <div id="detail-content" style="display:none;">
    <div class="detail-header">
      <h1 id="detail-title">Media Detail</h1>
      <button class="bm-star" id="detail-bm-star" style="display:none;" title="Bookmark"></button>
      <a href="/admin/search" class="action-btn">Back to Search</a>
    </div>

    <div class="detail-layout">
      <div class="detail-preview" id="detail-preview"></div>

      <div class="detail-meta">
        <div class="meta-section">
          <div class="meta-label">Filename</div>
          <div class="meta-value" id="meta-filename"></div>
        </div>
        <div class="meta-section">
          <div class="meta-label">Media Type</div>
          <div class="meta-value" id="meta-type"></div>
        </div>
        <div class="meta-section">
          <div class="meta-label">MIME Type</div>
          <div class="meta-value" id="meta-mime"></div>
        </div>
        <div class="meta-section">
          <div class="meta-label">File Size</div>
          <div class="meta-value" id="meta-size"></div>
        </div>
        <div class="meta-section">
          <div class="meta-label">SHA-256</div>
          <div class="meta-value meta-hash" id="meta-hash"></div>
        </div>
        <div class="meta-section">
          <div class="meta-label">Description</div>
          <div class="meta-value" id="meta-description">--</div>
        </div>
        <div class="meta-section">
          <div class="meta-label">Created</div>
          <div class="meta-value" id="meta-created"></div>
        </div>
        <div class="meta-section">
          <div class="meta-label">Updated</div>
          <div class="meta-value" id="meta-updated"></div>
        </div>

        <!-- Type-specific metadata -->
        <div id="type-meta"></div>
      </div>
    </div>

    <!-- Tags section -->
    <div class="tags-section">
      <h2>Tags</h2>
      <div class="tags-list" id="tags-list"></div>
      <div class="tag-add">
        <input type="text" id="tag-input" placeholder="Add tag..." autocomplete="off" />
        <div class="tag-suggestions" id="tag-suggestions" style="display:none;"></div>
        <button class="action-btn" id="add-tag-btn">Add</button>
      </div>
    </div>

    <!-- Sources section -->
    <div class="sources-section">
      <h2>Sources</h2>
      <div id="sources-list"></div>
    </div>

    <!-- Input items (for outputs) -->
    <div class="inputs-section" id="inputs-section" style="display:none;">
      <h2>Inputs</h2>
      <div id="inputs-list" class="inputs-grid"></div>
    </div>

    <!-- Output items (for inputs) -->
    <div class="outputs-section" id="outputs-section" style="display:none;">
      <h2>Outputs</h2>
      <div id="outputs-list" class="inputs-grid"></div>
    </div>

    <!-- Extraction status -->
    <div class="extraction-section">
      <h2>Extraction Status</h2>
      <div id="extraction-status"></div>
    </div>

    <!-- Actions -->
    <div class="detail-actions">
      <button class="action-btn" id="add-to-workspace-btn">Add to Workspace</button>
      <a class="action-btn" id="download-btn" href="#" download style="display:none;">Download Source</a>
      <button class="action-btn" id="re-extract-btn">Re-extract Metadata</button>
      <button class="action-btn action-btn--danger" id="delete-btn">Delete Media</button>
    </div>
  </div>

  <!-- Delete confirmation dialog -->
  <div class="dialog-overlay" id="delete-dialog" style="display:none;">
    <div class="dialog">
      <p>Delete this media item?</p>
      <p style="color: var(--color-muted); font-size: var(--text-sm); margin-top: var(--space-xs);">This action cannot be undone.</p>
      <div class="dialog-actions">
        <button class="btn-cancel" id="delete-cancel">Cancel</button>
        <button class="btn-danger" id="delete-confirm">Delete</button>
      </div>
    </div>
  </div>
</Admin>

<style>
  .detail-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }
  .detail-header h1 {
    margin-bottom: 0;
    border-bottom: none;
    padding-bottom: 0;
  }

  .detail-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-lg);
    margin-top: var(--space-md);
  }

  .detail-preview {
    border: 1px solid var(--color-border);
    background: #f5f5f5;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 200px;
    padding: var(--space-sm);
  }
  .detail-preview img {
    max-width: 100%;
    max-height: 500px;
    object-fit: contain;
  }
  .detail-preview audio,
  .detail-preview video {
    width: 100%;
    max-width: 100%;
  }

  .detail-meta {
    font-size: var(--text-sm);
  }
  .meta-section {
    display: flex;
    border-bottom: 1px dotted var(--color-border);
    padding: 4px 0;
  }
  .meta-label {
    width: 120px;
    flex-shrink: 0;
    font-size: 0.65rem;
    color: var(--color-muted);
    text-transform: uppercase;
    letter-spacing: 0.5pt;
  }
  .meta-value {
    flex: 1;
    word-break: break-all;
  }
  .meta-hash {
    font-size: 0.6rem;
    color: var(--color-muted);
  }

  .tags-section,
  .sources-section,
  .extraction-section {
    margin-top: var(--space-lg);
  }
  .tags-section h2,
  .sources-section h2,
  .extraction-section h2 {
    font-size: var(--text-lg);
    text-transform: uppercase;
    letter-spacing: 1pt;
    margin-bottom: var(--space-sm);
    padding-bottom: var(--space-xs);
    border-bottom: 2px solid var(--color-text);
  }

  .tags-list {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
    margin-bottom: var(--space-sm);
  }
  .tag-chip {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 2px 8px;
    border: 1px solid var(--color-border);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.5pt;
  }
  .tag-chip button {
    background: none;
    border: none;
    color: #c00;
    cursor: pointer;
    font-size: 0.8rem;
    padding: 0;
    line-height: 1;
  }
  .tag-chip button:hover { color: #a00; }

  .tag-add {
    display: flex;
    gap: var(--space-xs);
    position: relative;
  }
  .tag-add input {
    flex: 1;
    padding: 4px 8px;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    border: 1px solid var(--color-border);
  }
  .tag-add input:focus {
    outline: 2px solid var(--color-accent);
    outline-offset: -1px;
  }
  .tag-suggestions {
    position: absolute;
    top: 100%;
    left: 0;
    right: 60px;
    background: #fff;
    border: 1px solid var(--color-border);
    border-top: none;
    max-height: 150px;
    overflow-y: auto;
    z-index: 10;
  }
  .tag-suggestion {
    padding: 4px 8px;
    font-size: var(--text-sm);
    cursor: pointer;
  }
  .tag-suggestion:hover { background: #f0f0f0; }

  .inputs-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: var(--space-sm);
  }
  .input-card {
    border: 1px solid var(--color-border);
    padding: var(--space-xs);
    font-size: var(--text-sm);
  }
  .input-thumb {
    width: 100%;
    max-height: 150px;
    object-fit: contain;
    display: block;
    margin-bottom: var(--space-xs);
  }
  .input-info {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .input-info a {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .source-card {
    border: 1px solid var(--color-border);
    padding: var(--space-sm);
    margin-bottom: var(--space-sm);
    font-size: var(--text-sm);
  }
  .source-card__field {
    margin-bottom: 6px;
    font-size: var(--text-sm);
  }
  .source-card__label {
    display: block;
    color: var(--color-muted);
    font-size: 0.6rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5pt;
    margin-bottom: 1px;
  }

  .extraction-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 4px 0;
    border-bottom: 1px dotted var(--color-border);
    font-size: var(--text-sm);
  }
  .extraction-item .status-ok { color: #080; }
  .extraction-item .status-fail { color: #c00; }
  .extraction-item .status-pending { color: var(--color-muted); }

  .detail-actions {
    display: flex;
    gap: var(--space-sm);
    margin-top: var(--space-lg);
    padding-top: var(--space-md);
    border-top: 2px solid var(--color-text);
  }

  @media (max-width: 640px) {
    .detail-layout {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  document.addEventListener('astro:page-load', async () => {
    const contentEl = document.getElementById('detail-content');
    if (!contentEl) return;

    const user = await (window as any).__authReady;
    if (!user) return;

    const loadingEl = document.getElementById('detail-loading')!;
    const errorEl = document.getElementById('detail-error')!;

    const params = new URLSearchParams(window.location.search);
    const mediaId = params.get('id');
    if (!mediaId) {
      loadingEl.style.display = 'none';
      errorEl.textContent = 'No media ID provided';
      errorEl.style.display = 'block';
      return;
    }

    let currentItem: any = null;

    async function loadMedia() {
      try {
        const res = await fetch(`/api/media/${mediaId}`, { credentials: 'include' });
        if (!res.ok) throw new Error('Failed to load media');
        currentItem = await res.json();
        loadingEl.style.display = 'none';
        contentEl.style.display = 'block';
        renderDetail();
        // Bookmark star
        const bm = (window as any).__bookmarks;
        const starEl = document.getElementById('detail-bm-star');
        if (bm && starEl) {
          starEl.dataset.bmType = 'media_item';
          starEl.dataset.bmId = mediaId;
          starEl.style.display = '';
          bm.check('media_item', [mediaId]).then((set: Set<string>) => {
            if (set.has(mediaId)) {
              starEl.classList.add('bookmarked');
              starEl.setAttribute('title', 'Remove bookmark');
            }
          });
          starEl.addEventListener('click', () => {
            bm.toggle('media_item', mediaId);
          });
        }
      } catch (err: any) {
        loadingEl.style.display = 'none';
        errorEl.textContent = err.message;
        errorEl.style.display = 'block';
      }
    }

    function formatSize(bytes: number): string {
      if (bytes < 1024) return bytes + ' B';
      if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(1) + ' KB';
      return (bytes / (1024 * 1024)).toFixed(1) + ' MB';
    }

    function renderRelatedCard(r: any): string {
      const thumbUrl = r.media_type === 'image' ? `/api/media/${r.id}/thumbnail` : null;
      return `
      <div class="input-card">
        ${thumbUrl ? `<a href="/admin/search/detail?id=${r.id}"><img class="input-thumb" src="${thumbUrl}" alt="${r.filename}"></a>` : ''}
        <div class="input-info">
          <a href="/admin/search/detail?id=${r.id}" style="color: var(--color-accent); font-weight: bold;">${r.filename}</a>
          <span style="color: var(--color-muted); font-size: 0.65rem;">${r.media_type || ''}</span>
          ${r.slack_link ? `<a href="${r.slack_link}" target="_blank" style="color: var(--color-muted); font-size: 0.65rem;">Slack</a>` : ''}
        </div>
      </div>`;
    }

    async function renderDetail() {
      const item = currentItem;
      document.getElementById('detail-title')!.textContent = item.filename || 'Untitled';
      document.getElementById('meta-filename')!.textContent = item.filename || '--';
      document.getElementById('meta-type')!.textContent = item.media_type || '--';
      document.getElementById('meta-mime')!.textContent = item.mime_type || '--';
      document.getElementById('meta-size')!.textContent = item.file_size_bytes ? formatSize(item.file_size_bytes) : '--';
      document.getElementById('meta-hash')!.textContent = item.sha256 || '--';
      document.getElementById('meta-description')!.textContent = item.description || '--';
      document.getElementById('meta-created')!.textContent = item.created_at ? new Date(item.created_at).toLocaleString() : '--';
      document.getElementById('meta-updated')!.textContent = item.updated_at ? new Date(item.updated_at).toLocaleString() : '--';

      // Download button
      const downloadBtn = document.getElementById('download-btn') as HTMLAnchorElement;
      const fileUrl = `/api/media/${mediaId}/file`;
      downloadBtn.href = fileUrl;
      downloadBtn.style.display = '';

      // Preview
      const previewEl = document.getElementById('detail-preview')!;
      const thumbUrl = `/api/media/${mediaId}/thumbnail`;
      if (item.media_type === 'image') {
        previewEl.innerHTML = `<img src="${fileUrl}" alt="${item.filename || ''}" />`;
      } else if (item.media_type === 'audio') {
        previewEl.innerHTML = `<audio controls src="${fileUrl}"></audio>`;
      } else if (item.media_type === 'video') {
        previewEl.innerHTML = `<video controls src="${fileUrl}" poster="${thumbUrl}" style="max-height:400px;"></video>`;
      } else {
        previewEl.innerHTML = `<span style="color: var(--color-muted); text-transform: uppercase;">No preview available</span>`;
      }

      // Type-specific metadata
      const typeMeta = document.getElementById('type-meta')!;
      if (item.media_type === 'image' && item.image_meta) {
        const m = item.image_meta;
        typeMeta.innerHTML = `
          <div class="meta-section"><div class="meta-label">Dimensions</div><div class="meta-value">${m.width || '?'} x ${m.height || '?'}</div></div>
          <div class="meta-section"><div class="meta-label">Format</div><div class="meta-value">${m.format || '--'}</div></div>
          ${m.dominant_colors ? (() => {
            const colors = typeof m.dominant_colors === 'string' ? JSON.parse(m.dominant_colors) : (m.dominant_colors || []);
            function hexToGroup(c: string): string {
              const hex = c.replace('#','');
              const r = parseInt(hex.substring(0,2),16), g = parseInt(hex.substring(2,4),16), b = parseInt(hex.substring(4,6),16);
              const max = Math.max(r,g,b), min = Math.min(r,g,b);
              const l = (r+g+b)/(3*255), sat = max>0?(max-min)/max:0;
              if (l<0.10) return 'black'; if (l>0.90) return 'white';
              if (sat<0.10) return 'gray';
              let h=0; if(max!==min){if(max===r)h=60*((g-b)/(max-min)%6);else if(max===g)h=60*((b-r)/(max-min)+2);else h=60*((r-g)/(max-min)+4);}if(h<0)h+=360;
              if(sat<0.30&&h>10&&h<50) return l<0.45?'brown':'beige';
              if(sat<0.20) return 'gray';
              if(h<10||h>=350)return 'red';if(h<35)return 'orange';if(h<55)return 'yellow';if(h<160)return 'green';if(h<195)return 'teal';if(h<260)return 'blue';if(h<300)return 'purple';return 'pink';
            }
            // Deduplicate groups
            const groups = [...new Set(colors.map(hexToGroup))];
            const swatches = colors.map((c: string) =>
              `<span style="display:inline-block;width:28px;height:28px;background:${c};border:1px solid #ccc;border-radius:3px;vertical-align:middle;"></span>`
            ).join(' ');
            const groupLinks = groups.map((g: string) => `<a href="/admin/search?colorgroup=${g}" class="tag-chip" style="text-decoration:none;">${g}</a>`).join(' ');
            return `<div class="meta-section"><div class="meta-label">Palette</div><div class="meta-value" style="display:flex;gap:4px;align-items:center;flex-wrap:wrap;">${swatches}</div></div>` +
                   `<div class="meta-section"><div class="meta-label">Color Groups</div><div class="meta-value">${groupLinks}</div></div>`;
          })() : ''}
        `;
      } else if (item.media_type === 'audio' && item.audio_meta) {
        const m = item.audio_meta;
        typeMeta.innerHTML = `
          <div class="meta-section"><div class="meta-label">Duration</div><div class="meta-value">${m.duration_seconds ? m.duration_seconds.toFixed(1) + 's' : '--'}</div></div>
          <div class="meta-section"><div class="meta-label">Sample Rate</div><div class="meta-value">${m.sample_rate ? m.sample_rate + ' Hz' : '--'}</div></div>
          <div class="meta-section"><div class="meta-label">Channels</div><div class="meta-value">${m.channels || '--'}</div></div>
        `;
      } else if (item.media_type === 'video' && item.video_meta) {
        const m = item.video_meta;
        typeMeta.innerHTML = `
          <div class="meta-section"><div class="meta-label">Duration</div><div class="meta-value">${m.duration_seconds ? m.duration_seconds.toFixed(1) + 's' : '--'}</div></div>
          <div class="meta-section"><div class="meta-label">Resolution</div><div class="meta-value">${m.width || '?'} x ${m.height || '?'}</div></div>
          <div class="meta-section"><div class="meta-label">Codec</div><div class="meta-value">${m.codec || '--'}</div></div>
        `;
      } else {
        typeMeta.innerHTML = '';
      }

      // Tags
      renderTags();

      // Sources
      const sourcesEl = document.getElementById('sources-list')!;
      const sources = item.sources || [];
      if (sources.length === 0) {
        sourcesEl.innerHTML = '<p style="color: var(--color-muted); font-size: var(--text-sm);">No source information.</p>';
      } else {
        sourcesEl.innerHTML = sources.map((s: any) => {
          const sourceLabel = {slack_file: 'Slack File', slack_link: 'Slack Link', upload: 'Upload', job_output: 'Job Output'}[s.source_type] || s.source_type || 'Unknown';
          let meta: any = null;
          try { meta = s.source_metadata ? JSON.parse(s.source_metadata) : null; } catch {}
          return `
          <div class="source-card">
            <div class="source-card__field"><span class="source-card__label">Source:</span> ${sourceLabel}</div>
            ${s.source_channel ? `<div class="source-card__field"><span class="source-card__label">Channel:</span> ${s.source_channel}</div>` : ''}
            ${s.slack_link ? `<div class="source-card__field"><span class="source-card__label">Slack:</span> <a href="${s.slack_link}" target="_blank" style="color: var(--color-accent);">Open in Slack</a></div>` : ''}
            ${s.slack_message_text ? `<div class="source-card__field"><span class="source-card__label">Message:</span> ${s.slack_message_text}</div>` : ''}
            ${s.source_url ? `<div class="source-card__field"><span class="source-card__label">URL:</span> <a href="${s.source_url}" target="_blank" style="color: var(--color-accent);">${s.source_url}</a></div>` : ''}
            ${s.reaction_count ? `<div class="source-card__field"><span class="source-card__label">Reactions:</span> ${s.reaction_count}</div>` : ''}
            ${meta?.job_id ? `<div class="source-card__field"><span class="source-card__label">Job:</span> <a href="/admin/jobs/detail?id=${meta.job_id}" style="color: var(--color-accent);">${meta.app_name}${meta.recipe ? ' / ' + meta.recipe : ''}</a></div>` : ''}
            <div class="source-card__field"><span class="source-card__label">Added:</span> ${s.created_at ? new Date(s.created_at).toLocaleString() : '--'}</div>
          </div>
        `}).join('');
      }

      // Related items (inputs/outputs) via job linkage
      try {
        const relResp = await fetch(`/api/media/${mediaId}/related`, { credentials: 'include' });
        if (relResp.ok) {
          const related = await relResp.json();
          if (related.inputs?.length > 0) {
            const inputsSection = document.getElementById('inputs-section')!;
            const inputsList = document.getElementById('inputs-list')!;
            inputsSection.style.display = '';
            inputsList.innerHTML = related.inputs.map((inp: any) => renderRelatedCard(inp)).join('');
          }
          if (related.outputs?.length > 0) {
            const outputsSection = document.getElementById('outputs-section')!;
            const outputsList = document.getElementById('outputs-list')!;
            outputsSection.style.display = '';
            outputsList.innerHTML = related.outputs.map((out: any) => renderRelatedCard(out)).join('');
          }
        }
      } catch {}

      // Extraction failures
      const extractionEl = document.getElementById('extraction-status')!;
      const failures = item.extraction_failures || [];
      if (failures.length === 0) {
        extractionEl.innerHTML = '<p style="color: var(--color-muted); font-size: var(--text-sm);">No extraction failures.</p>';
      } else {
        extractionEl.innerHTML = failures.map((f: any) => {
          const statusClass = f.resolved ? 'status-ok' : 'status-fail';
          const statusText = f.resolved ? 'resolved' : `failed (${f.attempts} attempts)`;
          return `<div class="extraction-item">
            <span>${f.extraction_type || 'Unknown'}</span>
            <span class="${statusClass}">${statusText}</span>
            ${f.error_message ? `<span style="color: #c00; font-size: 0.65rem;">${f.error_message}</span>` : ''}
          </div>`;
        }).join('');
      }
    }

    function renderTags() {
      const tagsEl = document.getElementById('tags-list')!;
      const tags = currentItem.tags || [];
      if (tags.length === 0) {
        tagsEl.innerHTML = '<span style="color: var(--color-muted); font-size: var(--text-sm);">No tags</span>';
      } else {
        tagsEl.innerHTML = tags.map((tag: string) =>
          `<span class="tag-chip"><a href="/admin/search?tag=${encodeURIComponent(tag)}" style="color:inherit;text-decoration:none;">${tag}</a><button data-remove-tag="${tag}" title="Remove">&times;</button></span>`
        ).join('');
      }
    }

    // Tag autocomplete
    let suggestTimeout: ReturnType<typeof setTimeout>;
    const tagInput = document.getElementById('tag-input') as HTMLInputElement;
    const suggestionsEl = document.getElementById('tag-suggestions')!;

    tagInput?.addEventListener('input', () => {
      clearTimeout(suggestTimeout);
      const q = tagInput.value.trim();
      if (q.length < 1) { suggestionsEl.style.display = 'none'; return; }
      suggestTimeout = setTimeout(async () => {
        try {
          const res = await fetch(`/api/tags/suggest?q=${encodeURIComponent(q)}`, { credentials: 'include' });
          if (res.ok) {
            const suggestions: any[] = await res.json();
            if (suggestions.length > 0) {
              suggestionsEl.innerHTML = suggestions.map(s => `<div class="tag-suggestion" data-tag="${s.tag}">${s.tag} (${s.usage_count})</div>`).join('');
              suggestionsEl.style.display = 'block';
            } else {
              suggestionsEl.style.display = 'none';
            }
          }
        } catch { suggestionsEl.style.display = 'none'; }
      }, 200);
    });

    suggestionsEl?.addEventListener('click', (e) => {
      const el = (e.target as HTMLElement).closest('.tag-suggestion') as HTMLElement | null;
      if (el) {
        addTag(el.dataset.tag!);
        suggestionsEl.style.display = 'none';
        tagInput.value = '';
      }
    });

    document.getElementById('add-tag-btn')?.addEventListener('click', () => {
      const tag = tagInput.value.trim();
      if (tag) { addTag(tag); tagInput.value = ''; suggestionsEl.style.display = 'none'; }
    });

    tagInput?.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') {
        e.preventDefault();
        const tag = tagInput.value.trim();
        if (tag) { addTag(tag); tagInput.value = ''; suggestionsEl.style.display = 'none'; }
      }
    });

    async function addTag(tag: string) {
      try {
        await fetch(`/api/media/${mediaId}/tags`, {
          method: 'POST',
          credentials: 'include',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ tags: [tag] }),
        });
        if (!currentItem.tags) currentItem.tags = [];
        if (!currentItem.tags.includes(tag)) currentItem.tags.push(tag);
        renderTags();
      } catch { (window as any).toast.error('Failed to add tag'); }
    }

    // Remove tag
    document.getElementById('tags-list')?.addEventListener('click', async (e) => {
      const btn = (e.target as HTMLElement).closest('[data-remove-tag]') as HTMLElement | null;
      if (!btn) return;
      const tag = btn.dataset.removeTag!;
      try {
        await fetch(`/api/media/${mediaId}/tags/${encodeURIComponent(tag)}`, {
          method: 'DELETE',
          credentials: 'include',
        });
        currentItem.tags = (currentItem.tags || []).filter((t: string) => t !== tag);
        renderTags();
      } catch { (window as any).toast.error('Failed to remove tag'); }
    });

    // Add to workspace
    document.getElementById('add-to-workspace-btn')?.addEventListener('click', async () => {
      const wsId = localStorage.getItem('active_workspace_id');
      if (!wsId) {
        (window as any).toast.error('No active workspace. Create one from the workspace page first.');
        return;
      }
      try {
        const res = await fetch(`/api/workspaces/${wsId}/items`, {
          method: 'POST', credentials: 'include',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ media_item_ids: [mediaId] }),
        });
        if (res.ok) {
          const data = await res.json();
          (window as any).toast.success(data.already_present > 0 ? 'Already in workspace' : 'Added to workspace');
        } else { (window as any).toast.error('Failed to add to workspace'); }
      } catch { (window as any).toast.error('Failed to add to workspace'); }
    });

    // Re-extract
    document.getElementById('re-extract-btn')?.addEventListener('click', async () => {
      try {
        await fetch('/api/media/batch/re-extract', {
          method: 'POST',
          credentials: 'include',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ media_ids: [mediaId] }),
        });
        (window as any).toast.success('Re-extraction queued');
        loadMedia();
      } catch { (window as any).toast.error('Re-extraction failed'); }
    });

    // Delete
    document.getElementById('delete-btn')?.addEventListener('click', () => {
      document.getElementById('delete-dialog')!.style.display = 'flex';
    });
    document.getElementById('delete-cancel')?.addEventListener('click', () => {
      document.getElementById('delete-dialog')!.style.display = 'none';
    });
    document.getElementById('delete-confirm')?.addEventListener('click', async () => {
      try {
        const res = await fetch(`/api/media/${mediaId}`, {
          method: 'DELETE',
          credentials: 'include',
        });
        if (res.ok) {
          window.location.href = '/admin/search';
        } else {
          (window as any).toast.error('Delete failed');
        }
      } catch { (window as any).toast.error('Delete failed'); }
      document.getElementById('delete-dialog')!.style.display = 'none';
    });

    loadMedia();
  });
</script>
