---
import Admin from '../../../layouts/Admin.astro';
---

<Admin title="Workspace" current="workspace">
  <div class="page-header">
    <h1 id="workspace-title">Workspace</h1>
    <div class="header-actions">
      <button class="action-btn" id="clear-workspace-btn">Clear All</button>
    </div>
  </div>

  <div id="empty" class="empty-state" style="display:none;">
    <div class="empty-state__icon">&#128451;</div>
    Workspace is empty. Go to <a href="/admin/search">Search</a> and add items using
    the batch bar.
  </div>

  <div id="workspace-items" class="workspace-grid" style="display:none;"></div>

  <div class="pagination" id="pagination" style="display:none;">
    <button class="action-btn" id="prev-page">Prev</button>
    <span id="page-info">Page 1</span>
    <button class="action-btn" id="next-page">Next</button>
  </div>

  <div class="process-bar" id="process-bar" style="display:none;">
    <label>Process with:</label>
    <select id="app-select">
      <option value="">Select an app...</option>
    </select>
    <button class="action-btn" id="configure-btn" disabled
      >Configure & Run</button
    >
  </div>

  <!-- Inline app config section -->
  <div id="config-section" class="config-section" style="display:none;">
    <div class="config-header">
      <h2 id="config-app-name"></h2>
      <button class="btn-cancel" id="config-cancel">Cancel</button>
    </div>
    <p id="config-app-desc" class="config-app-desc"></p>
    <details id="config-app-detail-wrap" class="config-detail-wrap">
      <summary>About this app</summary>
      <div id="config-app-detail" class="config-detail"></div>
    </details>
    <div id="config-params"></div>
    <div id="shuffle-section" class="shuffle-section" style="display:none;">
      <div class="shuffle-header">
        <h3>Shuffle Inputs</h3>
        <div class="shuffle-controls">
          <label class="shuffle-filter"
            ><input type="checkbox" id="shuffle-exclude-app" /> Exclude processed</label
          >
          <label class="shuffle-filter"
            ><input type="checkbox" id="shuffle-exclude-recipe" /> Exclude this recipe</label
          >
          <button class="action-btn" id="shuffle-btn">Shuffle</button>
        </div>
      </div>
      <div class="shuffle-status" id="shuffle-status"></div>
      <div class="shuffle-grid" id="shuffle-grid"></div>
    </div>
    <div class="config-actions">
      <button class="action-btn" id="config-submit">Submit Job</button>
    </div>
  </div>
</Admin>

<!-- Global styles for dynamically rendered grid items (innerHTML) -->
<style is:global>
  .workspace-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    gap: var(--space-sm);
    margin-top: var(--space-md);
  }
  .workspace-grid .ws-item {
    border: 1px solid var(--color-border);
    font-size: var(--text-sm);
    font-family: var(--font-mono);
    position: relative;
    transition: border-color 0.15s;
    overflow: hidden;
    min-width: 0;
  }
  .workspace-grid .ws-item:hover {
    border-color: var(--color-text);
  }
  .workspace-grid .ws-thumb {
    width: 100%;
    aspect-ratio: 1;
    background: #111;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }
  .workspace-grid .ws-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .workspace-grid .ws-play {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0.35);
    opacity: 0;
    transition: opacity 0.15s;
    cursor: pointer;
    border: none;
    padding: 0;
  }
  .workspace-grid .ws-thumb:hover .ws-play {
    opacity: 1;
  }
  .workspace-grid .ws-play svg {
    width: 32px;
    height: 32px;
    fill: #fff;
    filter: drop-shadow(0 1px 3px rgba(0, 0, 0, 0.5));
  }
  .workspace-grid .ws-add {
    position: absolute;
    bottom: 4px;
    right: 4px;
    background: rgba(0, 0, 0, 0.6);
    color: #fff;
    border: 1px solid rgba(255, 255, 255, 0.3);
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-weight: bold;
    width: 24px;
    height: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    opacity: 0;
    transition: opacity 0.15s;
    padding: 0;
    z-index: 1;
  }
  .workspace-grid .ws-thumb:hover .ws-add {
    opacity: 1;
  }
  .workspace-grid .ws-add:hover {
    background: rgba(184, 134, 11, 0.8);
    border-color: #b8860b;
  }
  .workspace-grid .ws-duration {
    position: absolute;
    bottom: 3px;
    right: 4px;
    font-size: 0.6rem;
    background: rgba(0, 0, 0, 0.7);
    color: #fff;
    padding: 1px 4px;
    font-family: var(--font-mono);
  }
  .workspace-grid .ws-type-badge {
    position: absolute;
    top: 3px;
    left: 4px;
    font-size: 0.55rem;
    background: rgba(0, 0, 0, 0.6);
    color: #fff;
    padding: 1px 4px;
    text-transform: uppercase;
    font-family: var(--font-mono);
  }
  .workspace-grid .ws-info {
    padding: 4px 6px;
    border-top: 1px solid var(--color-border);
    min-width: 0;
  }
  .workspace-grid .ws-name {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    font-size: 0.65rem;
  }
  .workspace-grid .ws-remove {
    position: absolute;
    top: 2px;
    right: 4px;
    background: rgba(0, 0, 0, 0.5);
    border: none;
    color: #fff;
    cursor: pointer;
    font-size: var(--text-sm);
    padding: 0 3px;
    z-index: 2;
    line-height: 1.2;
    opacity: 0;
    transition: opacity 0.15s;
  }
  .workspace-grid .ws-item:hover .ws-remove {
    opacity: 1;
  }
  .workspace-grid .ws-remove:hover {
    background: rgba(0, 0, 0, 0.8);
  }

  /* Config section (inline, dynamically rendered content) */
  .config-section {
    margin-top: var(--space-md);
    border: 1px solid var(--color-border);
    padding: var(--space-md);
    font-family: var(--font-mono);
  }
  .config-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--space-sm);
  }
  .config-header h2 {
    margin: 0;
    border: none;
    padding: 0;
    font-size: 1.1rem;
    font-weight: bold;
  }
  .config-app-desc {
    color: var(--color-muted);
    font-size: var(--text-sm);
    margin: 0 0 var(--space-sm) 0;
  }
  .config-detail-wrap {
    margin-bottom: var(--space-md);
    font-size: var(--text-sm);
  }
  .config-detail-wrap summary {
    cursor: pointer;
    color: var(--color-muted);
    font-size: var(--text-sm);
    margin-bottom: var(--space-xs);
  }
  .config-detail {
    color: var(--color-muted);
    font-size: var(--text-sm);
    line-height: 1.5;
    border-left: 2px solid var(--color-border);
    padding: var(--space-xs) var(--space-sm);
    margin-top: var(--space-xs);
    white-space: pre-line;
  }
  #config-params {
    margin-top: var(--space-sm);
  }
  .config-field {
    padding: var(--space-md) 0;
    border-bottom: 1px solid var(--color-border);
  }
  .config-field[style*='display: none'] + .config-field {
    border-top: none;
  }
  .config-field label {
    display: block;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: bold;
    margin-bottom: 6px;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }
  .config-field .config-desc {
    color: var(--color-muted);
    font-size: 0.75rem;
    margin-bottom: 8px;
    line-height: 1.5;
  }
  .config-field .config-option-desc {
    color: var(--color-muted);
    font-size: 0.7rem;
    font-style: italic;
    margin-top: 6px;
    line-height: 1.4;
    border-left: 2px solid var(--color-border);
    padding-left: var(--space-xs);
  }
  .config-field input,
  .config-field select {
    width: 100%;
    padding: var(--space-xs) var(--space-sm);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    border: 1px solid var(--color-border);
    background: var(--color-bg);
    color: var(--color-text);
    box-sizing: border-box;
  }
  .config-field input:focus,
  .config-field select:focus {
    outline: 1px solid var(--color-text);
  }
  .config-actions {
    margin-top: var(--space-md);
    padding-top: var(--space-md);
    border-top: 1px solid var(--color-border);
    display: flex;
    justify-content: flex-end;
  }

  /* Input count validation messages */
  .config-input-count {
    font-size: 0.75rem;
    margin-top: 6px;
    padding: 4px 8px;
    font-family: var(--font-mono);
  }
  .input-count-ok {
    color: #6a9955;
  }
  .input-count-fill {
    color: #dcdcaa;
  }
  .input-count-over {
    color: #f44747;
    font-weight: bold;
  }

  /* Multi-select chain picker */
  .multi-select-wrap {
    margin-top: 4px;
  }
  .ms-picker {
    display: flex;
    gap: var(--space-xs);
  }
  .ms-picker select {
    flex: 1;
    padding: var(--space-xs) var(--space-sm);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    border: 1px solid var(--color-border);
    background: var(--color-bg);
    color: var(--color-text);
  }
  .ms-add-btn {
    white-space: nowrap;
    padding: var(--space-xs) var(--space-sm) !important;
    font-size: var(--text-sm) !important;
  }
  .ms-list {
    list-style: none;
    padding: 0;
    margin: var(--space-xs) 0 0 0;
  }
  .ms-list li {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    padding: 4px 8px;
    border: 1px solid var(--color-border);
    margin-bottom: -1px;
    font-size: var(--text-sm);
  }
  .ms-num {
    color: var(--color-muted);
    min-width: 1.5em;
  }
  .ms-label {
    flex: 1;
  }
  .ms-remove {
    background: none;
    border: none;
    color: var(--color-muted);
    cursor: pointer;
    font-size: 1rem;
    padding: 0 4px;
  }
  .ms-remove:hover {
    color: #f44747;
  }

  /* Shuffle section */
  .shuffle-section {
    margin-top: var(--space-md);
    border-top: 1px solid var(--color-border);
    padding-top: var(--space-md);
  }
  .shuffle-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-bottom: var(--space-sm);
  }
  .shuffle-header h3 {
    margin: 0;
    font-size: 0.9rem;
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }
  .shuffle-controls {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    flex-wrap: wrap;
  }
  .shuffle-filter {
    font-size: 0.7rem;
    font-family: var(--font-mono);
    color: var(--color-muted);
    display: flex;
    align-items: center;
    gap: 4px;
    cursor: pointer;
  }
  .shuffle-filter input[type='checkbox'] {
    width: auto;
    margin: 0;
  }
  .shuffle-status {
    font-size: 0.75rem;
    font-family: var(--font-mono);
    color: var(--color-muted);
    margin-bottom: var(--space-sm);
  }
  .shuffle-status.shuffle-warn {
    color: #dcdcaa;
  }
  .shuffle-status.shuffle-err {
    color: #f44747;
  }
  .shuffle-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    gap: var(--space-sm);
  }
  .shuffle-grid .ws-item {
    border: 1px solid var(--color-border);
    font-size: var(--text-sm);
    font-family: var(--font-mono);
    position: relative;
    transition: border-color 0.15s;
    overflow: hidden;
    min-width: 0;
  }
  .shuffle-grid .ws-item:hover {
    border-color: var(--color-text);
  }
  .shuffle-grid .ws-thumb {
    width: 100%;
    aspect-ratio: 1;
    background: #111;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }
  .shuffle-grid .ws-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .shuffle-grid .ws-type-badge {
    position: absolute;
    top: 3px;
    right: 4px;
    font-size: 0.55rem;
    background: rgba(0, 0, 0, 0.6);
    color: #fff;
    padding: 1px 4px;
    text-transform: uppercase;
    font-family: var(--font-mono);
  }
  .shuffle-grid .ws-info {
    padding: 4px 6px;
    border-top: 1px solid var(--color-border);
    min-width: 0;
  }
  .shuffle-grid .ws-name {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    font-size: 0.65rem;
  }
  .shuffle-grid .ws-duration {
    position: absolute;
    bottom: 3px;
    right: 4px;
    font-size: 0.6rem;
    background: rgba(0, 0, 0, 0.7);
    color: #fff;
    padding: 1px 4px;
    font-family: var(--font-mono);
  }
  .shuffle-lock {
    position: absolute;
    top: 2px;
    left: 4px;
    background: rgba(0, 0, 0, 0.5);
    border: none;
    color: #fff;
    cursor: pointer;
    font-size: 0.7rem;
    padding: 2px 4px;
    z-index: 2;
    opacity: 0.5;
    transition: opacity 0.15s;
    font-family: var(--font-mono);
  }
  .shuffle-grid .ws-item:hover .shuffle-lock {
    opacity: 0.8;
  }
  .shuffle-grid .ws-item.locked .shuffle-lock {
    opacity: 1;
    color: #dcdcaa;
  }
  .shuffle-grid .ws-item.locked {
    border-left: 3px solid var(--color-text);
  }
</style>

<style>
  .process-bar {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    margin-top: var(--space-md);
    padding: var(--space-sm);
    border: 1px solid var(--color-border);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
  }
  .process-bar select {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    padding: var(--space-xs);
    background: var(--color-bg);
    color: var(--color-text);
    border: 1px solid var(--color-border);
  }
</style>

<script>
  document.addEventListener('astro:page-load', async () => {
    await (window as any).__authReady;

    const wsId = localStorage.getItem('active_workspace_id');
    const emptyEl = document.getElementById('empty')!;
    const gridEl = document.getElementById('workspace-items')!;
    const processBar = document.getElementById('process-bar')!;
    const paginationEl = document.getElementById('pagination')!;
    const pageInfo = document.getElementById('page-info')!;
    const titleEl = document.getElementById('workspace-title')!;

    let currentPage = 1;
    const pageSize = 48;
    let totalItems = 0;

    // Shuffle state
    let shuffleItems: Array<{
      id: string;
      filename: string;
      media_type: string;
      locked: boolean;
      duration_seconds?: number;
    }> = [];
    let shuffleActive = false;
    let shuffleCount = 0;
    let shuffleMediaTypes: string[] = [];
    let shuffleAppName = '';
    let shuffleRecipeValue = '';

    function fmtDur(s: number) {
      const m = Math.floor(s / 60);
      const sec = Math.floor(s % 60);
      return `${m}:${sec.toString().padStart(2, '0')}`;
    }

    function renderShuffleGrid() {
      const grid = document.getElementById('shuffle-grid')!;
      if (shuffleItems.length === 0) {
        grid.innerHTML = '';
        return;
      }
      grid.innerHTML = shuffleItems
        .map((item, i) => {
          const hasThumb =
            item.media_type === 'image' || item.media_type === 'video';
          const thumb = hasThumb
            ? `<img src="/api/media/${item.id}/thumbnail" alt="" loading="lazy" />`
            : `<img src="/assets/default-cover.jpg" alt="${item.media_type}" loading="lazy" style="image-rendering: pixelated;" />`;
          const dur = item.duration_seconds
            ? `<span class="ws-duration">${fmtDur(item.duration_seconds)}</span>`
            : '';
          const lockIcon = item.locked ? '&#128274;' : '&#128275;';
          return `<div class="ws-item ${item.locked ? 'locked' : ''}" data-shuffle-idx="${i}">
          <button class="shuffle-lock" data-idx="${i}" title="${item.locked ? 'Unlock' : 'Lock'}">${lockIcon}</button>
          <div class="ws-thumb">
            <span class="ws-type-badge">${item.media_type}</span>
            ${thumb}
            ${dur}
          </div>
          <div class="ws-info">
            <div class="ws-name" title="${item.filename}">${item.filename}</div>
          </div>
        </div>`;
        })
        .join('');

      // Wire lock toggles
      grid.querySelectorAll('.shuffle-lock').forEach((btn) => {
        btn.addEventListener('click', (e) => {
          e.stopPropagation();
          const idx = parseInt((btn as HTMLElement).dataset.idx!);
          shuffleItems[idx].locked = !shuffleItems[idx].locked;
          renderShuffleGrid();
        });
      });
    }

    async function doShuffle() {
      const locked = shuffleItems.filter((i) => i.locked);
      const need = shuffleCount - locked.length;
      if (need <= 0) {
        (window as any).toast.error(
          'All items are locked. Unlock some to shuffle.',
        );
        return;
      }

      const excludeApp = (
        document.getElementById('shuffle-exclude-app') as HTMLInputElement
      ).checked;
      const excludeRecipe = (
        document.getElementById('shuffle-exclude-recipe') as HTMLInputElement
      ).checked;

      const params = new URLSearchParams({
        count: String(need),
        media_types: shuffleMediaTypes.join(','),
      });

      // Exclude locked item IDs
      const lockedIds = locked.map((i) => i.id);
      if (lockedIds.length > 0) {
        params.set('exclude_ids', lockedIds.join(','));
      }
      if (excludeApp && shuffleAppName) {
        params.set('exclude_app', shuffleAppName);
      }
      if (excludeRecipe && excludeApp && shuffleRecipeValue) {
        params.set('exclude_recipe', shuffleRecipeValue);
      }

      try {
        const res = await fetch(`/api/media/random?${params}`, {
          credentials: 'include',
        });
        if (!res.ok) {
          const err = await res.json().catch(() => ({}));
          (window as any).toast.error(
            err.detail || `Shuffle failed (HTTP ${res.status})`,
          );
          return;
        }
        const data = await res.json();

        const statusEl = document.getElementById('shuffle-status')!;
        if (data.items.length < need) {
          statusEl.textContent = `Only ${data.items.length + locked.length} of ${shuffleCount} available. Pool: ${data.total_available} items.`;
          statusEl.className = 'shuffle-status shuffle-warn';
        } else {
          statusEl.textContent = `${shuffleCount} items selected. Pool: ${data.total_available} available.`;
          statusEl.className = 'shuffle-status';
        }

        // Merge locked items with new random items
        const newItems = data.items.map((item: any) => ({
          id: item.id,
          filename: item.filename,
          media_type: item.media_type,
          duration_seconds: item.duration_seconds,
          locked: false,
        }));
        shuffleItems = [...locked, ...newItems];
        shuffleActive = true;
        renderShuffleGrid();
      } catch (e) {
        (window as any).toast.error('Shuffle failed: ' + (e as Error).message);
      }
    }

    function showShuffleSection(
      count: number,
      mediaTypes: string[],
      appName: string,
      recipe: string,
    ) {
      shuffleCount = count;
      shuffleMediaTypes = mediaTypes;
      shuffleAppName = appName;
      shuffleRecipeValue = recipe;

      const section = document.getElementById('shuffle-section')!;
      section.style.display = '';

      const statusEl = document.getElementById('shuffle-status')!;
      statusEl.textContent = `Needs ${count} ${mediaTypes.join('/')} item(s). Click Shuffle to draw random inputs.`;
      statusEl.className = 'shuffle-status';

      // Keep any existing locked items that still match, clear the rest
      shuffleItems = shuffleItems.filter((i) => i.locked);
      renderShuffleGrid();
    }

    function hideShuffleSection() {
      const section = document.getElementById('shuffle-section')!;
      section.style.display = 'none';
      shuffleItems = [];
      shuffleActive = false;
      document.getElementById('shuffle-grid')!.innerHTML = '';
      document.getElementById('shuffle-status')!.textContent = '';
    }

    // Wire shuffle button
    document
      .getElementById('shuffle-btn')
      ?.addEventListener('click', doShuffle);

    if (!wsId) {
      emptyEl.style.display = '';
      return;
    }

    async function loadItems() {
      const res = await fetch(
        `/api/workspaces/${wsId}/items?page=${currentPage}&per_page=${pageSize}`,
        { credentials: 'include' },
      );
      if (!res.ok) {
        emptyEl.style.display = '';
        return;
      }
      const data = await res.json();
      totalItems = data.total;

      // Update title
      const wsRes = await fetch(`/api/workspaces/${wsId}`, {
        credentials: 'include',
      });
      if (wsRes.ok) {
        const ws = await wsRes.json();
        titleEl.textContent = `${ws.name} (${totalItems})`;
      }

      if (totalItems === 0) {
        emptyEl.style.display = '';
        gridEl.style.display = 'none';
      } else {
        emptyEl.style.display = 'none';
        gridEl.style.display = 'grid';
      }

      // Always show process bar — shuffle works even with empty workspace
      processBar.style.display = 'flex';

      const playSvg = `<svg viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>`;

      function fmtDur(s: number) {
        const m = Math.floor(s / 60);
        const sec = Math.floor(s % 60);
        return `${m}:${sec.toString().padStart(2, '0')}`;
      }

      gridEl.innerHTML = data.items
        .map((item: any) => {
          const hasThumb =
            item.media_type === 'image' || item.media_type === 'video';
          const thumb = hasThumb
            ? `<img src="/api/media/${item.media_item_id}/thumbnail" alt="" loading="lazy" />`
            : `<img src="/assets/default-cover.jpg" alt="${item.media_type}" loading="lazy" style="image-rendering: pixelated;" />`;
          const canPlay =
            item.media_type === 'audio' || item.media_type === 'video';
          const playBtn = canPlay
            ? `<button class="ws-play" data-play-id="${item.media_item_id}" data-play-type="${item.media_type}" title="Play">${playSvg}</button><button class="ws-add" data-play-id="${item.media_item_id}" data-play-type="${item.media_type}" title="Add to queue">+</button>`
            : '';
          const dur = item.duration_seconds
            ? `<span class="ws-duration">${fmtDur(item.duration_seconds)}</span>`
            : '';
          return `<div class="ws-item">
          <button class="ws-remove" data-id="${item.media_item_id}" title="Remove">&times;</button>
          <div class="ws-thumb">
            <span class="ws-type-badge">${item.media_type}</span>
            ${thumb}
            ${playBtn}
            ${dur}
          </div>
          <div class="ws-info">
            <div class="ws-name" title="${item.filename}">${item.filename}</div>
          </div>
        </div>`;
        })
        .join('');

      // Remove buttons
      gridEl.querySelectorAll('.ws-remove').forEach((btn) => {
        btn.addEventListener('click', async (e) => {
          e.stopPropagation();
          const id = (btn as HTMLElement).dataset.id;
          await fetch(`/api/workspaces/${wsId}/items`, {
            method: 'DELETE',
            credentials: 'include',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ media_item_ids: [id] }),
          });
          loadItems();
        });
      });

      // Play buttons — dispatch to the persistent player
      gridEl.querySelectorAll('.ws-play').forEach((btn) => {
        btn.addEventListener('click', (e) => {
          e.stopPropagation();
          const el = btn as HTMLElement;
          const mediaId = el.dataset.playId!;
          const item = data.items.find((i: any) => i.media_item_id === mediaId);
          if (!item) return;
          document.dispatchEvent(
            new CustomEvent('player:queue', {
              detail: {
                tracks: [
                  {
                    track_id: mediaId,
                    title: item.filename,
                    release_title: '',
                    release_code: '',
                    media_type: item.media_type,
                    stream_url: `/api/media/${mediaId}/file`,
                    cover_url:
                      item.media_type === 'image' || item.media_type === 'video'
                        ? `/api/media/${mediaId}/thumbnail`
                        : '/assets/default-cover.jpg',
                    duration: item.duration_seconds || 0,
                    entity_name: '',
                  },
                ],
                startIndex: 0,
              },
            }),
          );
        });
      });

      // Add to queue buttons
      gridEl.querySelectorAll('.ws-add').forEach((btn) => {
        btn.addEventListener('click', (e) => {
          e.stopPropagation();
          const el = btn as HTMLElement;
          const mediaId = el.dataset.playId!;
          const item = data.items.find((i: any) => i.media_item_id === mediaId);
          if (!item) return;
          document.dispatchEvent(
            new CustomEvent('player:add', {
              detail: {
                tracks: [
                  {
                    track_id: mediaId,
                    title: item.filename,
                    release_title: '',
                    release_code: '',
                    media_type: item.media_type,
                    stream_url: `/api/media/${mediaId}/file`,
                    cover_url:
                      item.media_type === 'image' || item.media_type === 'video'
                        ? `/api/media/${mediaId}/thumbnail`
                        : '/assets/default-cover.jpg',
                    duration: item.duration_seconds || 0,
                    entity_name: '',
                  },
                ],
              },
            }),
          );
        });
      });

      // Pagination
      const totalPages = Math.ceil(totalItems / pageSize);
      paginationEl.style.display = totalPages > 1 ? 'flex' : 'none';
      pageInfo.textContent = `Page ${currentPage} of ${totalPages}`;
    }

    document.getElementById('prev-page')?.addEventListener('click', () => {
      if (currentPage > 1) {
        currentPage--;
        loadItems();
      }
    });
    document.getElementById('next-page')?.addEventListener('click', () => {
      if (currentPage * pageSize < totalItems) {
        currentPage++;
        loadItems();
      }
    });

    // Clear workspace
    document
      .getElementById('clear-workspace-btn')
      ?.addEventListener('click', async () => {
        if (
          !(await (window as any).confirmDialog(
            'Remove all items from workspace?',
            'Clear All',
          ))
        )
          return;
        await fetch(`/api/workspaces/${wsId}`, {
          method: 'DELETE',
          credentials: 'include',
        });
        localStorage.removeItem('active_workspace_id');
        emptyEl.style.display = '';
        gridEl.style.display = 'none';
        processBar.style.display = 'none';
      });

    // Load apps
    const appSelect = document.getElementById(
      'app-select',
    ) as HTMLSelectElement;
    const configureBtn = document.getElementById(
      'configure-btn',
    ) as HTMLButtonElement;
    let apps: any[] = [];

    try {
      const res = await fetch('/api/apps', { credentials: 'include' });
      if (res.ok) {
        apps = await res.json();
        apps.forEach((app) => {
          const opt = document.createElement('option');
          opt.value = app.name;
          opt.textContent = app.display_name;
          appSelect.appendChild(opt);
        });
      }
    } catch {}

    appSelect.addEventListener('change', () => {
      configureBtn.disabled = !appSelect.value;
    });

    // Configure & Run
    configureBtn.addEventListener('click', () => {
      const app = apps.find((a) => a.name === appSelect.value);
      if (!app) return;

      document.getElementById('config-app-name')!.textContent =
        app.display_name;
      document.getElementById('config-app-desc')!.textContent =
        app.description || '';

      const detailEl = document.getElementById('config-app-detail')!;
      const detailWrap = document.getElementById('config-app-detail-wrap')!;
      const manifest = app.manifest;
      if (manifest.long_description) {
        detailEl.textContent = manifest.long_description;
        detailWrap.style.display = '';
      } else {
        detailWrap.style.display = 'none';
      }

      const paramsContainer = document.getElementById('config-params')!;
      paramsContainer.innerHTML = '';

      const paramSpecs = manifest.params || {};

      // Check if a param's depends_on condition is met given current form values
      const isParamActive = (spec: any): boolean => {
        const dep = spec.depends_on;
        if (!dep) return true;
        const depEl = paramsContainer.querySelector(`[name="${dep.param}"]`) as
          | HTMLInputElement
          | HTMLSelectElement;
        if (!depEl) return true;
        const depVal = depEl.value;
        if (dep.values) return dep.values.includes(depVal);
        return depVal === dep.value;
      };

      // Update visibility of all param fields based on depends_on
      const updateVisibility = () => {
        for (const [name, spec] of Object.entries(paramSpecs) as [
          string,
          any,
        ][]) {
          const field = paramsContainer.querySelector(
            `[data-param-field="${name}"]`,
          ) as HTMLElement;
          if (!field) continue;
          field.style.display = isParamActive(spec) ? '' : 'none';
        }
      };

      // Helper: look up input_count for a selected option across all option_groups
      const getInputCount = (spec: any, value: string): number | null => {
        for (const g of spec.option_groups || []) {
          for (const o of g.options) {
            if (
              typeof o === 'object' &&
              o.value === value &&
              o.input_count != null
            ) {
              return o.input_count;
            }
          }
        }
        return null;
      };

      for (const [name, spec] of Object.entries(paramSpecs) as [
        string,
        any,
      ][]) {
        const field = document.createElement('div');
        field.className = 'config-field';
        field.setAttribute('data-param-field', name);

        let inputHtml = '';
        if (spec.type === 'multi_select') {
          // Multi-select: dropdown picker + ordered list of selections
          let groupedOpts = '';
          if (spec.option_groups) {
            groupedOpts = spec.option_groups
              .map((g: any) => {
                const opts = g.options
                  .map((o: any) => {
                    const val = typeof o === 'string' ? o : o.value;
                    const label = typeof o === 'string' ? o : o.label;
                    const ic =
                      typeof o === 'object' && o.input_count
                        ? ` (${o.input_count} img)`
                        : '';
                    return `<option value="${val}">${label}${ic}</option>`;
                  })
                  .join('');
                return `<optgroup label="${g.label}">${opts}</optgroup>`;
              })
              .join('');
          } else {
            groupedOpts = (spec.options || [])
              .map((o: string) => `<option value="${o}">${o}</option>`)
              .join('');
          }
          inputHtml = `
            <div class="multi-select-wrap" data-ms-name="${name}">
              <div class="ms-picker">
                <select class="ms-dropdown"><option value="">Add recipe to chain...</option>${groupedOpts}</select>
                <button type="button" class="action-btn ms-add-btn">Add</button>
              </div>
              <ol class="ms-list"></ol>
              <input type="hidden" name="${name}" value="[]" />
            </div>`;
        } else if (spec.type === 'select') {
          if (spec.option_groups) {
            const groups = spec.option_groups
              .map((g: any) => {
                const opts = g.options
                  .map((o: any) => {
                    const val = typeof o === 'string' ? o : o.value;
                    const label = typeof o === 'string' ? o : o.label;
                    return `<option value="${val}" ${val === spec.default ? 'selected' : ''}>${label}</option>`;
                  })
                  .join('');
                return `<optgroup label="${g.label}">${opts}</optgroup>`;
              })
              .join('');
            inputHtml = `<select name="${name}">${groups}</select>`;
          } else {
            const options = (spec.options || [])
              .map(
                (o: string) =>
                  `<option value="${o}" ${o === spec.default ? 'selected' : ''}>${o}</option>`,
              )
              .join('');
            inputHtml = `<select name="${name}">${options}</select>`;
          }
        } else if (spec.type === 'bool') {
          inputHtml = `<label style="display:inline;"><input type="checkbox" name="${name}" ${spec.default ? 'checked' : ''} /> Enabled</label>`;
        } else if (spec.type === 'float' || spec.type === 'int') {
          const step = spec.type === 'float' ? '0.1' : '1';
          const req = spec.required ? 'required' : '';
          inputHtml = `<input type="number" name="${name}" value="${spec.default ?? ''}" min="${spec.min ?? ''}" max="${spec.max ?? ''}" step="${step}" ${req} />`;
        } else {
          const req = spec.required ? 'required' : '';
          inputHtml = `<input type="text" name="${name}" value="${spec.default ?? ''}" ${req} />`;
        }

        field.innerHTML = `
          <label>${spec.label || name}${spec.required ? ' *' : ''}</label>
          ${spec.description ? `<div class="config-desc">${spec.description}</div>` : ''}
          ${inputHtml}
          <div class="config-option-desc" data-option-desc="${name}" style="display:none;"></div>
          <div class="config-input-count" data-input-count="${name}" style="display:none;"></div>
          <div class="param-error login-error" data-param="${name}" style="display:none; text-align:left;"></div>
        `;
        paramsContainer.appendChild(field);

        // Wire up multi_select add/remove behavior
        if (spec.type === 'multi_select') {
          const wrap = field.querySelector(
            `.multi-select-wrap[data-ms-name="${name}"]`,
          )!;
          const dropdown = wrap.querySelector(
            '.ms-dropdown',
          ) as HTMLSelectElement;
          const addBtn = wrap.querySelector('.ms-add-btn')!;
          const list = wrap.querySelector('.ms-list')!;
          const hiddenInput = wrap.querySelector(
            `input[name="${name}"]`,
          ) as HTMLInputElement;
          let selected: string[] = [];

          const syncHidden = () => {
            hiddenInput.value = JSON.stringify(selected);
            hiddenInput.dispatchEvent(new Event('change', { bubbles: true }));

            // Update shuffle section for multi_select chains
            const inputSpec = manifest.input || {};
            if (inputSpec.allow_random_fill && selected.length > 0) {
              let maxCount = 0;
              for (const val of selected) {
                const ic = getInputCount(spec, val);
                if (ic !== null && ic > maxCount) maxCount = ic;
              }
              if (maxCount > 0) {
                const mediaTypes = inputSpec.media_types || [];
                showShuffleSection(
                  maxCount,
                  mediaTypes,
                  app.name,
                  selected.join(','),
                );
              }
            } else if (selected.length === 0) {
              hideShuffleSection();
            }
          };

          const renderList = () => {
            list.innerHTML = selected
              .map((val, i) => {
                // Find label for this value
                let label = val;
                for (const g of spec.option_groups || []) {
                  for (const o of g.options) {
                    if (typeof o === 'object' && o.value === val) {
                      label = o.label || val;
                      break;
                    }
                  }
                }
                return `<li data-idx="${i}">
                <span class="ms-num">${i + 1}.</span>
                <span class="ms-label">${label}</span>
                <button type="button" class="ms-remove" data-idx="${i}" title="Remove">&times;</button>
              </li>`;
              })
              .join('');
            list.querySelectorAll('.ms-remove').forEach((btn) => {
              btn.addEventListener('click', () => {
                const idx = parseInt((btn as HTMLElement).dataset.idx!);
                selected.splice(idx, 1);
                renderList();
                syncHidden();
              });
            });
          };

          addBtn.addEventListener('click', () => {
            if (!dropdown.value) return;
            selected.push(dropdown.value);
            dropdown.value = '';
            renderList();
            syncHidden();
          });
        }

        // For grouped selects with option descriptions and input_count, show both
        if (spec.type === 'select' && spec.option_groups) {
          const selectEl = field.querySelector('select')!;
          const descEl = field.querySelector(
            `.config-option-desc[data-option-desc="${name}"]`,
          ) as HTMLElement;
          const countEl = field.querySelector(
            `.config-input-count[data-input-count="${name}"]`,
          ) as HTMLElement;
          const updateOptionDesc = () => {
            const val = (selectEl as HTMLSelectElement).value;
            let desc = '';
            let inputCount: number | null = null;
            for (const g of spec.option_groups) {
              for (const o of g.options) {
                const oVal = typeof o === 'string' ? o : o.value;
                if (oVal === val && typeof o === 'object') {
                  if (o.description) desc = o.description;
                  if (o.input_count != null) inputCount = o.input_count;
                  break;
                }
              }
              if (desc || inputCount) break;
            }
            if (desc) {
              descEl.textContent = desc;
              descEl.style.display = 'block';
            } else {
              descEl.style.display = 'none';
            }
            // Show input count validation info
            if (inputCount !== null) {
              const diff = totalItems - inputCount;
              if (diff === 0) {
                countEl.textContent = `Requires ${inputCount} images. You have ${totalItems} selected. Ready.`;
                countEl.className = 'config-input-count input-count-ok';
              } else if (diff < 0) {
                countEl.textContent = `Requires ${inputCount} images. You have ${totalItems} selected. ${-diff} more will be filled randomly from search.`;
                countEl.className = 'config-input-count input-count-fill';
              } else {
                countEl.textContent = `Requires ${inputCount} images. You have ${totalItems} selected. Remove ${diff} item(s) before submitting.`;
                countEl.className = 'config-input-count input-count-over';
              }
              countEl.style.display = 'block';

              // Show shuffle section if app allows random fill
              const inputSpec = manifest.input || {};
              if (inputSpec.allow_random_fill) {
                const mediaTypes = inputSpec.media_types || [];
                showShuffleSection(inputCount, mediaTypes, app.name, val);
              }
            } else {
              countEl.style.display = 'none';
              hideShuffleSection();
            }
          };
          selectEl.addEventListener('change', updateOptionDesc);
          updateOptionDesc();
        }
      }

      // Wire up depends_on visibility: any select/input change re-evaluates visibility
      paramsContainer.querySelectorAll('input, select').forEach((el) => {
        el.addEventListener('change', updateVisibility);
        el.addEventListener('input', () => {
          const name = (el as HTMLInputElement).name;
          const errDiv = paramsContainer.querySelector(
            `.param-error[data-param="${name}"]`,
          ) as HTMLElement;
          if (errDiv) errDiv.style.display = 'none';
        });
      });
      updateVisibility();

      // Reset shuffle when opening config for a new/different app
      hideShuffleSection();

      // If app has allow_random_fill but no per-recipe input_count, show shuffle with min_items
      const inputSpec = manifest.input || {};
      if (inputSpec.allow_random_fill) {
        const hasPerRecipeCount = Object.values(paramSpecs).some((s: any) =>
          (s.option_groups || []).some((g: any) =>
            g.options.some(
              (o: any) => typeof o === 'object' && o.input_count != null,
            ),
          ),
        );
        if (!hasPerRecipeCount && inputSpec.min_items) {
          showShuffleSection(
            inputSpec.min_items,
            inputSpec.media_types || [],
            app.name,
            '',
          );
        }
      }

      document.getElementById('config-section')!.style.display = '';
      document
        .getElementById('config-section')!
        .scrollIntoView({ behavior: 'smooth' });
    });

    document.getElementById('config-cancel')?.addEventListener('click', () => {
      document.getElementById('config-section')!.style.display = 'none';
      hideShuffleSection();
    });

    document
      .getElementById('config-submit')
      ?.addEventListener('click', async () => {
        const app = apps.find((a) => a.name === appSelect.value);
        if (!app) return;

        // Collect params from form
        const paramsContainer = document.getElementById('config-params')!;
        const jobParams: Record<string, any> = {};
        const manifest = app.manifest;

        // Clear previous inline errors
        paramsContainer.querySelectorAll('.param-error').forEach((el) => {
          (el as HTMLElement).style.display = 'none';
        });

        // Check if a param's depends_on is met (mirrors the visibility logic)
        const isActive = (spec: any): boolean => {
          const dep = spec.depends_on;
          if (!dep) return true;
          const depEl = paramsContainer.querySelector(
            `[name="${dep.param}"]`,
          ) as HTMLInputElement | HTMLSelectElement;
          if (!depEl) return true;
          const depVal = depEl.value;
          if (dep.values) return dep.values.includes(depVal);
          return depVal === dep.value;
        };

        let hasFieldError = false;
        let needsRandomFill = false;
        for (const [name, spec] of Object.entries(manifest.params || {}) as [
          string,
          any,
        ][]) {
          // Skip inactive (hidden) params
          if (!isActive(spec)) continue;

          const el = paramsContainer.querySelector(`[name="${name}"]`) as
            | HTMLInputElement
            | HTMLSelectElement;
          if (!el) continue;
          if (spec.type === 'bool') {
            jobParams[name] = (el as HTMLInputElement).checked;
          } else if (spec.type === 'float') {
            jobParams[name] = parseFloat(el.value);
          } else if (spec.type === 'int') {
            if (el.value.trim() === '') {
              // Optional int with no value — omit from params
              continue;
            }
            jobParams[name] = parseInt(el.value);
          } else if (spec.type === 'multi_select') {
            try {
              jobParams[name] = JSON.parse(el.value);
            } catch {
              jobParams[name] = [];
            }
          } else {
            jobParams[name] = el.value;
          }

          // Validate required params
          if (spec.required && spec.type !== 'bool') {
            if (spec.type === 'multi_select') {
              const arr = jobParams[name];
              const minSel = spec.min_selections || 2;
              if (!Array.isArray(arr) || arr.length < minSel) {
                const errDiv = paramsContainer.querySelector(
                  `.param-error[data-param="${name}"]`,
                ) as HTMLElement;
                if (errDiv) {
                  errDiv.textContent = `${spec.label || name} requires at least ${minSel} selections`;
                  errDiv.style.display = 'block';
                }
                hasFieldError = true;
              }
            } else {
              const val = String(el.value).trim();
              if (!val) {
                const errDiv = paramsContainer.querySelector(
                  `.param-error[data-param="${name}"]`,
                ) as HTMLElement;
                if (errDiv) {
                  errDiv.textContent = `${spec.label || name} is required`;
                  errDiv.style.display = 'block';
                }
                hasFieldError = true;
              }
            }
          }

          // Check per-recipe input_count validation (skip when shuffle is active — it already has the right count)
          if (!shuffleActive && spec.type === 'select' && spec.option_groups) {
            const selectedVal = el.value;
            for (const g of spec.option_groups) {
              for (const o of g.options) {
                if (
                  typeof o === 'object' &&
                  o.value === selectedVal &&
                  o.input_count != null
                ) {
                  const required = o.input_count as number;
                  if (totalItems > required) {
                    const errDiv = paramsContainer.querySelector(
                      `.param-error[data-param="${name}"]`,
                    ) as HTMLElement;
                    if (errDiv) {
                      errDiv.textContent = `This recipe requires ${required} images but you have ${totalItems}. Remove ${totalItems - required} item(s).`;
                      errDiv.style.display = 'block';
                    }
                    hasFieldError = true;
                  } else if (totalItems < required) {
                    needsRandomFill = true;
                  }
                }
              }
            }
          }
        }

        if (hasFieldError) return;

        // Get input item IDs — from shuffle if active, otherwise from workspace
        let mediaIds: string[];
        let useRandomFill = needsRandomFill;
        if (shuffleActive && shuffleItems.length > 0) {
          mediaIds = shuffleItems.map((i) => i.id);
          useRandomFill = false; // items are already fully specified
        } else {
          const allRes = await fetch(
            `/api/workspaces/${wsId}/items?page=1&per_page=200`,
            { credentials: 'include' },
          );
          const allData = await allRes.json();
          mediaIds = allData.items.map((i: any) => i.media_item_id);
        }

        try {
          const res = await fetch('/api/jobs', {
            method: 'POST',
            credentials: 'include',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              app_name: app.name,
              media_item_ids: mediaIds,
              params: jobParams,
              random_fill: useRandomFill,
            }),
          });

          if (res.ok) {
            const job = await res.json();
            document.getElementById('config-section')!.style.display = 'none';
            window.location.href = `/admin/jobs?highlight=${job.id}`;
          } else {
            try {
              const err = await res.json();
              const detail = err.detail;
              if (detail?.errors && Array.isArray(detail.errors)) {
                const msgs = detail.errors.map(
                  (e: any) => e.message || `${e.field}: unknown error`,
                );
                (window as any).toast.error(msgs.join(' | '), 10000);
              } else if (typeof detail === 'string') {
                (window as any).toast.error(detail);
              } else {
                (window as any).toast.error(
                  detail?.detail || 'Job submission failed',
                );
              }
            } catch {
              (window as any).toast.error(
                `Job submission failed (HTTP ${res.status})`,
              );
            }
          }
        } catch (e) {
          (window as any).toast.error(
            'Failed to create job: ' + (e as Error).message,
          );
        }
      });

    loadItems();
  });
</script>
