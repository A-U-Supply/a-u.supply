---
import Admin from '../../../layouts/Admin.astro';
---

<Admin title="Media Search" current="search">
  <div class="page-header">
    <h1>Media Search</h1>
    <div class="header-actions">
      <a class="workspace-badge" id="workspace-badge" href="/admin/search/workspace" style="display:none;" title="View workspace">Workspace: <span id="workspace-count">0</span></a>
      <button class="sync-btn" id="sync-now-btn" title="Sync new media from Slack">Sync Now</button>
      <span class="sync-status" id="sync-status"></span>
      <div class="view-toggle">
        <button class="toggle-btn active" id="grid-view-btn" title="Grid view">Grid</button>
        <button class="toggle-btn" id="list-view-btn" title="List view">List</button>
      </div>
    </div>
  </div>

  <form id="search-form" class="search-bar">
    <input type="text" id="search-input" placeholder="Search media..." autocomplete="off" />
    <button type="submit" class="search-submit">Search</button>
  </form>

  <div class="search-layout">
    <aside class="filter-panel" id="filter-panel">
      <button class="filter-toggle" id="filter-toggle">Filters</button>

      <div class="filter-body" id="filter-body">
        <div class="filter-group">
          <label class="filter-label">Media Type</label>
          <label class="filter-check"><input type="checkbox" value="image" checked /> Image</label>
          <label class="filter-check"><input type="checkbox" value="audio" checked /> Audio</label>
          <label class="filter-check"><input type="checkbox" value="video" checked /> Video</label>
        </div>

        <div class="filter-group">
          <label class="filter-label">Source Channel</label>
          <select id="filter-channel" multiple size="4">
            <option value="">Loading...</option>
          </select>
        </div>

        <div class="filter-group">
          <label class="filter-label">Date Range</label>
          <input type="date" id="filter-date-from" placeholder="From" />
          <input type="date" id="filter-date-to" placeholder="To" />
        </div>

        <div class="filter-group">
          <label class="filter-label">Color</label>
          <div class="color-checks">
            <label class="filter-check"><input type="checkbox" name="color-group" value="red" /> Red</label>
            <label class="filter-check"><input type="checkbox" name="color-group" value="orange" /> Orange</label>
            <label class="filter-check"><input type="checkbox" name="color-group" value="yellow" /> Yellow</label>
            <label class="filter-check"><input type="checkbox" name="color-group" value="green" /> Green</label>
            <label class="filter-check"><input type="checkbox" name="color-group" value="teal" /> Teal</label>
            <label class="filter-check"><input type="checkbox" name="color-group" value="blue" /> Blue</label>
            <label class="filter-check"><input type="checkbox" name="color-group" value="purple" /> Purple</label>
            <label class="filter-check"><input type="checkbox" name="color-group" value="pink" /> Pink</label>
            <label class="filter-check"><input type="checkbox" name="color-group" value="brown" /> Brown</label>
            <label class="filter-check"><input type="checkbox" name="color-group" value="beige" /> Beige</label>
            <label class="filter-check"><input type="checkbox" name="color-group" value="gray" /> Gray</label>
            <label class="filter-check"><input type="checkbox" name="color-group" value="black" /> Black</label>
            <label class="filter-check"><input type="checkbox" name="color-group" value="white" /> White</label>
          </div>
        </div>

        <div class="filter-group">
          <label class="filter-label">Posted By</label>
          <select id="filter-poster">
            <option value="">All</option>
          </select>
        </div>

        <div class="filter-group">
          <label class="filter-label">Tags</label>
          <input type="text" id="filter-tags" placeholder="Comma-separated tags" />
        </div>

        <div class="filter-group">
          <label class="filter-label">Min Reactions</label>
          <input type="number" id="filter-reactions-min" min="0" value="0" />
        </div>

        <div class="filter-group">
          <label class="filter-label">Min Tags</label>
          <input type="number" id="filter-tags-min" min="0" value="0" />
        </div>

        <div class="filter-group">
          <label class="filter-label">Sort By</label>
          <select id="sort-by">
            <option value="newest">Newest</option>
            <option value="oldest">Oldest</option>
            <option value="most_reactions">Most Reactions</option>
            <option value="largest">Largest</option>
            <option value="longest">Longest</option>
          </select>
        </div>

        <button class="action-btn" id="apply-filters" style="width:100%; margin-top: var(--space-xs);">Apply Filters</button>

        <div class="insights-section" id="insights-section" style="display:none;">
          <button class="insights-toggle" id="insights-toggle">Insights</button>
          <div class="insights-body" id="insights-body">
            <div class="insight-group" id="insight-uploaders"></div>
            <div class="insight-group" id="insight-tags"></div>
            <div class="insight-group" id="insight-reactions"></div>
            <div class="insight-group" id="insight-timeline"></div>
            <div class="insight-group" id="insight-colors"></div>
          </div>
        </div>
      </div>
    </aside>

    <div class="results-area">
      <div class="stats-bar" id="stats-bar" style="display:none;"></div>
      <div id="active-filters" class="active-filters" style="display:none;"></div>
      <div class="batch-bar" id="batch-bar" style="display:none;">
        <span id="selected-count">0 selected</span>
        <button class="action-btn" data-batch="tag">Tag</button>
        <button class="action-btn" data-batch="workspace">+ Workspace</button>
        <button class="action-btn" data-batch="re-extract">Re-extract</button>
        <button class="action-btn" data-batch="export">Export</button>
        <button class="action-btn action-btn--danger" data-batch="delete">Delete</button>
        <button class="action-btn" id="clear-selection">Clear</button>
      </div>

      <div id="loading" style="color: var(--color-muted);"><span class="loading-dots">Loading</span></div>
      <div id="error" class="login-error" style="display:none;"></div>
      <div id="empty" class="empty-state" style="display:none;">
        <div class="empty-state__icon">&#128269;</div>
        No media found.
      </div>

      <div id="results-grid" class="results-grid" style="display:none;"></div>

      <div class="table-wrap" id="results-table" style="display:none;">
        <table class="release-table">
          <thead>
            <tr>
              <th><input type="checkbox" id="select-all" /></th>
              <th>Filename</th>
              <th>Type</th>
              <th>Posted By</th>
              <th>Channel</th>
              <th>Size</th>
              <th>Reactions</th>
              <th>Tags</th>
              <th>Created</th>
            </tr>
          </thead>
          <tbody id="results-tbody"></tbody>
        </table>
      </div>

      <div class="pagination" id="pagination" style="display:none;">
        <button class="action-btn" id="prev-page">Prev</button>
        <span id="page-info">Page 1</span>
        <button class="action-btn" id="next-page">Next</button>
      </div>
    </div>
  </div>

  <!-- Batch tag dialog -->
  <div class="dialog-overlay" id="batch-tag-dialog" style="display:none;">
    <div class="dialog">
      <p>Add tags to selected items</p>
      <input type="text" id="batch-tag-input" placeholder="Comma-separated tags" style="width:100%; margin-top: var(--space-sm); padding: var(--space-xs); font-family: var(--font-mono); font-size: var(--text-sm); border: 1px solid var(--color-border);" />
      <div class="dialog-actions">
        <button class="btn-cancel" id="batch-tag-cancel">Cancel</button>
        <button class="action-btn" id="batch-tag-confirm">Apply Tags</button>
      </div>
    </div>
  </div>

  <!-- Delete confirmation dialog -->
  <div class="dialog-overlay" id="delete-dialog" style="display:none;">
    <div class="dialog">
      <p>Delete <strong id="delete-count">0</strong> selected items?</p>
      <p style="color: var(--color-muted); font-size: var(--text-sm); margin-top: var(--space-xs);">This action cannot be undone.</p>
      <div class="dialog-actions">
        <button class="btn-cancel" id="delete-cancel">Cancel</button>
        <button class="btn-danger" id="delete-confirm">Delete</button>
      </div>
    </div>
  </div>
</Admin>

<style>
  .workspace-badge {
    padding: var(--space-xs) var(--space-sm);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-text);
    background: none;
    border: 1px solid var(--color-border);
    text-decoration: none;
  }
  .workspace-badge:hover { border-color: var(--color-text); }
  .sync-btn {
    padding: var(--space-xs) var(--space-sm);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: bold;
    text-transform: uppercase;
    letter-spacing: 0.5pt;
    background: #1a1a1a;
    color: #fff;
    border: 2px solid #1a1a1a;
    cursor: pointer;
  }
  .sync-btn:hover { background: #333; border-color: #333; }
  .sync-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }
  .sync-btn.syncing {
    background: none;
    color: var(--color-text);
    border-color: var(--color-border);
  }
  .sync-status {
    font-size: 0.65rem;
    color: var(--color-muted);
    text-transform: uppercase;
    letter-spacing: 0.5pt;
  }
  .view-toggle {
    display: flex;
    gap: 0;
  }
  .toggle-btn {
    padding: var(--space-xs) var(--space-sm);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    text-transform: uppercase;
    letter-spacing: 0.5pt;
    background: none;
    border: 1px solid var(--color-border);
    cursor: pointer;
    color: var(--color-muted);
  }
  .toggle-btn:first-child { border-right: none; }
  .toggle-btn.active {
    color: var(--color-text);
    font-weight: bold;
    background: var(--color-bg);
    border-color: var(--color-text);
  }

  .search-bar {
    display: flex;
    gap: 0;
    margin: var(--space-md) 0;
  }
  .search-bar input {
    flex: 1;
    padding: var(--space-sm);
    font-family: var(--font-mono);
    font-size: var(--text-base);
    border: 2px solid var(--color-text);
    border-right: none;
    background: #fff;
    color: var(--color-text);
  }
  .search-bar input:focus {
    outline: none;
    border-color: var(--color-accent);
  }
  .search-submit {
    padding: var(--space-sm) var(--space-md);
    font-family: var(--font-mono);
    font-size: var(--text-base);
    font-weight: bold;
    text-transform: uppercase;
    letter-spacing: 1pt;
    background: #1a1a1a;
    color: #fff;
    border: 2px solid #1a1a1a;
    cursor: pointer;
  }
  .search-submit:hover { background: #333; border-color: #333; }

  .search-layout {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: var(--space-md);
    align-items: start;
  }

  .filter-panel {
    border: 1px solid var(--color-border);
    padding: var(--space-sm);
  }
  .filter-toggle {
    display: none;
    width: 100%;
    padding: var(--space-xs);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    text-transform: uppercase;
    background: none;
    border: 1px solid var(--color-border);
    cursor: pointer;
    color: var(--color-text);
  }
  .filter-group {
    margin-bottom: var(--space-sm);
  }
  .filter-label {
    display: block;
    font-size: 0.65rem;
    color: var(--color-muted);
    text-transform: uppercase;
    letter-spacing: 0.5pt;
    margin-bottom: var(--space-xs);
  }
  .filter-check {
    display: block;
    font-size: var(--text-sm);
    margin-bottom: 2px;
    cursor: pointer;
  }
  .filter-check input { margin-right: 4px; }
  .filter-group input[type="text"],
  .filter-group input[type="number"],
  .filter-group input[type="date"],
  .filter-group select {
    width: 100%;
    padding: 4px 6px;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    border: 1px solid var(--color-border);
    background: #fff;
    color: var(--color-text);
  }
  .filter-group input:focus,
  .filter-group select:focus {
    outline: 2px solid var(--color-accent);
    outline-offset: -1px;
  }

  .color-checks {
  }

  .active-filters {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
    padding: var(--space-xs) 0;
    margin-bottom: var(--space-xs);
    font-size: 0.7rem;
  }
  .active-filter {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 2px 8px;
    border: 1px solid var(--color-accent);
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.5pt;
  }
  .active-filter__remove {
    background: none;
    border: none;
    color: inherit;
    font-size: 0.8rem;
    cursor: pointer;
    padding: 0;
    line-height: 1;
  }
  .active-filter__color {
    display: inline-block;
    width: 12px;
    height: 12px;
    border: 1px solid #ccc;
    vertical-align: middle;
  }

  /* Stats bar */
  .stats-bar {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    padding: var(--space-xs) var(--space-sm);
    font-size: 0.65rem;
    color: var(--color-muted);
    text-transform: uppercase;
    letter-spacing: 0.5pt;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: var(--space-xs);
    flex-wrap: wrap;
  }
  .stats-bar .stat-total {
    color: var(--color-text);
    font-weight: bold;
  }
  .stats-bar .stat-type {
    cursor: pointer;
  }
  .stats-bar .stat-type:hover {
    color: var(--color-text);
    text-decoration: underline;
  }
  .stats-bar .stat-sep {
    color: var(--color-border);
  }

  /* Insights panel */
  .insights-section {
    margin-top: var(--space-md);
    border-top: 1px solid var(--color-border);
    padding-top: var(--space-sm);
  }
  .insights-toggle {
    width: 100%;
    padding: var(--space-xs);
    font-family: var(--font-mono);
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.5pt;
    background: none;
    border: 1px solid var(--color-border);
    cursor: pointer;
    color: var(--color-text);
  }
  .insights-toggle:hover { border-color: var(--color-text); }
  .insights-body {
    margin-top: var(--space-sm);
  }
  .insights-body.collapsed { display: none; }
  .insight-group {
    margin-bottom: var(--space-md);
  }
  .insight-group:empty { display: none; }
  .insight-title {
    font-size: 0.6rem;
    color: var(--color-muted);
    text-transform: uppercase;
    letter-spacing: 0.5pt;
    margin-bottom: var(--space-xs);
  }
  .insight-bar-row {
    display: flex;
    align-items: center;
    gap: 4px;
    margin-bottom: 2px;
    font-size: 0.6rem;
    cursor: pointer;
  }
  .insight-bar-row:hover { color: var(--color-accent); }
  .insight-bar-label {
    flex: 0 0 70px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    text-align: right;
  }
  .insight-bar-track {
    flex: 1;
    height: 10px;
    background: #f0f0f0;
    position: relative;
  }
  .insight-bar-fill {
    height: 100%;
    background: var(--color-text);
    transition: width 0.3s;
  }
  .insight-bar-row:hover .insight-bar-fill { background: var(--color-accent); }
  .insight-bar-count {
    flex: 0 0 30px;
    text-align: right;
    color: var(--color-muted);
    font-size: 0.55rem;
  }

  .batch-bar {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    padding: var(--space-xs) var(--space-sm);
    background: #f5f5f5;
    border: 1px solid var(--color-border);
    margin-bottom: var(--space-sm);
    flex-wrap: wrap;
  }
  .batch-bar span {
    font-size: var(--text-sm);
    color: var(--color-muted);
    margin-right: auto;
  }

  .pagination { justify-content: center; }

  @media (max-width: 640px) {
    .page-header { flex-direction: column; align-items: stretch; }
    .header-actions { flex-wrap: wrap; }
    .search-bar input { font-size: 16px; } /* prevent iOS zoom */
    .search-layout {
      grid-template-columns: 1fr;
    }
    .filter-toggle { display: block; }
    .filter-body { display: none; }
    .filter-body.open { display: block; margin-top: var(--space-sm); }
  }
</style>

<!-- Global styles for dynamically rendered grid items (innerHTML) -->
<style is:global>
  .results-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: var(--space-sm);
  }
  .results-grid .grid-item {
    border: 1px solid var(--color-border);
    cursor: pointer;
    position: relative;
    transition: border-color 0.15s;
    overflow: hidden;
    min-width: 0;
  }
  .results-grid .grid-item:hover { border-color: var(--color-text); }
  .results-grid .grid-item.selected { border-color: var(--color-accent); border-width: 2px; }
  .results-grid .grid-item__check {
    position: absolute;
    top: 4px;
    left: 4px;
    z-index: 1;
  }
  .results-grid .grid-item__thumb {
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
    background: #eee;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: var(--text-sm);
    color: var(--color-muted);
    text-transform: uppercase;
    position: relative;
    overflow: hidden;
  }
  .results-grid .grid-item__thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .results-grid .grid-item__play {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0,0,0,0.35);
    opacity: 0;
    transition: opacity 0.15s;
    cursor: pointer;
    border: none;
    padding: 0;
  }
  .results-grid .grid-item__thumb:hover .grid-item__play { opacity: 1; }
  .results-grid .grid-item__play svg {
    width: 32px;
    height: 32px;
    fill: #fff;
    filter: drop-shadow(0 1px 3px rgba(0,0,0,0.5));
  }
  .results-grid .grid-item__add {
    position: absolute;
    bottom: 4px;
    right: 4px;
    background: rgba(0,0,0,0.6);
    color: #fff;
    border: 1px solid rgba(255,255,255,0.3);
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-weight: bold;
    width: 24px;
    height: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    opacity: 0;
    transition: opacity 0.15s;
    padding: 0;
    z-index: 1;
  }
  .results-grid .grid-item__thumb:hover .grid-item__add { opacity: 1; }
  .results-grid .grid-item__add:hover { background: rgba(184,134,11,0.8); border-color: #b8860b; }
  .results-grid .grid-item__info {
    padding: 4px 6px;
    font-size: 0.65rem;
    border-top: 1px solid var(--color-border);
    min-width: 0;
  }
  .results-grid .grid-item__name {
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    display: flex;
    align-items: center;
    gap: 3px;
  }
  .results-grid .grid-item__meta {
    color: var(--color-muted);
    display: flex;
    justify-content: space-between;
  }

  @media (max-width: 640px) {
    .results-grid {
      grid-template-columns: repeat(auto-fill, minmax(100px, 1fr));
      gap: 4px;
    }
    .results-grid .grid-item__info { font-size: 0.55rem; }
    .batch-bar { font-size: 0.6rem; gap: 4px; }
    .batch-bar .action-btn { font-size: 0.55rem; padding: 2px 4px; }
    /* Hide less important columns on mobile */
    .release-table th:nth-child(4),
    .release-table td:nth-child(4),
    .release-table th:nth-child(5),
    .release-table td:nth-child(5),
    .release-table th:nth-child(6),
    .release-table td:nth-child(6) {
      display: none;
    }
  }
</style>

<script>
  document.addEventListener('astro:page-load', async () => {
    const searchForm = document.getElementById('search-form') as HTMLFormElement | null;
    if (!searchForm) return;

    const user = await (window as any).__authReady;
    if (!user) return;

    // Sync Now button
    const syncBtn = document.getElementById('sync-now-btn') as HTMLButtonElement | null;
    const syncStatus = document.getElementById('sync-status');
    syncBtn?.addEventListener('click', async () => {
      if (syncBtn.disabled) return;
      syncBtn.disabled = true;
      syncBtn.classList.add('syncing');
      syncBtn.textContent = 'Syncing...';
      if (syncStatus) syncStatus.textContent = '';

      try {
        const res = await fetch('/api/ingest/slack/sync', {
          method: 'POST',
          credentials: 'include',
        });
        const data = await res.json();
        if (data.ok) {
          const reactionsUpdated = data.reactions?.updated || 0;
          if (syncStatus) syncStatus.textContent = `Reactions: ${reactionsUpdated} updated. Scrape: ${data.scrape?.status || 'started'}`;
          // Poll for scrape completion, then refresh results
          if (data.scrape?.status === 'started') {
            pollScrapeStatus();
          } else {
            doSearch();
          }
        } else {
          if (syncStatus) syncStatus.textContent = data.detail || 'Sync failed';
        }
      } catch {
        if (syncStatus) syncStatus.textContent = 'Sync request failed';
      } finally {
        syncBtn.disabled = false;
        syncBtn.classList.remove('syncing');
        syncBtn.textContent = 'Sync Now';
      }
    });

    async function pollScrapeStatus() {
      const poll = async () => {
        try {
          const res = await fetch('/api/ingest/slack/status', { credentials: 'include' });
          const data = await res.json();
          if (data.ok && data.status?.running) {
            if (syncStatus) syncStatus.textContent = `Scraping: ${data.status.current_channel || '...'}`;
            setTimeout(poll, 3000);
          } else {
            if (syncStatus) syncStatus.textContent = 'Sync complete';
            doSearch();
            setTimeout(() => { if (syncStatus) syncStatus.textContent = ''; }, 5000);
          }
        } catch {
          if (syncStatus) syncStatus.textContent = '';
        }
      };
      setTimeout(poll, 2000);
    }

    let currentView = 'grid';
    let currentPage = 1;
    const pageSize = 24;
    let totalResults = 0;
    let allResults: any[] = [];
    let selectedIds = new Set<string>();

    const searchInput = document.getElementById('search-input') as HTMLInputElement;
    const loadingEl = document.getElementById('loading')!;
    const errorEl = document.getElementById('error')!;
    const emptyEl = document.getElementById('empty')!;
    const gridEl = document.getElementById('results-grid')!;
    const tableEl = document.getElementById('results-table')!;
    const tbodyEl = document.getElementById('results-tbody')!;
    const paginationEl = document.getElementById('pagination')!;
    const batchBar = document.getElementById('batch-bar')!;
    const selectedCount = document.getElementById('selected-count')!;
    const pageInfo = document.getElementById('page-info')!;

    // View toggle
    document.getElementById('grid-view-btn')?.addEventListener('click', () => {
      currentView = 'grid';
      document.getElementById('grid-view-btn')!.classList.add('active');
      document.getElementById('list-view-btn')!.classList.remove('active');
      renderResults();
    });
    document.getElementById('list-view-btn')?.addEventListener('click', () => {
      currentView = 'list';
      document.getElementById('list-view-btn')!.classList.add('active');
      document.getElementById('grid-view-btn')!.classList.remove('active');
      renderResults();
    });

    // Filter toggle (mobile)
    document.getElementById('filter-toggle')?.addEventListener('click', () => {
      document.getElementById('filter-body')?.classList.toggle('open');
    });

    // Insights toggle
    document.getElementById('insights-toggle')?.addEventListener('click', () => {
      document.getElementById('insights-body')?.classList.toggle('collapsed');
    });

    // Apply filters button
    document.getElementById('apply-filters')?.addEventListener('click', () => {
      currentPage = 1;
      doSearch();
    });

    // Search form
    searchForm.addEventListener('submit', (e) => {
      e.preventDefault();
      currentPage = 1;
      doSearch();
    });

    // Pagination
    document.getElementById('prev-page')?.addEventListener('click', () => {
      if (currentPage > 1) { currentPage--; doSearch(); }
    });
    document.getElementById('next-page')?.addEventListener('click', () => {
      if (currentPage * pageSize < totalResults) { currentPage++; doSearch(); }
    });

    // Select all
    document.getElementById('select-all')?.addEventListener('change', (e) => {
      const checked = (e.target as HTMLInputElement).checked;
      allResults.forEach(r => {
        if (checked) selectedIds.add(r.id);
        else selectedIds.delete(r.id);
      });
      updateSelection();
      renderResults();
    });

    // Batch actions
    document.querySelectorAll('[data-batch]').forEach(btn => {
      btn.addEventListener('click', () => {
        const action = (btn as HTMLElement).dataset.batch;
        if (action === 'tag') {
          document.getElementById('batch-tag-dialog')!.style.display = 'flex';
        } else if (action === 'workspace') {
          addToWorkspace();
        } else if (action === 'delete') {
          document.getElementById('delete-count')!.textContent = String(selectedIds.size);
          document.getElementById('delete-dialog')!.style.display = 'flex';
        } else if (action === 're-extract') {
          batchReExtract();
        } else if (action === 'export') {
          batchExport();
        }
      });
    });

    document.getElementById('clear-selection')?.addEventListener('click', () => {
      selectedIds.clear();
      updateSelection();
      renderResults();
    });

    // Batch tag dialog
    document.getElementById('batch-tag-cancel')?.addEventListener('click', () => {
      document.getElementById('batch-tag-dialog')!.style.display = 'none';
    });
    document.getElementById('batch-tag-confirm')?.addEventListener('click', async () => {
      const input = document.getElementById('batch-tag-input') as HTMLInputElement;
      const tags = input.value.split(',').map(t => t.trim()).filter(Boolean);
      if (tags.length === 0) return;
      try {
        await fetch('/api/media/batch/tags', {
          method: 'POST',
          credentials: 'include',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ media_ids: Array.from(selectedIds), tags }),
        });
        document.getElementById('batch-tag-dialog')!.style.display = 'none';
        input.value = '';
        doSearch();
      } catch { (window as any).toast.error('Failed to apply tags'); }
    });

    // Delete dialog
    document.getElementById('delete-cancel')?.addEventListener('click', () => {
      document.getElementById('delete-dialog')!.style.display = 'none';
    });
    document.getElementById('delete-confirm')?.addEventListener('click', async () => {
      try {
        await fetch('/api/media/batch/delete', {
          method: 'POST',
          credentials: 'include',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ media_ids: Array.from(selectedIds) }),
        });
        document.getElementById('delete-dialog')!.style.display = 'none';
        selectedIds.clear();
        doSearch();
      } catch { (window as any).toast.error('Delete failed'); }
    });

    async function batchReExtract() {
      try {
        await fetch('/api/media/batch/re-extract', {
          method: 'POST',
          credentials: 'include',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ media_ids: Array.from(selectedIds) }),
        });
        (window as any).toast.success('Re-extraction queued for ' + selectedIds.size + ' items');
      } catch { (window as any).toast.error('Re-extraction failed'); }
    }

    async function batchExport() {
      try {
        const res = await fetch('/api/media/batch/export', {
          method: 'POST',
          credentials: 'include',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ media_ids: Array.from(selectedIds) }),
        });
        if (res.ok) {
          const blob = await res.blob();
          const url = URL.createObjectURL(blob);
          const a = document.createElement('a');
          a.href = url;
          a.download = 'media-export.zip';
          a.click();
          URL.revokeObjectURL(url);
        }
      } catch { (window as any).toast.error('Export failed'); }
    }

    // --- Workspace ---
    async function ensureWorkspace(): Promise<string> {
      let wsId = localStorage.getItem('active_workspace_id');
      if (wsId) return wsId;
      const res = await fetch('/api/workspaces', { method: 'POST', credentials: 'include',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name: 'My Workspace' }) });
      const data = await res.json();
      wsId = data.id;
      localStorage.setItem('active_workspace_id', wsId!);
      return wsId!;
    }

    async function refreshWorkspaceBadge() {
      const wsId = localStorage.getItem('active_workspace_id');
      const badge = document.getElementById('workspace-badge')!;
      const countEl = document.getElementById('workspace-count')!;
      if (!wsId) { badge.style.display = 'none'; return; }
      try {
        const res = await fetch(`/api/workspaces/${wsId}`, { credentials: 'include' });
        if (!res.ok) { badge.style.display = 'none'; return; }
        const data = await res.json();
        countEl.textContent = String(data.item_count);
        badge.style.display = data.item_count > 0 ? '' : 'none';
      } catch { badge.style.display = 'none'; }
    }

    async function addToWorkspace() {
      const wsId = await ensureWorkspace();
      try {
        const res = await fetch(`/api/workspaces/${wsId}/items`, { method: 'POST', credentials: 'include',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ media_item_ids: Array.from(selectedIds) }) });
        const data = await res.json();
        if (data.ok) {
          (window as any).toast.success(`Added ${data.added} item(s) to workspace`);
          refreshWorkspaceBadge();
        }
      } catch { (window as any).toast.error('Failed to add to workspace'); }
    }

    refreshWorkspaceBadge();

    function getFilters() {
      const types: string[] = [];
      document.querySelectorAll('.filter-check input[type="checkbox"]:checked').forEach(cb => {
        const input = cb as HTMLInputElement;
        // Only media type checkboxes (not color group)
        if (!input.name) types.push(input.value);
      });
      const channel = document.getElementById('filter-channel') as HTMLSelectElement;
      const channels = Array.from(channel.selectedOptions).map(o => o.value).filter(Boolean);
      const dateFrom = (document.getElementById('filter-date-from') as HTMLInputElement).value;
      const dateTo = (document.getElementById('filter-date-to') as HTMLInputElement).value;
      const poster = (document.getElementById('filter-poster') as HTMLSelectElement).value;
      const colorGroups = Array.from(document.querySelectorAll('input[name="color-group"]:checked')).map(cb => (cb as HTMLInputElement).value);
      const tags = (document.getElementById('filter-tags') as HTMLInputElement).value;
      const reactionsMin = parseInt((document.getElementById('filter-reactions-min') as HTMLInputElement).value) || 0;
      const tagsMin = parseInt((document.getElementById('filter-tags-min') as HTMLInputElement).value) || 0;
      const sortBy = (document.getElementById('sort-by') as HTMLSelectElement).value;
      return { types, channels, poster, colorGroups, dateFrom, dateTo, tags, reactionsMin, tagsMin, sortBy };
    }

    async function doSearch() {
      loadingEl.style.display = 'block';
      errorEl.style.display = 'none';
      emptyEl.style.display = 'none';
      gridEl.style.display = 'none';
      tableEl.style.display = 'none';
      paginationEl.style.display = 'none';

      const filters = getFilters();
      const sortMap: Record<string, string> = {
        newest: 'created_at:desc',
        oldest: 'created_at:asc',
        most_reactions: 'total_reaction_count:desc',
        largest: 'file_size_bytes:desc',
        longest: 'duration_seconds:desc',
      };
      const body: any = {
        query: searchInput.value,
        media_types: filters.types,
        sort: sortMap[filters.sortBy] || null,
        page: currentPage,
        per_page: pageSize,
        filters: {},
      };
      if (filters.channels.length) body.filters.source_channels = filters.channels;
      if (filters.poster) body.filters.poster = filters.poster;
      if (filters.colorGroups.length) {
        body.filters.color_group = filters.colorGroups;
      }
      if (filters.dateFrom || filters.dateTo) body.filters.date_range = { from: filters.dateFrom || undefined, to: filters.dateTo || undefined };
      if (filters.tags) body.filters.tags = filters.tags.split(',').map((t: string) => t.trim()).filter(Boolean);
      if (filters.reactionsMin > 0) body.filters.reaction_count = { min: filters.reactionsMin };
      if (filters.tagsMin > 0) body.filters.tag_count = { min: filters.tagsMin };

      // Update URL to reflect current search state (shareable, back/forward friendly)
      const stateParams = new URLSearchParams();
      if (searchInput.value) stateParams.set('q', searchInput.value);
      if (filters.poster) stateParams.set('poster', filters.poster);
      if (filters.colorGroups.length) stateParams.set('colorgroup', filters.colorGroups.join(','));
      if (filters.channels.length) stateParams.set('channel', filters.channels.join(','));
      if (filters.tags) stateParams.set('tags', filters.tags);
      if (filters.dateFrom) stateParams.set('from', filters.dateFrom);
      if (filters.dateTo) stateParams.set('to', filters.dateTo);
      if (filters.reactionsMin > 0) stateParams.set('rxn', String(filters.reactionsMin));
      if (filters.tagsMin > 0) stateParams.set('mintags', String(filters.tagsMin));
      if (filters.sortBy !== 'newest') stateParams.set('sort', filters.sortBy);
      if (filters.types.length < 3 && filters.types.length > 0) stateParams.set('types', filters.types.join(','));
      if (currentPage > 1) stateParams.set('page', String(currentPage));
      const qs = stateParams.toString();
      const newUrl = window.location.pathname + (qs ? '?' + qs : '');
      history.replaceState(null, '', newUrl);

      try {
        const res = await fetch('/api/search', {
          method: 'POST',
          credentials: 'include',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(body),
        });
        if (!res.ok) throw new Error('Search failed');
        const data = await res.json();
        allResults = data.results || data.hits || [];
        totalResults = data.total || allResults.length;
        loadingEl.style.display = 'none';
        renderResults();
        renderStatsBar(data.counts_by_type || {}, totalResults);
        // Fetch full aggregation stats in background
        fetchStats(body);
      } catch (err: any) {
        loadingEl.style.display = 'none';
        errorEl.textContent = err.message;
        errorEl.style.display = 'block';
      }

      showActiveFilters();
    }

    function updateSelection() {
      if (selectedIds.size > 0) {
        batchBar.style.display = 'flex';
        selectedCount.textContent = selectedIds.size + ' selected';
      } else {
        batchBar.style.display = 'none';
      }
    }

    function formatSize(bytes: number): string {
      if (bytes < 1024) return bytes + ' B';
      if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(1) + ' KB';
      return (bytes / (1024 * 1024)).toFixed(1) + ' MB';
    }

    function renderResults() {
      if (allResults.length === 0) {
        emptyEl.style.display = 'block';
        return;
      }
      emptyEl.style.display = 'none';

      if (currentView === 'grid') {
        tableEl.style.display = 'none';
        gridEl.style.display = 'grid';
        const playSvg = `<svg viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>`;
        gridEl.innerHTML = allResults.map(item => {
          const checked = selectedIds.has(item.id) ? 'checked' : '';
          const selectedClass = selectedIds.has(item.id) ? ' selected' : '';
          const thumb = (item.media_type === 'image' || item.media_type === 'video')
            ? `<img src="/api/media/${item.id}/thumbnail" alt="" loading="lazy" />`
            : `<img src="/assets/default-cover.jpg" alt="${item.media_type || '?'}" loading="lazy" style="image-rendering: pixelated;" />`;
          const canPlay = item.media_type === 'audio' || item.media_type === 'video';
          const playBtn = canPlay
            ? `<button class="grid-item__play" data-play-id="${item.id}" data-play-type="${item.media_type}" title="Play">${playSvg}</button><button class="grid-item__add" data-play-id="${item.id}" data-play-type="${item.media_type}" title="Add to queue">+</button>`
            : '';
          const poster = (item.sources || []).map((s: any) => s.uploader).filter(Boolean)[0] || '';
          const rxn = item.total_reaction_count ?? 0;
          return `<div class="grid-item${selectedClass}" data-id="${item.id}">
            <input type="checkbox" class="grid-item__check" data-select="${item.id}" ${checked} />
            <div class="grid-item__thumb">${thumb}${playBtn}</div>
            <div class="grid-item__info">
              <div class="grid-item__name" title="${item.filename || ''}">
                <button class="bm-star bm-star--sm" data-bm-type="media_item" data-bm-id="${item.id}" title="Bookmark"></button>
                ${item.filename || 'Untitled'}
              </div>
              <div class="grid-item__meta">
                ${poster ? `<span>${poster}</span>` : ''}
                ${rxn > 0 ? `<span>${rxn} rxn</span>` : ''}
                <span>${item.tag_count ?? 0} tags</span>
              </div>
            </div>
          </div>`;
        }).join('');
      } else {
        gridEl.style.display = 'none';
        tableEl.style.display = 'block';
        tbodyEl.innerHTML = allResults.map(item => {
          const checked = selectedIds.has(item.id) ? 'checked' : '';
          const tags = (item.tags || []).join(', ') || '--';
          const date = item.created_at ? new Date(item.created_at * 1000).toLocaleDateString() : '--';
          const poster = (item.sources || []).map((s: any) => s.uploader).filter(Boolean)[0] || '--';
          const channel = (item.source_channels || [])[0] || '--';
          const rxn = item.total_reaction_count ?? 0;
          return `<tr>
            <td><input type="checkbox" data-select="${item.id}" ${checked} /></td>
            <td><a href="/admin/search/detail?id=${item.id}" style="color: var(--color-text); text-decoration: underline;">${item.filename || 'Untitled'}</a></td>
            <td>${item.media_type || '--'}</td>
            <td>${poster}</td>
            <td>${channel}</td>
            <td style="white-space:nowrap;">${item.file_size_bytes ? formatSize(item.file_size_bytes) : '--'}</td>
            <td>${rxn}</td>
            <td>${tags}</td>
            <td style="white-space:nowrap;">${date}</td>
          </tr>`;
        }).join('');
      }

      // Pagination
      const totalPages = Math.ceil(totalResults / pageSize);
      if (totalPages > 1) {
        paginationEl.style.display = 'flex';
        pageInfo.textContent = `Page ${currentPage} of ${totalPages}`;
        (document.getElementById('prev-page') as HTMLButtonElement).disabled = currentPage <= 1;
        (document.getElementById('next-page') as HTMLButtonElement).disabled = currentPage >= totalPages;
      }

      updateSelection();

      // Check bookmarks for visible items
      const bm = (window as any).__bookmarks;
      if (bm) {
        const ids = allResults.map((i: any) => i.id);
        bm.check('media_item', ids).then((set: Set<string>) => {
          document.querySelectorAll('.bm-star[data-bm-type="media_item"]').forEach((el: Element) => {
            const id = (el as HTMLElement).dataset.bmId!;
            if (set.has(id)) {
              el.classList.add('bookmarked');
              el.setAttribute('title', 'Remove bookmark');
            }
          });
        });
      }
    }

    // Delegate click for grid items and checkboxes
    document.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;

      // Bookmark star click
      const starBtn = target.closest('.bm-star') as HTMLElement | null;
      if (starBtn) {
        e.stopPropagation();
        e.preventDefault();
        const bm = (window as any).__bookmarks;
        if (bm) bm.toggle(starBtn.dataset.bmType!, starBtn.dataset.bmId!);
        return;
      }

      // Play button click
      const playBtn = target.closest('.grid-item__play') as HTMLElement | null;
      if (playBtn) {
        e.stopPropagation();
        e.preventDefault();
        const mediaId = playBtn.dataset.playId!;
        const mediaType = playBtn.dataset.playType!;
        const item = allResults.find((i: any) => i.id === mediaId);
        if (!item) return;
        document.dispatchEvent(new CustomEvent('player:queue', {
          detail: {
            tracks: [{
              track_id: mediaId,
              title: item.filename || 'Untitled',
              release_title: '',
              release_code: '',
              media_type: mediaType,
              stream_url: `/api/media/${mediaId}/file`,
              cover_url: (mediaType === 'image' || mediaType === 'video')
                ? `/api/media/${mediaId}/thumbnail` : '/assets/default-cover.jpg',
              duration: 0,
              entity_name: '',
            }],
            startIndex: 0,
          },
        }));
        return;
      }

      // Add to queue button click
      const addBtn = target.closest('.grid-item__add') as HTMLElement | null;
      if (addBtn) {
        e.stopPropagation();
        e.preventDefault();
        const mediaId = addBtn.dataset.playId!;
        const mediaType = addBtn.dataset.playType!;
        const item = allResults.find((i: any) => i.id === mediaId);
        if (!item) return;
        document.dispatchEvent(new CustomEvent('player:add', {
          detail: {
            tracks: [{
              track_id: mediaId,
              title: item.filename || 'Untitled',
              release_title: '',
              release_code: '',
              media_type: mediaType,
              stream_url: `/api/media/${mediaId}/file`,
              cover_url: (mediaType === 'image' || mediaType === 'video')
                ? `/api/media/${mediaId}/thumbnail` : '/assets/default-cover.jpg',
              duration: 0,
              entity_name: '',
            }],
          },
        }));
        return;
      }

      // Checkbox selection
      const checkbox = target.closest('[data-select]') as HTMLInputElement | null;
      if (checkbox) {
        e.stopPropagation();
        const id = checkbox.dataset.select!;
        if (checkbox.checked) selectedIds.add(id);
        else selectedIds.delete(id);
        updateSelection();
        return;
      }

      // Grid item click (navigate)
      const gridItem = target.closest('.grid-item') as HTMLElement | null;
      if (gridItem && !target.closest('.grid-item__check') && !target.closest('.grid-item__play') && !target.closest('.grid-item__add')) {
        const id = gridItem.dataset.id;
        if (id) window.location.href = `/admin/search/detail?id=${id}`;
      }
    });

    async function loadFacets() {
      try {
        const res = await fetch('/api/search/facets', { credentials: 'include' });
        if (!res.ok) return;
        const data = await res.json();
        const channelSelect = document.getElementById('filter-channel') as HTMLSelectElement;
        channelSelect.innerHTML = (data.channels || []).map((ch: string) => `<option value="${ch}">${ch}</option>`).join('');
        const posterSelect = document.getElementById('filter-poster') as HTMLSelectElement;
        posterSelect.innerHTML = '<option value="">All</option>' +
          (data.uploaders || []).map((u: string) => `<option value="${u}">${u}</option>`).join('');
        // Restore from URL after dropdowns are populated
        const p = new URLSearchParams(window.location.search);
        if (p.get('poster')) posterSelect.value = p.get('poster')!;
        if (p.get('channel')) {
          const chs = p.get('channel')!.split(',');
          Array.from(channelSelect.options).forEach(o => { o.selected = chs.includes(o.value); });
        }
      } catch {}
    }

    // Populate UI from URL params
    const initParams = new URLSearchParams(window.location.search);
    function restoreFromUrl() {
      const si = document.getElementById('search-input') as HTMLInputElement;
      if (initParams.get('q') && si) si.value = initParams.get('q')!;

      // Tags: merge ?tag= and ?tags= into one field
      const ft = document.getElementById('filter-tags') as HTMLInputElement;
      const tagVals: string[] = [];
      if (initParams.get('tag')) tagVals.push(initParams.get('tag')!);
      if (initParams.get('tags')) tagVals.push(...initParams.get('tags')!.split(',').map(t => t.trim()).filter(Boolean));
      if (tagVals.length && ft) ft.value = [...new Set(tagVals)].join(', ');

      const fr = document.getElementById('filter-reactions-min') as HTMLInputElement;
      if (initParams.get('rxn') && fr) fr.value = initParams.get('rxn')!;
      const fm = document.getElementById('filter-tags-min') as HTMLInputElement;
      if (initParams.get('mintags') && fm) fm.value = initParams.get('mintags')!;
      const sb = document.getElementById('sort-by') as HTMLSelectElement;
      if (initParams.get('sort') && sb) sb.value = initParams.get('sort')!;

      // Color group checkboxes
      if (initParams.get('colorgroup')) {
        const groups = initParams.get('colorgroup')!.split(',');
        document.querySelectorAll('input[name="color-group"]').forEach(cb => {
          (cb as HTMLInputElement).checked = groups.includes((cb as HTMLInputElement).value);
        });
      }
      // Date range
      if (initParams.get('from')) (document.getElementById('filter-date-from') as HTMLInputElement).value = initParams.get('from')!;
      if (initParams.get('to')) (document.getElementById('filter-date-to') as HTMLInputElement).value = initParams.get('to')!;

      // Media types
      if (initParams.get('types')) {
        const types = initParams.get('types')!.split(',');
        document.querySelectorAll('.filter-check input[type="checkbox"]').forEach(cb => {
          const input = cb as HTMLInputElement;
          if (!input.name) input.checked = types.includes(input.value);
        });
      }

      if (initParams.get('page')) currentPage = parseInt(initParams.get('page')!) || 1;

      // Legacy ?color= param: convert to colorgroup if possible
      if (initParams.get('color') && !initParams.get('colorgroup')) {
        // Old hex color URLs no longer supported; redirect to search
      }
    }

    function clearFilter(filterName: string) {
      switch (filterName) {
        case 'q': searchInput.value = ''; break;
        case 'color': break; // no longer used
        case 'poster': (document.getElementById('filter-poster') as HTMLSelectElement).value = ''; break;
        case 'tags': (document.getElementById('filter-tags') as HTMLInputElement).value = ''; break;
        case 'colorgroup':
          document.querySelectorAll('input[name="color-group"]').forEach(cb => { (cb as HTMLInputElement).checked = false; });
          break;
        case 'channel':
          Array.from((document.getElementById('filter-channel') as HTMLSelectElement).options).forEach(o => { o.selected = false; });
          break;
        case 'dateFrom': (document.getElementById('filter-date-from') as HTMLInputElement).value = ''; break;
        case 'dateTo': (document.getElementById('filter-date-to') as HTMLInputElement).value = ''; break;
        case 'rxn': (document.getElementById('filter-reactions-min') as HTMLInputElement).value = '0'; break;
        case 'mintags': (document.getElementById('filter-tags-min') as HTMLInputElement).value = '0'; break;
        case 'types':
          document.querySelectorAll('.filter-check input[type="checkbox"]').forEach(cb => {
            const input = cb as HTMLInputElement;
            if (!input.name) input.checked = true;
          });
          break;
      }
      currentPage = 1;
      doSearch();
    }
    // Expose for inline onclick
    (window as any).__clearFilter = clearFilter;

    function showActiveFilters() {
      const el = document.getElementById('active-filters')!;
      const filters = getFilters();
      const chips: string[] = [];

      if (searchInput.value) {
        chips.push(`<span class="active-filter">Query: "${searchInput.value}" <button class="active-filter__remove" onclick="__clearFilter('q')">&times;</button></span>`);
      }
      if (filters.colorGroups.length) {
        chips.push(`<span class="active-filter">Colors: ${filters.colorGroups.join(', ')} <button class="active-filter__remove" onclick="__clearFilter('colorgroup')">&times;</button></span>`);
      }
      if (filters.tags) {
        chips.push(`<span class="active-filter">Tags: ${filters.tags} <button class="active-filter__remove" onclick="__clearFilter('tags')">&times;</button></span>`);
      }
      if (filters.poster) {
        chips.push(`<span class="active-filter">Posted by: ${filters.poster} <button class="active-filter__remove" onclick="__clearFilter('poster')">&times;</button></span>`);
      }
      if (filters.channels.length) {
        chips.push(`<span class="active-filter">Channel: ${filters.channels.join(', ')} <button class="active-filter__remove" onclick="__clearFilter('channel')">&times;</button></span>`);
      }
      if (filters.dateFrom) {
        chips.push(`<span class="active-filter">From: ${filters.dateFrom} <button class="active-filter__remove" onclick="__clearFilter('dateFrom')">&times;</button></span>`);
      }
      if (filters.dateTo) {
        chips.push(`<span class="active-filter">To: ${filters.dateTo} <button class="active-filter__remove" onclick="__clearFilter('dateTo')">&times;</button></span>`);
      }
      if (filters.reactionsMin > 0) {
        chips.push(`<span class="active-filter">Min reactions: ${filters.reactionsMin} <button class="active-filter__remove" onclick="__clearFilter('rxn')">&times;</button></span>`);
      }
      if (filters.tagsMin > 0) {
        chips.push(`<span class="active-filter">Min tags: ${filters.tagsMin} <button class="active-filter__remove" onclick="__clearFilter('mintags')">&times;</button></span>`);
      }
      if (filters.types.length < 3 && filters.types.length > 0) {
        chips.push(`<span class="active-filter">Types: ${filters.types.join(', ')} <button class="active-filter__remove" onclick="__clearFilter('types')">&times;</button></span>`);
      }

      if (chips.length > 0) {
        chips.push(`<button class="action-btn" onclick="location.href='/admin/search'" style="margin-left:auto;">Clear All</button>`);
        el.innerHTML = chips.join('');
        el.style.display = 'flex';
      } else {
        el.innerHTML = '';
        el.style.display = 'none';
      }
    }

    // --- Stats bar & Insights rendering ---

    function renderStatsBar(countsByType: Record<string, number>, total: number) {
      const statsBar = document.getElementById('stats-bar')!;
      if (total === 0) { statsBar.style.display = 'none'; return; }

      const parts: string[] = [`<span class="stat-total">${total.toLocaleString()} results</span>`];
      const typeLabels: Record<string, string> = { image: 'images', audio: 'audio', video: 'videos' };
      for (const [type, label] of Object.entries(typeLabels)) {
        const count = countsByType[type];
        if (count > 0) {
          parts.push(`<span class="stat-sep">/</span>`);
          parts.push(`<span class="stat-type" data-type-filter="${type}">${count} ${label}</span>`);
        }
      }
      statsBar.innerHTML = parts.join(' ');
      statsBar.style.display = 'flex';

      // Click type counts to filter
      statsBar.querySelectorAll('.stat-type').forEach(el => {
        el.addEventListener('click', () => {
          const type = (el as HTMLElement).dataset.typeFilter!;
          document.querySelectorAll('.filter-check input[type="checkbox"]').forEach(cb => {
            const input = cb as HTMLInputElement;
            if (!input.name) input.checked = input.value === type;
          });
          currentPage = 1;
          doSearch();
        });
      });
    }

    async function fetchStats(searchBody: any) {
      try {
        const res = await fetch('/api/search/stats', {
          method: 'POST',
          credentials: 'include',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(searchBody),
        });
        if (!res.ok) return;
        const stats = await res.json();
        renderInsights(stats);
      } catch {}
    }

    function renderInsights(stats: any) {
      const section = document.getElementById('insights-section')!;
      section.style.display = 'block';

      renderBarChart('insight-uploaders', 'Top Posters', stats.top_uploaders || [], 'uploader', 'count');
      renderBarChart('insight-tags', 'Top Tags', stats.top_tags || [], 'tag', 'count');
      renderReactionChart(stats.reaction_buckets || []);
      renderTimeline(stats.date_histogram || []);
      renderColorChart(stats.color_groups || {});
    }

    function renderBarChart(containerId: string, title: string, items: any[], labelKey: string, countKey: string) {
      const el = document.getElementById(containerId)!;
      if (!items.length) { el.innerHTML = ''; return; }
      const max = Math.max(...items.map(i => i[countKey]), 1);
      const rows = items.slice(0, 10).map(item => {
        const pct = Math.round((item[countKey] / max) * 100);
        const label = item[labelKey];
        return `<div class="insight-bar-row insight-clickable" data-insight-type="${labelKey}" data-insight-value="${label}" title="${label}: ${item[countKey]}">
          <span class="insight-bar-label">${label}</span>
          <span class="insight-bar-track"><span class="insight-bar-fill" style="width:${pct}%"></span></span>
          <span class="insight-bar-count">${item[countKey]}</span>
        </div>`;
      }).join('');
      el.innerHTML = `<div class="insight-title">${title}</div>${rows}`;

      // Click to filter
      el.querySelectorAll('.insight-clickable').forEach(row => {
        row.addEventListener('click', () => {
          const type = (row as HTMLElement).dataset.insightType!;
          const value = (row as HTMLElement).dataset.insightValue!;
          if (type === 'tag') {
            const tagInput = document.getElementById('filter-tags') as HTMLInputElement;
            const existing = tagInput.value.split(',').map(t => t.trim()).filter(Boolean);
            if (!existing.includes(value)) {
              existing.push(value);
              tagInput.value = existing.join(', ');
            }
          } else if (type === 'uploader') {
            (document.getElementById('filter-poster') as HTMLSelectElement).value = value;
          }
          currentPage = 1;
          doSearch();
        });
      });
    }

    function renderReactionChart(buckets: any[]) {
      const el = document.getElementById('insight-reactions')!;
      if (!buckets.length) { el.innerHTML = ''; return; }
      const max = Math.max(...buckets.map(b => b.count), 1);
      const rows = buckets.map(b => {
        // Extract minimum value from label (e.g. "3-5" → 3, "26+" → 26, "0" → 0)
        const minVal = parseInt(b.label.replace('+', ''));
        const pct = Math.round((b.count / max) * 100);
        return `<div class="insight-bar-row insight-clickable" data-reaction-min="${minVal}" title="${b.label} reactions: ${b.count} items">
          <span class="insight-bar-label">${b.label}</span>
          <span class="insight-bar-track"><span class="insight-bar-fill" style="width:${pct}%"></span></span>
          <span class="insight-bar-count">${b.count}</span>
        </div>`;
      }).join('');
      el.innerHTML = `<div class="insight-title">Reactions</div>${rows}`;

      el.querySelectorAll('.insight-clickable').forEach(row => {
        row.addEventListener('click', () => {
          const minVal = (row as HTMLElement).dataset.reactionMin!;
          (document.getElementById('filter-reactions-min') as HTMLInputElement).value = minVal;
          currentPage = 1;
          doSearch();
        });
      });
    }

    function renderTimeline(histogram: any[]) {
      const el = document.getElementById('insight-timeline')!;
      if (!histogram.length) { el.innerHTML = ''; return; }
      const max = Math.max(...histogram.map(h => h.count), 1);
      // Show last 12 months max
      const recent = histogram.slice(-12);
      const rows = recent.map(h => {
        const pct = Math.round((h.count / max) * 100);
        return `<div class="insight-bar-row insight-clickable" data-month="${h.month}" title="${h.month}: ${h.count} items">
          <span class="insight-bar-label">${h.month}</span>
          <span class="insight-bar-track"><span class="insight-bar-fill" style="width:${pct}%"></span></span>
          <span class="insight-bar-count">${h.count}</span>
        </div>`;
      }).join('');
      el.innerHTML = `<div class="insight-title">Timeline</div>${rows}`;

      el.querySelectorAll('.insight-clickable').forEach(row => {
        row.addEventListener('click', () => {
          const month = (row as HTMLElement).dataset.month!; // "YYYY-MM"
          const [year, mon] = month.split('-').map(Number);
          const lastDay = new Date(year, mon, 0).getDate();
          (document.getElementById('filter-date-from') as HTMLInputElement).value = `${month}-01`;
          (document.getElementById('filter-date-to') as HTMLInputElement).value = `${month}-${String(lastDay).padStart(2, '0')}`;
          currentPage = 1;
          doSearch();
        });
      });
    }

    function renderColorChart(colorGroups: Record<string, number>) {
      const el = document.getElementById('insight-colors')!;
      const entries = Object.entries(colorGroups).sort((a, b) => b[1] - a[1]);
      if (!entries.length) { el.innerHTML = ''; return; }
      const max = Math.max(...entries.map(e => e[1]), 1);
      const colorMap: Record<string, string> = {
        red: '#e53935', orange: '#fb8c00', yellow: '#fdd835', green: '#43a047',
        teal: '#00897b', blue: '#1e88e5', purple: '#8e24aa', pink: '#d81b60',
        brown: '#6d4c41', beige: '#d7ccc8', gray: '#9e9e9e', black: '#212121', white: '#f5f5f5',
      };
      const rows = entries.map(([color, count]) => {
        const pct = Math.round((count / max) * 100);
        const hex = colorMap[color] || '#999';
        return `<div class="insight-bar-row" title="${color}: ${count} items" data-color-filter="${color}">
          <span class="insight-bar-label" style="display:flex;align-items:center;justify-content:flex-end;gap:4px;">
            <span style="display:inline-block;width:10px;height:10px;background:${hex};border:1px solid #ccc;flex-shrink:0;"></span>
            ${color}
          </span>
          <span class="insight-bar-track"><span class="insight-bar-fill" style="width:${pct}%;background:${hex}"></span></span>
          <span class="insight-bar-count">${count}</span>
        </div>`;
      }).join('');
      el.innerHTML = `<div class="insight-title">Colors</div>${rows}`;

      // Click to filter by color
      el.querySelectorAll('[data-color-filter]').forEach(row => {
        row.addEventListener('click', () => {
          const color = (row as HTMLElement).dataset.colorFilter!;
          document.querySelectorAll('input[name="color-group"]').forEach(cb => {
            (cb as HTMLInputElement).checked = (cb as HTMLInputElement).value === color;
          });
          currentPage = 1;
          doSearch();
        });
      });
    }

    // Restore form state from URL, load facets, then run first search
    restoreFromUrl();
    await loadFacets();
    doSearch();
  });
</script>
