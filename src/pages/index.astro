---
import Base from '../layouts/Base.astro';
---

<Base title="A-U.SUPPLY — Audio Units Division">
  <main class="back-cover">
    <div class="back-cover__content">
      <div class="back-cover__image">
        <img src="/assets/aedas-800.jpg" alt="An Electronically Deduced Aural Syllomis" />
      </div>

      <div class="back-cover__brand">
        <h1 class="back-cover__title">A-U.SUPPLY</h1>
        <p class="back-cover__subtitle">Audio Units Division</p>
      </div>

      <div class="back-cover__contact">
        ausupply000@gmail.com<br />
        https://a-u.supply
      </div>

      <p class="back-cover__quote">
        "Your only choice will be between a goat's ass and the face of god."
      </p>

      <div class="back-cover__doc">
        Document No: AU-REF-2026-001 &nbsp;|&nbsp; Revision 01 &nbsp;|&nbsp; 2026-03-23
      </div>
    </div>
  </main>
</Base>

<style>
  .back-cover {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    min-height: calc(100vh - 7rem);
    padding: var(--space-md) var(--space-md);
  }

  .back-cover__content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-md);
  }

  .back-cover__image img {
    max-height: min(35vh, 280px);
    width: auto;
    border: 1px solid var(--color-border);
  }

  .back-cover__title {
    font-size: var(--text-xl);
    font-weight: bold;
    letter-spacing: 2pt;
    text-transform: uppercase;
    margin-bottom: var(--space-xs);
  }

  .back-cover__subtitle {
    font-size: var(--text-base);
    letter-spacing: 1pt;
    color: var(--color-muted);
  }

  .back-cover__contact {
    font-size: var(--text-sm);
    line-height: 2;
    color: var(--color-muted);
  }

  .back-cover__quote {
    font-size: var(--text-sm);
    font-style: italic;
    color: var(--color-muted);
  }

  .back-cover__doc {
    font-size: 0.5rem;
    color: var(--color-border);
  }
</style>
