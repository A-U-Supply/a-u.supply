---
import Base from '../../layouts/Base.astro';
---

<Base title="A-U.SUPPLY — Product Catalog">
  <main class="catalog">
    <header class="catalog__header">
      <h1 class="catalog__title">Product Catalog</h1>
      <p class="catalog__subtitle">Audio Units Division</p>
    </header>

    <div class="catalog__filters">
      <div class="filter-group">
        <label for="filter-entity">Entity</label>
        <select id="filter-entity">
          <option value="">All Entities</option>
        </select>
      </div>
      <div class="filter-group">
        <label for="filter-year">Year</label>
        <select id="filter-year">
          <option value="">All Years</option>
        </select>
      </div>
      <div class="filter-group">
        <label for="filter-sort">Sort</label>
        <select id="filter-sort">
          <option value="date_desc">Date (newest)</option>
          <option value="date_asc">Date (oldest)</option>
          <option value="title">Title</option>
          <option value="code">Product Code</option>
        </select>
      </div>
    </div>

    <div id="loading" class="catalog__status">Loading catalog...</div>
    <div id="error" class="catalog__status catalog__status--error" style="display:none;"></div>
    <div id="empty" class="catalog__status" style="display:none;">No releases found.</div>

    <div id="grid" class="catalog__grid" style="display:none;"></div>
  </main>

  <footer class="footer">
    <span class="footer__doc">A-U.SUPPLY</span>
    <span class="footer__contact">ausupply000@gmail.com</span>
    <span class="footer__site">a-u.supply</span>
  </footer>
</Base>

<style>
  .catalog {
    max-width: 1200px;
    margin: 0 auto;
    padding: var(--space-md);
    min-height: calc(100vh - 4rem);
  }

  .catalog__header {
    margin-bottom: var(--space-lg);
  }

  .catalog__back {
    font-size: var(--text-sm);
    color: var(--color-muted);
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 1pt;
  }
  .catalog__back:hover {
    color: var(--color-accent);
  }

  .catalog__title {
    font-size: var(--text-2xl);
    font-weight: bold;
    letter-spacing: 2pt;
    text-transform: uppercase;
    margin-top: var(--space-xs);
    margin-bottom: var(--space-xs);
  }

  .catalog__subtitle {
    font-size: var(--text-sm);
    color: var(--color-muted);
    letter-spacing: 1pt;
    text-transform: uppercase;
  }

  .catalog__filters {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-bottom: var(--space-md);
    padding: var(--space-sm);
    border: 1px solid var(--color-border);
  }

  .filter-group {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .filter-group label {
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.5pt;
    color: var(--color-muted);
  }

  .filter-group select {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    padding: 4px 8px;
    border: 1px solid var(--color-border);
    background: var(--color-bg);
    color: var(--color-text);
    cursor: pointer;
    min-width: 140px;
  }
  .filter-group select:focus {
    outline: 1px solid var(--color-accent);
    border-color: var(--color-accent);
  }

  .catalog__status {
    color: var(--color-muted);
    font-size: var(--text-sm);
    padding: var(--space-md) 0;
  }
  .catalog__status--error {
    color: #c00;
  }

  .catalog__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: var(--space-md);
  }

  .footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--space-sm) var(--space-md);
    border-top: 1px solid var(--color-border);
    font-size: var(--text-sm);
    color: var(--color-muted);
    max-width: 1200px;
    margin: 0 auto;
  }

  @media (max-width: 640px) {
    .catalog__grid {
      grid-template-columns: 1fr;
    }
    .catalog__filters {
      flex-direction: column;
    }
    .footer {
      flex-direction: column;
      text-align: center;
      gap: var(--space-xs);
    }
  }
</style>

<script>
  let allReleases: any[] = [];

  async function init() {
    await Promise.all([loadEntities(), loadReleases()]);
    setupFilters();
  }

  async function loadEntities() {
    try {
      const res = await fetch('/api/entities');
      if (!res.ok) return;
      const entities = await res.json();
      const select = document.getElementById('filter-entity') as HTMLSelectElement;
      entities.forEach((e: any) => {
        const opt = document.createElement('option');
        opt.value = e.slug;
        opt.textContent = e.name;
        select.appendChild(opt);
      });
    } catch { /* ignore */ }
  }

  async function loadReleases() {
    const loadingEl = document.getElementById('loading')!;
    const errorEl = document.getElementById('error')!;

    try {
      const res = await fetch('/api/releases');
      if (!res.ok) throw new Error('Failed to load catalog');
      const data = await res.json();
      allReleases = data.releases || [];
      loadingEl.style.display = 'none';

      // Populate year filter from actual data
      const years = new Set<string>();
      allReleases.forEach((r: any) => {
        if (r.release_date) years.add(r.release_date.substring(0, 4));
      });
      const yearSelect = document.getElementById('filter-year') as HTMLSelectElement;
      Array.from(years).sort().reverse().forEach(y => {
        const opt = document.createElement('option');
        opt.value = y;
        opt.textContent = y;
        yearSelect.appendChild(opt);
      });

      renderGrid();
    } catch (err: any) {
      loadingEl.style.display = 'none';
      errorEl.textContent = err.message;
      errorEl.style.display = 'block';
    }
  }

  function setupFilters() {
    const entitySel = document.getElementById('filter-entity') as HTMLSelectElement;
    const yearSel = document.getElementById('filter-year') as HTMLSelectElement;
    const sortSel = document.getElementById('filter-sort') as HTMLSelectElement;

    const onChange = () => {
      loadFiltered(entitySel.value, yearSel.value, sortSel.value);
    };

    entitySel.addEventListener('change', onChange);
    yearSel.addEventListener('change', onChange);
    sortSel.addEventListener('change', onChange);
  }

  async function loadFiltered(entity: string, year: string, sort: string) {
    const params = new URLSearchParams();
    if (entity) params.set('entity', entity);
    if (year) params.set('year', year);
    params.set('sort', sort);

    const loadingEl = document.getElementById('loading')!;
    const errorEl = document.getElementById('error')!;
    loadingEl.style.display = 'block';

    try {
      const res = await fetch(`/api/releases?${params}`);
      if (!res.ok) throw new Error('Failed to load catalog');
      const data = await res.json();
      allReleases = data.releases || [];
      loadingEl.style.display = 'none';
      renderGrid();
    } catch (err: any) {
      loadingEl.style.display = 'none';
      errorEl.textContent = err.message;
      errorEl.style.display = 'block';
    }
  }

  function formatDuration(totalSeconds: number): string {
    if (!totalSeconds) return '--:--';
    const m = Math.floor(totalSeconds / 60);
    const s = Math.floor(totalSeconds % 60);
    return `${m}:${s.toString().padStart(2, '0')}`;
  }

  function renderGrid() {
    const grid = document.getElementById('grid')!;
    const emptyEl = document.getElementById('empty')!;

    if (allReleases.length === 0) {
      grid.style.display = 'none';
      emptyEl.style.display = 'block';
      return;
    }

    emptyEl.style.display = 'none';
    grid.style.display = 'grid';

    grid.innerHTML = allReleases.map((r: any) => {
      const code = r.product_code;
      const encoded = encodeURIComponent(code);
      const entities = (r.entities || []).map((e: any) => e.name).join(', ') || 'Unknown';
      const date = r.release_date || '----';
      const tracks = r.track_count ?? 0;
      const duration = formatDuration(r.total_duration_seconds || 0);
      const coverUrl = r.cover_art_url
        ? `/api/releases/${encoded}/cover?size=thumb`
        : '';

      const coverHtml = coverUrl
        ? `<img class="card__cover" src="${coverUrl}" alt="${r.title || code}" loading="lazy">`
        : `<div class="card__cover card__cover--empty">NO COVER</div>`;

      return `<a href="/catalog/release?code=${encoded}" class="card">
        ${coverHtml}
        <div class="card__body">
          <span class="card__code">${code}</span>
          <span class="card__title">${r.title || '(untitled)'}</span>
          <span class="card__artist">${entities}</span>
          <div class="card__meta">
            <span>${date}</span>
            <span>${tracks} trk &middot; ${duration}</span>
          </div>
        </div>
      </a>`;
    }).join('');
  }

  // Run on initial load and on View Transition navigations
  document.addEventListener('astro:page-load', () => init());
</script>

<style is:global>
  .card {
    display: block;
    border: 1px solid var(--color-border);
    text-decoration: none;
    color: var(--color-text);
    transition: border-color 0.15s;
  }
  .card:hover {
    border-color: var(--color-accent);
  }

  .card__cover {
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
    border-bottom: 1px solid var(--color-border);
  }
  .card__cover--empty {
    display: flex;
    align-items: center;
    justify-content: center;
    background: #f5f5f5;
    color: var(--color-muted);
    font-size: var(--text-sm);
    letter-spacing: 1pt;
  }

  .card__body {
    padding: var(--space-sm);
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .card__code {
    font-size: 0.65rem;
    color: var(--color-muted);
    letter-spacing: 0.5pt;
    text-transform: uppercase;
  }

  .card__title {
    font-size: var(--text-base);
    font-weight: bold;
    line-height: 1.3;
  }

  .card__artist {
    font-size: var(--text-sm);
    color: var(--color-muted);
  }

  .card__meta {
    display: flex;
    justify-content: space-between;
    font-size: 0.65rem;
    color: var(--color-muted);
    margin-top: var(--space-xs);
    border-top: 1px solid var(--color-border);
    padding-top: var(--space-xs);
  }
</style>
