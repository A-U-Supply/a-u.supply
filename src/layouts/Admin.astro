---
import { ViewTransitions } from 'astro:transitions';
import Player from '../components/Player.svelte';

interface Props {
  title: string;
  current?: string;
}
const { title, current } = Astro.props;
---

<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="icon" type="image/jpeg" href="/favicon.jpg">
  <title>{title} — A-U.SUPPLY Admin</title>
  <ViewTransitions />
</head>
<body>
  <button class="sidebar__toggle" id="sidebar-toggle">|||</button>

  <div class="admin-shell">
    <aside class="sidebar" id="sidebar">
      <div class="sidebar__brand">
        <a href="/">A-U.SUPPLY</a>
      </div>

      <div class="sidebar__section">Navigation</div>
      <ul class="sidebar__nav">
        <li><a href="/admin/catalog" aria-current={current === 'catalog' ? 'page' : undefined}>Catalog</a></li>
        <li><a href="/admin/catalog/new" aria-current={current === 'catalog-new' ? 'page' : undefined}>New Release</a></li>
        <li><a href="/admin/dashboard" aria-current={current === 'dashboard' ? 'page' : undefined}>Dashboard</a></li>
        <li><a href="/admin/files" aria-current={current === 'files' ? 'page' : undefined}>Files</a></li>
        <li><a href="/admin/settings" aria-current={current === 'settings' ? 'page' : undefined}>Settings</a></li>
      </ul>

      <div class="sidebar__section">Search Engine</div>
      <ul class="sidebar__nav">
        <li><a href="/admin/search" aria-current={current === 'search' ? 'page' : undefined}>Search</a></li>
        <li><a href="/admin/search/triage" aria-current={current === 'triage' ? 'page' : undefined}>Triage</a></li>
        <li><a href="/admin/search/upload" aria-current={current === 'upload' ? 'page' : undefined}>Upload</a></li>
        <li><a href="/admin/search/failures" aria-current={current === 'failures' ? 'page' : undefined}>Failures</a></li>
        <li><a href="/admin/api-keys" aria-current={current === 'api-keys' ? 'page' : undefined}>API Keys</a></li>
      </ul>

      <div class="sidebar__section">App Runner</div>
      <ul class="sidebar__nav">
        <li><a href="/admin/search/workspace" aria-current={current === 'workspace' ? 'page' : undefined}>Workspace</a></li>
        <li><a href="/admin/jobs" aria-current={current === 'jobs' ? 'page' : undefined}>Jobs</a></li>
      </ul>

      <div class="sidebar__footer">
        <div class="sidebar__user" id="sidebar-user"></div>
        <button class="sidebar__logout" id="logout-btn">Log Out</button>
      </div>
    </aside>

    <main class="admin-main">
      <div class="page-loading" id="page-loading" style="display:none;">
        <span class="loading-dots">Loading</span>
      </div>
      <slot />
    </main>
  </div>
  <div class="player-slot" transition:persist="audio-player">
    <Player client:only="svelte" />
  </div>
  <div class="toast-container" id="toast-container"></div>
</body>
</html>

<style is:global>
  @import '../styles/global.css';
  @import '../styles/admin.css';
</style>

<script>
  // Show loading indicator during ViewTransition navigations
  document.addEventListener('astro:before-preparation', () => {
    const loader = document.getElementById('page-loading');
    if (loader) loader.style.display = 'block';
  });

  document.addEventListener('astro:page-load', () => {
    const loader = document.getElementById('page-loading');
    if (loader) loader.style.display = 'none';

    // Auth check — redirect to login if not authenticated
    // Expose as a promise on window so page scripts can await it
    // regardless of script loading order (no race condition)
    let resolveAuth: (user: any) => void;
    (window as any).__authReady = new Promise((r) => { resolveAuth = r; });

    async function checkAuth() {
      try {
        const res = await fetch('/api/me', { credentials: 'include' });
        if (!res.ok) {
          window.location.href = '/login';
          return;
        }
        const user = await res.json();
        const userEl = document.getElementById('sidebar-user');
        if (userEl) userEl.textContent = user.name;
        resolveAuth!(user);
      } catch {
        window.location.href = '/login';
      }
    }
    checkAuth();

    // Logout
    document.getElementById('logout-btn')?.addEventListener('click', async () => {
      await fetch('/api/logout', { method: 'POST', credentials: 'include' });
      window.location.href = '/login';
    });

    // Mobile sidebar toggle
    document.getElementById('sidebar-toggle')?.addEventListener('click', () => {
      document.getElementById('sidebar')?.classList.toggle('open');
    });

    // Close sidebar when clicking outside on mobile
    document.addEventListener('click', (e) => {
      const sidebar = document.getElementById('sidebar');
      const toggle = document.getElementById('sidebar-toggle');
      if (sidebar?.classList.contains('open') &&
          !sidebar.contains(e.target as Node) &&
          !toggle?.contains(e.target as Node)) {
        sidebar.classList.remove('open');
      }
    });

    // Dialog dismiss: Escape key and click-outside
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        const open = document.querySelector('.dialog-overlay[style*="flex"]') as HTMLElement | null;
        if (open) { open.style.display = 'none'; e.preventDefault(); }
      }
    });
    document.addEventListener('click', (e) => {
      const overlay = (e.target as HTMLElement).closest('.dialog-overlay');
      if (overlay && e.target === overlay) {
        (overlay as HTMLElement).style.display = 'none';
      }
    });

    // Toast notification system
    const toastContainer = document.getElementById('toast-container')!;
    function showToast(message: string, type: 'success' | 'error' = 'success') {
      const toast = document.createElement('div');
      toast.className = `toast toast--${type}`;
      toast.innerHTML = `<span>${message}</span><button class="toast__close">&times;</button>`;
      toast.querySelector('.toast__close')!.addEventListener('click', () => removeToast(toast));
      toastContainer.appendChild(toast);
      setTimeout(() => removeToast(toast), 4000);
    }
    function removeToast(toast: HTMLElement) {
      if (toast.classList.contains('removing')) return;
      toast.classList.add('removing');
      toast.addEventListener('animationend', () => toast.remove());
    }
    (window as any).toast = {
      success: (msg: string) => showToast(msg, 'success'),
      error: (msg: string) => showToast(msg, 'error'),
    };

    // Confirm dialog: returns a Promise<boolean>
    (window as any).confirmDialog = (message: string, dangerLabel = 'Confirm') => {
      return new Promise<boolean>((resolve) => {
        let overlay = document.getElementById('shared-confirm-dialog');
        if (!overlay) {
          overlay = document.createElement('div');
          overlay.id = 'shared-confirm-dialog';
          overlay.className = 'dialog-overlay';
          overlay.innerHTML = `<div class="dialog">
            <p id="confirm-message"></p>
            <div class="dialog-actions">
              <button class="btn-cancel" id="confirm-no">Cancel</button>
              <button class="btn-danger" id="confirm-yes"></button>
            </div>
          </div>`;
          document.body.appendChild(overlay);
        }
        document.getElementById('confirm-message')!.textContent = message;
        document.getElementById('confirm-yes')!.textContent = dangerLabel;
        overlay.style.display = 'flex';

        const cleanup = (result: boolean) => {
          overlay!.style.display = 'none';
          resolve(result);
        };
        document.getElementById('confirm-no')!.onclick = () => cleanup(false);
        document.getElementById('confirm-yes')!.onclick = () => cleanup(true);
      });
    };
  });
</script>
