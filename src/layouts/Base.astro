---
import { ViewTransitions } from 'astro:transitions';
import Player from '../components/Player.svelte';

interface Props {
  title: string;
}
const { title } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <link rel="icon" type="image/jpeg" href="/favicon.jpg">
  <title>{title}</title>
  <ViewTransitions />
</head>
<body>
  <div class="nav-progress" id="nav-progress"></div>
  <header class="header">
    <div class="header__inner">
      <a href="/" class="header__logo">
        <img src="/assets/logo.png" alt="A-U.Supply" />
      </a>
    </div>
  </header>
  <div class="content-wrap">
    <slot />
  </div>
  <footer class="site-footer">
    <nav class="site-footer__nav">
      <a href="/catalog">AU-CAT</a>
      <span class="site-footer__dot">&middot;</span>
      <a href="/profile">AU-CP</a>
      <span class="site-footer__dot">&middot;</span>
      <a href="/personnel">AU-PD</a>
      <span class="site-footer__dot">&middot;</span>
      <a href="/channels">AU-DC</a>
      <span class="site-footer__dot">&middot;</span>
      <a href="/entities">AU-AE</a>
      <span class="site-footer__dot">&middot;</span>
      <a href="/infrastructure">AU-PI</a>
      <span class="site-footer__dot">&middot;</span>
      <a href="/the-expenditure">AU-EXP</a>
      <span class="site-footer__dot">&middot;</span>
      <a href="/admin/dashboard">AUP-1</a>
    </nav>
  </footer>
  <div class="player-spacer"></div>
  <div class="player-slot" transition:persist="audio-player">
    <Player client:only="svelte" />
  </div>
</body>
</html>

<style is:global>
  @import '../styles/global.css';

  body {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
  }

  .header {
    border-bottom: 1px solid var(--color-border);
    padding: var(--space-sm) var(--space-md);
  }

  .header__inner {
    max-width: 960px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .header__logo {
    display: block;
    line-height: 0;
  }

  .header__logo img {
    height: 48px;
    width: auto;
  }

  .content-wrap {
    display: flex;
    flex-direction: column;
  }

  .site-footer {
    border-top: 1px solid var(--color-border);
    padding: var(--space-sm) var(--space-md) var(--space-lg);
    text-align: center;
  }

  .site-footer__nav {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 1.5pt;
  }

  .site-footer__nav a {
    color: var(--color-muted);
    text-decoration: none;
  }

  .site-footer__nav a:hover {
    color: var(--color-accent);
  }

  .site-footer__dot {
    color: var(--color-muted);
    margin: 0 0.3em;
  }

  .nav-progress {
    position: fixed;
    top: 0;
    left: 0;
    height: 2px;
    background: var(--color-accent);
    z-index: 9999;
    width: 0;
    opacity: 0;
    transition: width 0.3s ease, opacity 0.2s;
  }

  .nav-progress.active {
    opacity: 1;
    animation: progress-grow 2s ease-out forwards;
  }

  @keyframes progress-grow {
    0% { width: 0; }
    50% { width: 60%; }
    100% { width: 90%; }
  }

  @media (max-width: 640px) {
    .header__logo img {
      height: 36px;
    }

    .site-footer__nav {
      font-size: 0.5rem;
      letter-spacing: 1pt;
      line-height: 2;
    }

    .site-footer {
      padding-bottom: calc(var(--space-xl) + env(safe-area-inset-bottom, 0px));
    }
  }
</style>

<script>
  document.addEventListener('astro:before-preparation', () => {
    const bar = document.getElementById('nav-progress');
    if (bar) {
      bar.style.width = '0';
      bar.classList.add('active');
    }
  });

  document.addEventListener('astro:page-load', () => {
    const bar = document.getElementById('nav-progress');
    if (bar) {
      bar.style.width = '100%';
      setTimeout(() => {
        bar.classList.remove('active');
        bar.style.width = '0';
      }, 200);
    }
  });
</script>
